      <CheatEntries>
        <CheatEntry>
          <ID>7829</ID>
          <Description>"Compact Mode"</Description>
          <Color>0080FF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
LuaCall(cycleFullCompact(nil,true))


[DISABLE]
