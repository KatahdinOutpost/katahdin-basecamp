          <Color>00FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : Magicraft.exe
  Version: 1.2.23
  Date   : 2026-03-13
  Author : It4chi
}

define(bytes,48 8B 40 20 48 83 C4 28)

// 48 8B 40 18 48 85 C0 -&gt; Old

[ENABLE]
aobscanmodule(aob_Player,GameAssembly.dll,48 8B 40 20 48 83 C4 28 C3 E8 ? ? ? ? CC CC CC CC CC 48 89 5C 24 08 48 89 6C 24 10)
assert(aob_Player,bytes)
alloc(Script,$50,aob_Player)
registersymbol(aob_Player)
alloc(Base_Address,8)
registersymbol(Base_Address)
label(return)

Script:
  mov [Base_Address],rax
  mov rax,[rax+20]
  add rsp,28
  jmp return

aob_Player:
  jmp Script
  nop 3
return:

[DISABLE]

aob_Player:
  db bytes

dealloc(*)
unregistersymbol(*)

