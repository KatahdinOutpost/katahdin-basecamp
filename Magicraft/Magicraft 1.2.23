        <CheatEntry>
          <ID>7836</ID>
          <Description>"Godmode / OneHit Kill / Health (on error, restart the game and let the game load your player) "</Description>
          <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
          <Color>00FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : Magicraft.exe
  Version: 1.2.23
  Date   : 2026-04-02
  Author : It4chi
}

define(abytes,C4 41 7A 11 BF 60 02 00 00)

define(phbytes,C5 FC 10 84 11 A0 02 00 00)

[ENABLE]

aobscanmodule(aob_aHealth,lib_burst_generated.dll,C4 41 7A 11 BF 60 02 00 00)
assert(aob_aHealth,bytes)
registersymbol(aob_aHealth)
alloc(aScript,$60,aob_aHealth)
label(areturn)

alloc(GSummon,1)
registersymbol(GSummon)

alloc(OneHit,1)
registersymbol(OneHit)

Label(Summon)
Label(Enemy)
Label(oCode)

GSummon:
  db 0
Onehit:
  db 0


aScript:
  pushfq                        // Save Flags
  cmp [r15],#800001             // Player -&gt; rdx = ID; r15 = ID; [r15+10] = ID
  je oCode
  cmp rcx,0                     // Enemy Check (Player and Summons haven't rcx)
  je Summon
  jmp Enemy

Summon:
  cmp byte ptr [GSummon],1
  jne oCode
  vucomiss xmm15, xmm1          // Check for Damage
  ja oCode                      // No Damage (Heal) = Pass
  popfq                         // Resore Flags -&gt; Wrong Flags = Crash
  jmp areturn                   // If Damage = Retun Nop -&gt; No Damage/Godmode

Enemy:
  cmp byte ptr [OneHit],1
  jne oCode
  vsubss xmm15,xmm1,xmm1        // xmm0 = Damage; xmm1 = Current Healt, xmm15 = New Current Health

oCode:
  popfq                         // Restore Flags -&gt; Wrong Flags = Crash
  vmovss [r15+260],xmm15        // [r15+18] = Max HP; [r15+260] = Current Health; [r15+264] = Shield; [r15+268] = Temp Shield
  jmp areturn

aob_aHealth:
  jmp aScript
  nop 4
areturn:


//////////////////////////////////////////////////////////////////////////////////////

aobscanmodule(aob_playerhealth,lib_burst_generated.dll,C5 FC 10 84 11 A0 02 00 00)
assert(aob_playerhealth,bytes)
registersymbol(aob_playerhealth)
alloc(phScript,$60,aob_playerhealth)
label(phreturn)

alloc(Player,8)
registersymbol(Player)

alloc(Godmode,1)
registersymbol(Godmode)

Godmode:
  db 0

phScript:
  pushfq
  cmp [rcx+rdx+40],#800001           // [rcx+rdx+40] = PlayerID; [rcx+rdx+50] = PlayerID
  jne @f
  push rax
  lea rax,[rcx+rdx]                  // Base Address for Player Values
  mov [Player],rax
  pop rax
  cmp byte ptr [Godmode],1
  jne @f
  push rax
  mov eax,[rcx+rdx+58]               // [rcx+rdx+58] = Max Health
  mov [rcx+rdx+2A0],eax              // [rcx+rdx+2A0] = Current Health
  mov [rcx+rdx+2A8],(float)100       // [rcx+rdx+2A4] = Shield; [rcx+rdx+2A8] = Temp Shield
  pop rax
  @@:
  popfq
  db phbytes                         //  vmovups ymm0,[rcx+rdx+2A0]
  jmp phreturn

aob_playerhealth:
  jmp phScript
  nop 4
phreturn:

[DISABLE]

unregistersymbol(*)
dealloc(*)

aob_aHealth:
  db abytes

