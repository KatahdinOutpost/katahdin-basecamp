{$lua}
local ExtraCriticalChanceWhenShootARegs = { "rbx", "rsi", "rdi", "rcx", "rdx", "rax", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "rbp", "rsp" }
local ExtraCriticalChanceWhenShootARegBufferOffsets = { rbx = 8, rsi = 24, rdi = 40, rcx = 56, rdx = 72, rax = 88, r8 = 104, r9 = 120, r10 = 136, r11 = 152, r12 = 264, r13 = 280, r14 = 296, r15 = 312, rbp = 328, rsp = 344}

-- GLOBAL variables for communication between scripts
_G.ExtraCriticalChanceWhenShootAAddressEntry = nil
_G.ExtraCriticalChanceWhenShootAOriginalStaticAddress = nil
_G.ExtraCriticalChanceWhenShootABasePointer = nil
_G.ExtraCriticalChanceWhenShootACurrentRegister = nil

local function findOrCreateExtraCriticalChanceWhenShootAEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeExtraCriticalChanceWhenShootAStatus" then
      _G.ExtraCriticalChanceWhenShootAAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "ExtraCriticalChanceWhenShootA (Primary Array)"
  entry.Type = vtSingle
  entry.Address = "seeExtraCriticalChanceWhenShootAStatus"
  _G.ExtraCriticalChanceWhenShootAAddressEntry = entry
  return entry
end

local function findOrCreateExtraCriticalChanceWhenShootAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setExtraCriticalChanceWhenShootAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addExtraCriticalChanceWhenShootAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subExtraCriticalChanceWhenShootAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.ExtraCriticalChanceWhenShootAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "ExtraCriticalChanceWhenShootA Value (See)"
  entry.Type = vtSingle
  entry.Address = valueSymbolName
  _G.ExtraCriticalChanceWhenShootAValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForExtraCriticalChanceWhenShootAPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(ExtraCriticalChanceWhenShootARegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(ExtraCriticalChanceWhenShootARegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handleExtraCriticalChanceWhenShootAOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readFloat
  local writeFunc = writeFloat

  if operation == "Set" then
    local valueAddr = getAddressSafe("setExtraCriticalChanceWhenShootAValue")
    local value = readFloat(valueAddr)
    writeFloat(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addExtraCriticalChanceWhenShootAValue")
    local value = readFloat(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastExtraCriticalChanceWhenShootAValue then
        _G.lastExtraCriticalChanceWhenShootAValue = currentValue
      elseif currentValue &gt; _G.lastExtraCriticalChanceWhenShootAValue then
        local newValue = currentValue + value
        writeFloat(addr, newValue)
        _G.lastExtraCriticalChanceWhenShootAValue = newValue
      else
        _G.lastExtraCriticalChanceWhenShootAValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subExtraCriticalChanceWhenShootAValue")
    local value = readFloat(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastExtraCriticalChanceWhenShootAValue then
        _G.lastExtraCriticalChanceWhenShootAValue = currentValue
      elseif currentValue &gt; _G.lastExtraCriticalChanceWhenShootAValue then
        local newValue = currentValue - value
        writeFloat(addr, newValue)
        _G.lastExtraCriticalChanceWhenShootAValue = newValue
      else
        _G.lastExtraCriticalChanceWhenShootAValue = currentValue
      end
    end
  end
end

local function ExtraCriticalChanceWhenShootATimerCallback()
  local injectionAddr = getAddressSafe("ExtraCriticalChanceWhenShootACopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForExtraCriticalChanceWhenShootAPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeExtraCriticalChanceWhenShootA")
  if not debugBufferAddr then return end

  local bufferOffset = ExtraCriticalChanceWhenShootARegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.ExtraCriticalChanceWhenShootABasePointer = pointerBase
  _G.ExtraCriticalChanceWhenShootACurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and ExtraCriticalChanceWhenShootARegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + ExtraCriticalChanceWhenShootARegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.ExtraCriticalChanceWhenShootAOriginalStaticAddress then
    _G.ExtraCriticalChanceWhenShootAOriginalStaticAddress = getAddressSafe("seeExtraCriticalChanceWhenShootAStatus")
  end

  unregisterSymbol("seeExtraCriticalChanceWhenShootAStatus")
  registerSymbol("seeExtraCriticalChanceWhenShootAStatus", primaryAddr)
  forceRefreshExistingEntry("seeExtraCriticalChanceWhenShootAStatus", primaryAddr)
  handleExtraCriticalChanceWhenShootAOperation(primaryAddr, "See", "Float")

  if not _G.ExtraCriticalChanceWhenShootAEntryCreated then
    findOrCreateExtraCriticalChanceWhenShootAEntry()
    _G.ExtraCriticalChanceWhenShootAEntryCreated = true
  end

  if not _G.ExtraCriticalChanceWhenShootAValueEntryCreated then
    findOrCreateExtraCriticalChanceWhenShootAValueEntry()
    _G.ExtraCriticalChanceWhenShootAValueEntryCreated = true
  end
end

