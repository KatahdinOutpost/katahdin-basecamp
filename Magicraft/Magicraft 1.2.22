{$lua}
local KeysCountWhenPickUpOrUseARegs = { "rbx", "rsi", "rdi", "rcx", "rdx", "rax", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "rbp", "rsp" }
local KeysCountWhenPickUpOrUseARegBufferOffsets = { rbx = 8, rsi = 24, rdi = 40, rcx = 56, rdx = 72, rax = 88, r8 = 104, r9 = 120, r10 = 136, r11 = 152, r12 = 264, r13 = 280, r14 = 296, r15 = 312, rbp = 328, rsp = 344}

-- GLOBAL variables for communication between scripts
_G.KeysCountWhenPickUpOrUseAAddressEntry = nil
_G.KeysCountWhenPickUpOrUseAOriginalStaticAddress = nil
_G.KeysCountWhenPickUpOrUseABasePointer = nil
_G.KeysCountWhenPickUpOrUseACurrentRegister = nil

local function findOrCreateKeysCountWhenPickUpOrUseAEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeKeysCountWhenPickUpOrUseAStatus" then
      _G.KeysCountWhenPickUpOrUseAAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "KeysCountWhenPickUpOrUseA (Primary Array)"
  entry.Type = vtDword
  entry.Address = "seeKeysCountWhenPickUpOrUseAStatus"
  _G.KeysCountWhenPickUpOrUseAAddressEntry = entry
  return entry
end

local function findOrCreateKeysCountWhenPickUpOrUseAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setKeysCountWhenPickUpOrUseAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addKeysCountWhenPickUpOrUseAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subKeysCountWhenPickUpOrUseAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.KeysCountWhenPickUpOrUseAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "KeysCountWhenPickUpOrUseA Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.KeysCountWhenPickUpOrUseAValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForKeysCountWhenPickUpOrUseAPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(KeysCountWhenPickUpOrUseARegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(KeysCountWhenPickUpOrUseARegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handleKeysCountWhenPickUpOrUseAOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readInteger
  local writeFunc = writeInteger

  if operation == "Set" then
    local valueAddr = getAddressSafe("setKeysCountWhenPickUpOrUseAValue")
    local value = readInteger(valueAddr)
    writeInteger(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addKeysCountWhenPickUpOrUseAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastKeysCountWhenPickUpOrUseAValue then
        _G.lastKeysCountWhenPickUpOrUseAValue = currentValue
      elseif currentValue &gt; _G.lastKeysCountWhenPickUpOrUseAValue then
        local newValue = currentValue + value
        writeInteger(addr, newValue)
        _G.lastKeysCountWhenPickUpOrUseAValue = newValue
      else
        _G.lastKeysCountWhenPickUpOrUseAValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subKeysCountWhenPickUpOrUseAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastKeysCountWhenPickUpOrUseAValue then
        _G.lastKeysCountWhenPickUpOrUseAValue = currentValue
      elseif currentValue &gt; _G.lastKeysCountWhenPickUpOrUseAValue then
        local newValue = currentValue - value
        writeInteger(addr, newValue)
        _G.lastKeysCountWhenPickUpOrUseAValue = newValue
      else
        _G.lastKeysCountWhenPickUpOrUseAValue = currentValue
      end
    end
  end
end

local function KeysCountWhenPickUpOrUseATimerCallback()
  local injectionAddr = getAddressSafe("KeysCountWhenPickUpOrUseACopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForKeysCountWhenPickUpOrUseAPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeKeysCountWhenPickUpOrUseA")
  if not debugBufferAddr then return end

  local bufferOffset = KeysCountWhenPickUpOrUseARegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.KeysCountWhenPickUpOrUseABasePointer = pointerBase
  _G.KeysCountWhenPickUpOrUseACurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and KeysCountWhenPickUpOrUseARegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + KeysCountWhenPickUpOrUseARegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.KeysCountWhenPickUpOrUseAOriginalStaticAddress then
    _G.KeysCountWhenPickUpOrUseAOriginalStaticAddress = getAddressSafe("seeKeysCountWhenPickUpOrUseAStatus")
  end

  unregisterSymbol("seeKeysCountWhenPickUpOrUseAStatus")
  registerSymbol("seeKeysCountWhenPickUpOrUseAStatus", primaryAddr)
  forceRefreshExistingEntry("seeKeysCountWhenPickUpOrUseAStatus", primaryAddr)
  handleKeysCountWhenPickUpOrUseAOperation(primaryAddr, "See", "4 Bytes")

  if not _G.KeysCountWhenPickUpOrUseAEntryCreated then
    findOrCreateKeysCountWhenPickUpOrUseAEntry()
    _G.KeysCountWhenPickUpOrUseAEntryCreated = true
  end

  if not _G.KeysCountWhenPickUpOrUseAValueEntryCreated then
    findOrCreateKeysCountWhenPickUpOrUseAValueEntry()
    _G.KeysCountWhenPickUpOrUseAValueEntryCreated = true
  end
end

if _G.unlimitedKeysCountWhenPickUpOrUseATimer and _G.unlimitedKeysCountWhenPickUpOrUseATimer.destroy then
  _G.unlimitedKeysCountWhenPickUpOrUseATimer.destroy()
  _G.unlimitedKeysCountWhenPickUpOrUseATimer = nil
end

_G.KeysCountWhenPickUpOrUseAEntryCreated = false
_G.KeysCountWhenPickUpOrUseAValueEntryCreated = false
_G.KeysCountWhenPickUpOrUseAAddressEntry = nil
_G.KeysCountWhenPickUpOrUseAOriginalStaticAddress = nil

if not _G.KeysCountWhenPickUpOrUseABasePointer then _G.KeysCountWhenPickUpOrUseABasePointer = nil end
if not _G.KeysCountWhenPickUpOrUseACurrentRegister then _G.KeysCountWhenPickUpOrUseACurrentRegister = nil end

if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.unlimitedKeysCountWhenPickUpOrUseATimer = createTimer(nil, false)
    _G.unlimitedKeysCountWhenPickUpOrUseATimer.Interval = 555
    _G.unlimitedKeysCountWhenPickUpOrUseATimer.OnTimer = KeysCountWhenPickUpOrUseATimerCallback
    _G.unlimitedKeysCountWhenPickUpOrUseATimer.Enabled = true
  end
  startupTimer.Enabled = true
end
{$asm}

[DISABLE]

{$lua}
if _G.unlimitedKeysCountWhenPickUpOrUseATimer and _G.unlimitedKeysCountWhenPickUpOrUseATimer.destroy then
  _G.unlimitedKeysCountWhenPickUpOrUseATimer.destroy()
  _G.unlimitedKeysCountWhenPickUpOrUseATimer = nil
end

if _G.KeysCountWhenPickUpOrUseAOriginalStaticAddress then
  unregisterSymbol("seeKeysCountWhenPickUpOrUseAStatus")
  registerSymbol("seeKeysCountWhenPickUpOrUseAStatus", _G.KeysCountWhenPickUpOrUseAOriginalStaticAddress)

  if _G.KeysCountWhenPickUpOrUseAAddressEntry then
    _G.KeysCountWhenPickUpOrUseAAddressEntry.Address = string.format("0x%X", _G.KeysCountWhenPickUpOrUseAOriginalStaticAddress)
    sleep(1)
    _G.KeysCountWhenPickUpOrUseAAddressEntry.Address = "seeKeysCountWhenPickUpOrUseAStatus"
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeKeysCountWhenPickUpOrUseAStatus")
  if allocatedAddr then
    unregisterSymbol("seeKeysCountWhenPickUpOrUseAStatus")
    registerSymbol("seeKeysCountWhenPickUpOrUseAStatus", allocatedAddr)

    if _G.KeysCountWhenPickUpOrUseAAddressEntry then
      _G.KeysCountWhenPickUpOrUseAAddressEntry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      _G.KeysCountWhenPickUpOrUseAAddressEntry.Address = "seeKeysCountWhenPickUpOrUseAStatus"
    end
  end
end

_G.KeysCountWhenPickUpOrUseAEntryCreated = false
_G.KeysCountWhenPickUpOrUseAValueEntryCreated = false
_G.KeysCountWhenPickUpOrUseAAddressEntry = nil
_G.KeysCountWhenPickUpOrUseAOriginalStaticAddress = nil

_G.KeysCountWhenPickUpOrUseABasePointer = nil
_G.KeysCountWhenPickUpOrUseACurrentRegister = nil
_G.lastKeysCountWhenPickUpOrUseAValue = nil

{$asm}

KeysCountWhenPickUpOrUseA:
