  readmem(KeyCountWhenChangeAreaA,30)

label(code)
label(return)

newmem:



code:
  // Original code
  readmem(KeyCountWhenChangeAreaA,6)
  jmp return

KeyCountWhenChangeAreaA:
  jmp newmem
  nop 1
return:
