{$lua}
local MaxPotionsOnUseARegs = { "rbx", "rsi", "rdi", "rcx", "rdx", "rax", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "rbp", "rsp" }
local MaxPotionsOnUseARegBufferOffsets = { rbx = 8, rsi = 24, rdi = 40, rcx = 56, rdx = 72, rax = 88, r8 = 104, r9 = 120, r10 = 136, r11 = 152, r12 = 264, r13 = 280, r14 = 296, r15 = 312, rbp = 328, rsp = 344}

-- GLOBAL variables for communication between scripts
_G.MaxPotionsOnUseAAddressEntry = nil
_G.MaxPotionsOnUseAOriginalStaticAddress = nil
_G.MaxPotionsOnUseABasePointer = nil
_G.MaxPotionsOnUseACurrentRegister = nil

local function findOrCreateMaxPotionsOnUseAEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeMaxPotionsOnUseAStatus" then
      _G.MaxPotionsOnUseAAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "MaxPotionsOnUseA (Primary Array)"
  entry.Type = vtDword
  entry.Address = "seeMaxPotionsOnUseAStatus"
  _G.MaxPotionsOnUseAAddressEntry = entry
  return entry
end

local function findOrCreateMaxPotionsOnUseAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setMaxPotionsOnUseAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addMaxPotionsOnUseAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subMaxPotionsOnUseAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.MaxPotionsOnUseAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "MaxPotionsOnUseA Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.MaxPotionsOnUseAValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForMaxPotionsOnUseAPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(MaxPotionsOnUseARegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(MaxPotionsOnUseARegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handleMaxPotionsOnUseAOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readInteger
  local writeFunc = writeInteger

  if operation == "Set" then
    local valueAddr = getAddressSafe("setMaxPotionsOnUseAValue")
    local value = readInteger(valueAddr)
    writeInteger(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addMaxPotionsOnUseAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastMaxPotionsOnUseAValue then
        _G.lastMaxPotionsOnUseAValue = currentValue
      elseif currentValue &gt; _G.lastMaxPotionsOnUseAValue then
        local newValue = currentValue + value
        writeInteger(addr, newValue)
        _G.lastMaxPotionsOnUseAValue = newValue
      else
        _G.lastMaxPotionsOnUseAValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subMaxPotionsOnUseAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastMaxPotionsOnUseAValue then
        _G.lastMaxPotionsOnUseAValue = currentValue
      elseif currentValue &gt; _G.lastMaxPotionsOnUseAValue then
        local newValue = currentValue - value
        writeInteger(addr, newValue)
        _G.lastMaxPotionsOnUseAValue = newValue
      else
        _G.lastMaxPotionsOnUseAValue = currentValue
      end
    end
  end
end

local function MaxPotionsOnUseATimerCallback()
  local injectionAddr = getAddressSafe("MaxPotionsOnUseACopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForMaxPotionsOnUseAPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeMaxPotionsOnUseA")
  if not debugBufferAddr then return end

  local bufferOffset = MaxPotionsOnUseARegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.MaxPotionsOnUseABasePointer = pointerBase
  _G.MaxPotionsOnUseACurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and MaxPotionsOnUseARegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + MaxPotionsOnUseARegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.MaxPotionsOnUseAOriginalStaticAddress then
    _G.MaxPotionsOnUseAOriginalStaticAddress = getAddressSafe("seeMaxPotionsOnUseAStatus")
  end

  unregisterSymbol("seeMaxPotionsOnUseAStatus")
  registerSymbol("seeMaxPotionsOnUseAStatus", primaryAddr)
  forceRefreshExistingEntry("seeMaxPotionsOnUseAStatus", primaryAddr)
  handleMaxPotionsOnUseAOperation(primaryAddr, "See", "4 Bytes")

  if not _G.MaxPotionsOnUseAEntryCreated then
    findOrCreateMaxPotionsOnUseAEntry()
    _G.MaxPotionsOnUseAEntryCreated = true
  end

  if not _G.MaxPotionsOnUseAValueEntryCreated then
    findOrCreateMaxPotionsOnUseAValueEntry()
    _G.MaxPotionsOnUseAValueEntryCreated = true
  end
end

if _G.unlimitedMaxPotionsOnUseATimer and _G.unlimitedMaxPotionsOnUseATimer.destroy then
  _G.unlimitedMaxPotionsOnUseATimer.destroy()
  _G.unlimitedMaxPotionsOnUseATimer = nil
end

_G.MaxPotionsOnUseAEntryCreated = false
_G.MaxPotionsOnUseAValueEntryCreated = false
_G.MaxPotionsOnUseAAddressEntry = nil
_G.MaxPotionsOnUseAOriginalStaticAddress = nil

if not _G.MaxPotionsOnUseABasePointer then _G.MaxPotionsOnUseABasePointer = nil end
if not _G.MaxPotionsOnUseACurrentRegister then _G.MaxPotionsOnUseACurrentRegister = nil end

if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.unlimitedMaxPotionsOnUseATimer = createTimer(nil, false)
    _G.unlimitedMaxPotionsOnUseATimer.Interval = 555
    _G.unlimitedMaxPotionsOnUseATimer.OnTimer = MaxPotionsOnUseATimerCallback
    _G.unlimitedMaxPotionsOnUseATimer.Enabled = true
  end
  startupTimer.Enabled = true
end
{$asm}

[DISABLE]

{$lua}
if _G.unlimitedMaxPotionsOnUseATimer and _G.unlimitedMaxPotionsOnUseATimer.destroy then
  _G.unlimitedMaxPotionsOnUseATimer.destroy()
  _G.unlimitedMaxPotionsOnUseATimer = nil
end

if _G.MaxPotionsOnUseAOriginalStaticAddress then
  unregisterSymbol("seeMaxPotionsOnUseAStatus")
  registerSymbol("seeMaxPotionsOnUseAStatus", _G.MaxPotionsOnUseAOriginalStaticAddress)

  if _G.MaxPotionsOnUseAAddressEntry then
    _G.MaxPotionsOnUseAAddressEntry.Address = string.format("0x%X", _G.MaxPotionsOnUseAOriginalStaticAddress)
    sleep(1)
    _G.MaxPotionsOnUseAAddressEntry.Address = "seeMaxPotionsOnUseAStatus"
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeMaxPotionsOnUseAStatus")
  if allocatedAddr then
    unregisterSymbol("seeMaxPotionsOnUseAStatus")
    registerSymbol("seeMaxPotionsOnUseAStatus", allocatedAddr)

    if _G.MaxPotionsOnUseAAddressEntry then
      _G.MaxPotionsOnUseAAddressEntry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      _G.MaxPotionsOnUseAAddressEntry.Address = "seeMaxPotionsOnUseAStatus"
    end
  end
end

_G.MaxPotionsOnUseAEntryCreated = false
_G.MaxPotionsOnUseAValueEntryCreated = false
_G.MaxPotionsOnUseAAddressEntry = nil
_G.MaxPotionsOnUseAOriginalStaticAddress = nil

_G.MaxPotionsOnUseABasePointer = nil
_G.MaxPotionsOnUseACurrentRegister = nil
_G.lastMaxPotionsOnUseAValue = nil

{$asm}

