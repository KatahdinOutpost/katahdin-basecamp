-- Custom Record Color Manager for Cheat Engine
-- Allows customization of record colors based on their types

local colorConfig = {}
local colorTimer = nil
local updateInterval = 1000
local colorManagerForm = nil
local mainForm = nil

-- Default color scheme
local defaultColors = {
    groupHeader = 0xFF0000,      -- Red for Group Headers
    pointer = 0xFF00FF,           -- Magenta for Pointers
    autoAssembler = 0x00FF00,     -- Green for Auto Assembler
    bigEndian = 0x00FFFF,         -- Cyan for Big Endian types
    byte = 0x00A5FF,              -- Light Blue for Byte
    word = 0x00A5FF,              -- Light Blue for Word (2 Bytes)
    dword = 0x00A5FF,             -- Light Blue for DWord (4 Bytes)
    qword = 0x00A5FF,             -- Light Blue for QWord (8 Bytes)
    float = 0x00A5FF,             -- Light Blue for Float
    double = 0x00A5FF,            -- Light Blue for Double
    string = 0xFFFF00,            -- Yellow for String
    aobScan = 0xFF8C00,           -- Dark Orange for AOB Scan
    custom = 0x808080,            -- Gray for Custom types
}

-- Initialize color configuration
function initializeColorConfig()
    -- Try to load saved configuration
    local config = loadColorConfig()
    if config and next(config) ~= nil then
        colorConfig = config
    else
        colorConfig = defaultColors
    end
end

-- Save configuration to CE script
function saveColorConfig()
    local addressList = getAddressList()
    local scriptRecord = addressList.getMemoryRecordByDescription('ColorManager_Config')

    if not scriptRecord then
        scriptRecord = addressList.createMemoryRecord()
        scriptRecord.Description = 'ColorManager_Config'
        scriptRecord.Type = vtAutoAssembler
    end

    local configScript = "// Color Manager Configuration\n"
    configScript = configScript .. "{$lua}\n"
    configScript = configScript .. "if not savedColorConfig then\n"
    configScript = configScript .. "  savedColorConfig = {}\n"
    configScript = configScript .. "end\n\n"

    for key, color in pairs(colorConfig) do
        configScript = configScript .. string.format("savedColorConfig.%s = 0x%06X\n", key, color)
    end

    configScript = configScript .. "{$asm}\n"

    scriptRecord.Script = configScript
    scriptRecord.Active = false
    scriptRecord.Active = true
end

-- Load configuration from CE script
function loadColorConfig()
    local addressList = getAddressList()
    local scriptRecord = addressList.getMemoryRecordByDescription('ColorManager_Config')

    if not scriptRecord then
        return nil
    end

    if not scriptRecord.Active then
        scriptRecord.Active = true
    end

    if savedColorConfig then
        return savedColorConfig
    end

    return nil
end

-- Apply colors to records
function applyColors()
    synchronize(function()
        local success = pcall(function()
            local addressList = getAddressList()
            if not addressList then return end

            local count = addressList.Count
            if count &lt;= 0 then return end

            for i = 0, count - 1 do
                local memrec = addressList[i]
                if memrec and memrec.Description then
                    local desc = memrec.Description

                    -- Skip special records
                    if desc == "&lt;--- Auto Attach" or desc == "Tests" or desc == "ColorManager_Config" then
                        goto continue
                    end

                    memrec.Color = nil

                    -- Apply colors based on type
                    if memrec.IsGroupHeader then
                        memrec.Color = colorConfig.groupHeader
                    elseif memrec.IsPointer or (memrec.OffsetCount and memrec.OffsetCount &gt; 0) then
                        memrec.Color = colorConfig.pointer
                    elseif memrec.Type == vtAutoAssembler then
                        memrec.Color = colorConfig.autoAssembler
                    elseif memrec.Type == vtString then
                        memrec.Color = colorConfig.string
                    elseif memrec.Type == vtByteArray then
                        -- Array of Bytes deve essere controllato PRIMA dei Big Endian
                        memrec.Color = colorConfig.aobScan
                    -- Big Endian types
                    elseif memrec.Type == 8 or memrec.Type == 9 or memrec.Type == 11 or memrec.Type == 13 then
                        memrec.Color = colorConfig.bigEndian
                    -- Standard types
                    elseif memrec.Type == vtByte then
                        memrec.Color = colorConfig.byte
                    elseif memrec.Type == vtWord then
                        memrec.Color = colorConfig.word
                    elseif memrec.Type == vtDword then
                        memrec.Color = colorConfig.dword
                    elseif memrec.Type == vtQword then
                        memrec.Color = colorConfig.qword
                    elseif memrec.Type == vtSingle then
                        memrec.Color = colorConfig.float
                    elseif memrec.Type == vtDouble then
                        memrec.Color = colorConfig.double
                    else
                        memrec.Color = colorConfig.custom
                    end
                end
                ::continue::
            end
        end)

        if not success and colorTimer then
            colorTimer.Enabled = false
            createTimer(nil, false, function()
                colorTimer.Enabled = true
            end).Interval = 1000
        end
    end)
end

-- Create color selection button
function createColorButton(parent, x, y, currentColor, labelText)
    local container = createPanel(parent)
    container.Left = x
    container.Top = y
    container.Width = 250
    container.Height = 30
    container.BevelOuter = "bvNone"

    local label = createLabel(container)
    label.Left = 0
    label.Top = 5
    label.Width = 120
    label.Caption = labelText

    local colorPreview = createPanel(container)
    colorPreview.Left = 125
    colorPreview.Top = 5
    colorPreview.Width = 20
    colorPreview.Height = 20
    colorPreview.Color = currentColor
    colorPreview.BevelOuter = "bvRaised"

    local button = createButton(container)
    button.Left = 150
    button.Top = 2
    button.Width = 90
    button.Height = 25
    button.Caption = "Choose..."

    return container, colorPreview, button
end

-- Create the color manager form
function showColorManager()
    if colorManagerForm and not colorManagerForm.isDestroyed then
        colorManagerForm.bringToFront()
        return
    end

    colorManagerForm = createForm()
    colorManagerForm.Caption = "Record Color Manager"
    colorManagerForm.Width = 400
    colorManagerForm.Height = 600  -- Aumentato da 550 a 600
    colorManagerForm.Position = "poScreenCenter"
    colorManagerForm.BorderStyle = "bsDialog"

    -- Create main panel instead of scrollbox
    local mainPanel = createPanel(colorManagerForm)
    mainPanel.Left = 0
    mainPanel.Top = 0
    mainPanel.Width = 380
    mainPanel.Height = 520  -- Aumentato da 470 a 520
    mainPanel.BevelOuter = "bvNone"

    local yPos = 10
    local colorPreviews = {}
    local colorButtons = {}  -- Aggiungiamo anche i riferimenti ai pulsanti

    -- Title label
    local titleLabel = createLabel(mainPanel)
    titleLabel.Left = 10
    titleLabel.Top = yPos
    titleLabel.Caption = "Customize colors for each record type:"
    titleLabel.Font.Style = "[fsBold]"
    yPos = yPos + 25

    -- Separator
    local sep1 = createPanel(mainPanel)
    sep1.Left = 10
    sep1.Top = yPos
    sep1.Width = 360
    sep1.Height = 2
    sep1.Color = 0x808080
    sep1.BevelOuter = "bvNone"
    yPos = yPos + 10

    -- Color configurations
    local colorSettings = {
        {key = "groupHeader", label = "Group Headers:"},
        {key = "pointer", label = "Pointers:"},
        {key = "autoAssembler", label = "Auto Assembler Scripts:"},
        {key = "string", label = "String:"},
        {key = "bigEndian", label = "Big Endian Types:"},
        {key = "byte", label = "Byte (1 Byte):"},
        {key = "word", label = "Word (2 Bytes):"},
        {key = "dword", label = "DWord (4 Bytes):"},
        {key = "qword", label = "QWord (8 Bytes):"},
        {key = "float", label = "Float:"},
        {key = "double", label = "Double:"},
        {key = "aobScan", label = "Array of Bytes:"},
        {key = "custom", label = "Custom/Other Types:"},
    }

    for _, setting in ipairs(colorSettings) do
        local container, preview, button = createColorButton(
            mainPanel,
            10,
            yPos,
            colorConfig[setting.key],
            setting.label
        )

        colorPreviews[setting.key] = preview
        colorButtons[setting.key] = button

        button.OnClick = function()
            local colorDialog = createColorDialog(colorManagerForm)
            colorDialog.Color = colorConfig[setting.key]
            if colorDialog.execute() then
                colorConfig[setting.key] = colorDialog.Color
                preview.Color = colorDialog.Color
                applyColors()
            end
        end

        yPos = yPos + 35
    end

    -- Function to update all preview colors
    local function updateAllPreviews()
        for key, preview in pairs(colorPreviews) do
            if colorConfig[key] then
                preview.Color = colorConfig[key]
            end
        end
    end

    -- Buttons panel
    local buttonPanel = createPanel(colorManagerForm)
    buttonPanel.Left = 0
    buttonPanel.Top = 520  -- Aumentato da 470 a 520
    buttonPanel.Width = 400
    buttonPanel.Height = 80
    buttonPanel.BevelOuter = "bvNone"

    -- Apply button
    local btnApply = createButton(buttonPanel)
    btnApply.Left = 10
    btnApply.Top = 10
    btnApply.Width = 90
    btnApply.Height = 30
    btnApply.Caption = "Apply"
    btnApply.OnClick = function()
        applyColors()
        saveColorConfig()
    end

    -- Reset to defaults button
    local btnReset = createButton(buttonPanel)
    btnReset.Left = 110
    btnReset.Top = 10
    btnReset.Width = 90
    btnReset.Height = 30
    btnReset.Caption = "Reset Defaults"
    btnReset.OnClick = function()
        if messageDialog("Reset all colors to default values?", mtConfirmation, mbYes, mbNo) == mrYes then
            -- Reset diretto di ogni singolo valore
            colorConfig.groupHeader = 0xFF0000
            colorConfig.pointer = 0xFF00FF
            colorConfig.autoAssembler = 0x00FF00
            colorConfig.bigEndian = 0x00FFFF
            colorConfig.byte = 0x00A5FF
            colorConfig.word = 0x00A5FF
            colorConfig.dword = 0x00A5FF
            colorConfig.qword = 0x00A5FF
            colorConfig.float = 0x00A5FF
            colorConfig.double = 0x00A5FF
            colorConfig.string = 0xFFFF00
            colorConfig.aobScan = 0xFF8C00
            colorConfig.custom = 0x808080

            -- Update all preview panels direttamente
            if colorPreviews.groupHeader then colorPreviews.groupHeader.Color = 0xFF0000 end
            if colorPreviews.pointer then colorPreviews.pointer.Color = 0xFF00FF end
            if colorPreviews.autoAssembler then colorPreviews.autoAssembler.Color = 0x00FF00 end
            if colorPreviews.bigEndian then colorPreviews.bigEndian.Color = 0x00FFFF end
            if colorPreviews.byte then colorPreviews.byte.Color = 0x00A5FF end
            if colorPreviews.word then colorPreviews.word.Color = 0x00A5FF end
            if colorPreviews.dword then colorPreviews.dword.Color = 0x00A5FF end
            if colorPreviews.qword then colorPreviews.qword.Color = 0x00A5FF end
            if colorPreviews.float then colorPreviews.float.Color = 0x00A5FF end
            if colorPreviews.double then colorPreviews.double.Color = 0x00A5FF end
            if colorPreviews.string then colorPreviews.string.Color = 0xFFFF00 end
            if colorPreviews.aobScan then colorPreviews.aobScan.Color = 0xFF8C00 end
            if colorPreviews.custom then colorPreviews.custom.Color = 0x808080 end

            -- Apply the changes
            applyColors()
            saveColorConfig()
            showMessage("Colors reset to defaults!")
        end
    end

    -- Save button
    local btnSave = createButton(buttonPanel)
    btnSave.Left = 210
    btnSave.Top = 10
    btnSave.Width = 90
    btnSave.Height = 30
    btnSave.Caption = "Save"
    btnSave.OnClick = function()
        saveColorConfig()
        showMessage("Color configuration saved successfully!")
    end

    -- Close button
    local btnClose = createButton(buttonPanel)
    btnClose.Left = 310
    btnClose.Top = 10
    btnClose.Width = 70
    btnClose.Height = 30
    btnClose.Caption = "Close"
    btnClose.OnClick = function()
        colorManagerForm.close()
    end

    colorManagerForm.OnClose = function(sender)
        sender.destroy()
        colorManagerForm = nil
    end

    colorManagerForm.show()
end

-- Start the coloring system
function startColoringSystem()
    if colorTimer then
        colorTimer.destroy()
        colorTimer = nil
    end

    colorTimer = createTimer(getMainForm())
    if colorTimer then
        colorTimer.Interval = updateInterval
        colorTimer.OnTimer = applyColors
        colorTimer.Enabled = true
    end
end

-- Stop the coloring system
function stopColoringSystem()
    if colorTimer then
        colorTimer.Enabled = false
        colorTimer.destroy()
        colorTimer = nil
    end
end

-- Initialize the tool
function initColorManager()
    mainForm = getMainForm()

    if not mainForm then
        showMessage("Error: Unable to find Cheat Engine MainForm")
        return
    end

    -- Initialize configuration
    initializeColorConfig()

    -- Add menu item to main menu
    local mainMenu = mainForm.Menu
    if mainMenu then
        -- Remove existing menu item if present
        for i = mainMenu.Items.Count - 1, 0, -1 do
            if mainMenu.Items[i].Caption == "Change Color" then
                mainMenu.Items.delete(i)
            end
        end

        -- Create new menu item
        local colorMenu = createMenuItem(mainMenu)
        colorMenu.Caption = "Change Color"
        colorMenu.OnClick = function()
            showColorManager()
        end

        -- Add to main menu
        mainMenu.Items.add(colorMenu)
    end

    -- Start the coloring system
    startColoringSystem()

    -- Apply initial colors
    applyColors()
end

-- Clean up function
function cleanupColorManager()
    stopColoringSystem()
    if colorManagerForm then
        colorManagerForm.destroy()
        colorManagerForm = nil
    end
end

-- Initialize the color manager
initColorManager()








