{$lua}

-- Global table to track registered templates
local registeredTemplates = {}
local lastWildcardSetting = true  -- Default setting: wildcards enabled

local function formatAddress(address, useModules)
    if not useModules then
        return string.format("%.8x", address)
    end

    -- Find module for address
    local modules = enumModules()
    if not modules then return string.format("%.8x", address) end

    for i, module in ipairs(modules) do
        local base = module.Address
        local size = module.Size
        if address &gt;= base and address &lt; (base + size) then
            return module.Name .. "+" .. string.format("%.8x", address - base)
        end
    end

    return string.format("%.8x", address)
end

local function parseAddressInput(input)
    -- Check if input is in module+offset format
    local moduleName, offsetStr = string.match(input, "(.+)%+([%x]+)")
    if moduleName and offsetStr then
        local offset = tonumber(offsetStr, 16)
        if not offset then return nil end

        -- Find module
        local modules = enumModules()
        if not modules then return nil end

        for i, module in ipairs(modules) do
            if module.Name:lower() == moduleName:lower() then
                return module.Address + offset, module.Name, offset
            end
        end
        return nil -- Module not found
    else
        -- Input is a plain address
        local address = tonumber(input, 16)
        if not address then return nil end

        -- Check if address belongs to any module
        local modules = enumModules()
        if modules then
            for i, module in ipairs(modules) do
                local base = module.Address
                local size = getModuleSize(module.Name)
                if address &gt;= base and address &lt; (base + size) then
                    return address, module.Name, address - base
                end
            end
        end

        return address, nil, nil -- Address without module
    end
end

local function createProgressDialog(title, message)
    local progressForm = createForm(false)
    progressForm.Caption = title
    progressForm.Width = 400
    progressForm.Height = 150
    progressForm.Position = 'poScreenCenter'
    progressForm.BorderStyle = 'bsDialog'
    progressForm.FormStyle = 'fsStayOnTop'

    local messageLabel = createLabel(progressForm)
    messageLabel.Caption = message
    messageLabel.Left = 20
    messageLabel.Top = 20
    messageLabel.Width = 360
    messageLabel.Height = 30
    messageLabel.Alignment = 'taCenter'
    messageLabel.Font.Size = 10
    messageLabel.Font.Style = 'fsBold'

    local statusLabel = createLabel(progressForm)
    statusLabel.Caption = "Initializing..."
    statusLabel.Left = 20
    statusLabel.Top = 60
    statusLabel.Width = 360
    statusLabel.Height = 20
    statusLabel.Alignment = 'taCenter'
    statusLabel.Font.Size = 9

    local progressBar = createProgressBar(progressForm)
    progressBar.Left = 20
    progressBar.Top = 90
    progressBar.Width = 360
    progressBar.Height = 20
    progressBar.Min = 0
    progressBar.Max = 100
    progressBar.Position = 0
    progressBar.Style = 'pbstMarquee'

    progressForm.show()

    local function updateProgress(status, percentage)
        if progressForm and not progressForm.Destroyed then
            statusLabel.Caption = status or "Processing..."
            if percentage then
                progressBar.Style = 'pbstNormal'
                progressBar.Position = percentage
            else
                progressBar.Style = 'pbstMarquee'
            end
            progressForm.repaint()
            sleep(1)
        end
    end

    local function closeProgress()
        if progressForm and not progressForm.Destroyed then
            progressForm.close()
            progressForm.destroy()
        end
    end

    return updateProgress, closeProgress
end

local function createUniqueAOBPattern(startAddress, endAddress, minimalSize, moduleName)
    local updateProgress, closeProgress = createProgressDialog("Smart Auto Inject", "Searching for Unique AOB Patterns...")

    updateProgress("Initializing pattern search...", 0)

    local currentAddress = startAddress
    local instructions = {}

    updateProgress("Collecting instructions from memory...", 10)

    -- Collect many more instructions to allow for very long patterns
    local maxInstructions = 500
    while currentAddress &lt; startAddress + 2000 and #instructions &lt; maxInstructions do
        local instSize = getInstructionSize(currentAddress)
        if not instSize or instSize == 0 then break end

        local bytes = readBytes(currentAddress, instSize, true)
        if not bytes then break end

        table.insert(instructions, {
            address = currentAddress,
            size = instSize,
            bytes = bytes
        })

        currentAddress = currentAddress + instSize

        if #instructions % 50 == 0 then
            local progressPercent = 10 + (30 * #instructions / maxInstructions)
            updateProgress("Collected " .. #instructions .. " instructions...", progressPercent)
        end
    end

    updateProgress("Collected " .. #instructions .. " instructions. Preparing pattern generation...", 40)

    -- Function to test if AOB pattern is unique
    local function testAOBPattern(pattern, targetModule)
        local results

        if targetModule then
            results = AOBScan(pattern, targetModule)
        end

        if not results or (results and results.Count == 0) then
            if results then
                results.destroy()
            end
            results = AOBScan(pattern)
        end

        local count = 0
        if results then
            if results.Count then
                count = results.Count
            elseif type(results) == "table" then
                for k, v in pairs(results) do
                    count = count + 1
                end
            end

            if results.destroy then
                results.destroy()
            end
        end

        return count == 1, count
    end

    -- Function to create exact pattern (no wildcards)
    local function createExactPattern(instructionCount)
        local patternTable = {}

        for i = 1, instructionCount do
            if i &gt; #instructions then break end
            local inst = instructions[i]
            if inst and inst.bytes then
                for j = 1, #inst.bytes do
                    table.insert(patternTable, string.format("%02X", inst.bytes[j]))
                end
            end
        end

        return table.concat(patternTable, " ")
    end

    -- Function to create wildcarded pattern
    local function createWildcardPattern(instructionCount)
        local patternTable = {}

        for i = 1, instructionCount do
            if i &gt; #instructions then break end
            local inst = instructions[i]
            if inst and inst.bytes then
                -- First byte exact, rest wildcard
                table.insert(patternTable, string.format("%02X", inst.bytes[1]))
                for j = 2, #inst.bytes do
                    table.insert(patternTable, "??")
                end
            end
        end

        return table.concat(patternTable, " ")
    end

    -- Progressive search for both exact and wildcard patterns
    updateProgress("Starting pattern uniqueness testing...", 50)

    local startInstructionCount = 5
    local currentInstructionCount = startInstructionCount
    local maxAttempts = 10
    local attempt = 1
    local finalExactPattern = nil
    local finalWildcardPattern = nil

    -- First, try to find unique exact pattern
    updateProgress("Searching for unique exact pattern...", 50)
    while attempt &lt;= maxAttempts and currentInstructionCount &lt;= #instructions do
        local attemptProgress = 50 + (20 * attempt / maxAttempts)
        updateProgress("Testing exact pattern with " .. currentInstructionCount .. " instructions...", attemptProgress)

        local pattern = createExactPattern(currentInstructionCount)

        if pattern and string.len(pattern) &gt; 0 then
            local isUnique, matchCount = testAOBPattern(pattern, moduleName)

            if isUnique then
                finalExactPattern = pattern
                updateProgress("Found unique exact pattern!", 70)
                break
            end
        end

        currentInstructionCount = currentInstructionCount * 2
        attempt = attempt + 1
    end

    -- If no unique exact pattern found, create a fallback
    if not finalExactPattern then
        local fallbackInstructionCount = math.min(30, #instructions)
        finalExactPattern = createExactPattern(fallbackInstructionCount)
    end

    -- Reset for wildcard pattern search
    currentInstructionCount = startInstructionCount
    attempt = 1

    -- Now find unique wildcard pattern
    updateProgress("Searching for unique wildcard pattern...", 75)
    while attempt &lt;= maxAttempts and currentInstructionCount &lt;= #instructions do
        local attemptProgress = 75 + (20 * attempt / maxAttempts)
        updateProgress("Testing wildcard pattern with " .. currentInstructionCount .. " instructions...", attemptProgress)

        local pattern = createWildcardPattern(currentInstructionCount)

        if pattern and string.len(pattern) &gt; 0 then
            local isUnique, matchCount = testAOBPattern(pattern, moduleName)

            if isUnique then
                finalWildcardPattern = pattern
                updateProgress("Found unique wildcard pattern!", 95)
                break
            end
        end

        currentInstructionCount = currentInstructionCount * 2
        attempt = attempt + 1
    end

    -- If no unique wildcard pattern found, create a fallback
    if not finalWildcardPattern then
        local fallbackInstructionCount = math.min(30, #instructions)
        finalWildcardPattern = createWildcardPattern(fallbackInstructionCount)
    end

    updateProgress("Pattern generation complete", 100)
    sleep(300)
    closeProgress()

    return finalExactPattern, finalWildcardPattern
end

local function registerDynamicInjection(templateName, jmpInstruction, requiredSize)
    if registeredTemplates[templateName] then
        return
    end

    local callback = function(script, sender)
        local memoryView = getMemoryViewForm()
        local disassemblerView = memoryView.DisassemblerView
        local startAddress = disassemblerView.SelectedAddress
        local endAddress = disassemblerView.SelectedAddress2 or startAddress

        if startAddress &gt; endAddress then
            startAddress, endAddress = endAddress, startAddress
        end

        local selectedAddress = inputQuery('Code injection template', 'On what address do you want the jump? (Can use ModuleName+Offset format)', string.format('%08X', startAddress))
        if selectedAddress then
            address, moduleName, moduleOffset = parseAddressInput(selectedAddress)
            if not address then
                error("Invalid address format")
                return
            end
            useModule = moduleName ~= nil
        else
            return
        end

        local symbolName = inputQuery('Code injection template', 'What do you want to name the symbol for the injection point?', 'INJECT')
        if not symbolName then return end

        -- Calculate actual replacement size
        local actualReplacementSize = 0
        local instCount = 0
        local currentAddress = startAddress
        while actualReplacementSize &lt; requiredSize do
            local instSize = getInstructionSize(currentAddress)
            if not instSize then break end
            actualReplacementSize = actualReplacementSize + instSize
            instCount = instCount + 1
            currentAddress = currentAddress + instSize
        end

        local exactAobString, wildcardAobString = createUniqueAOBPattern(startAddress, startAddress + actualReplacementSize + 20, 15, moduleName)

        -- Calculate size to backup (actualReplacementSize + some extra for safety)
        local backupSize = math.max(actualReplacementSize + 15, 30)
        local nopCount = actualReplacementSize - requiredSize

        -- Generate the script

        script.add("[ENABLE]")
        script.add('{$lua}')
        script.add("if syntaxcheck then return end")

        -- AOB registration function with multiple pattern support and error dialog
        script.add('function aob_register(sym, pat1, pat2)')
        script.add('  -- Function to show error message')
        script.add('  local function showErrorMessage(message)')
        script.add('    local errorForm = createForm(false)')
        script.add('    errorForm.Caption = "AOB Registration Error"')
        script.add('    errorForm.Width = 400')
        script.add('    errorForm.Height = 150')
        script.add('    errorForm.Position = "poScreenCenter"')
        script.add('    errorForm.BorderStyle = "bsDialog"')
        script.add('    errorForm.FormStyle = "fsStayOnTop"')
        script.add('    ')
        script.add('    local label = createLabel(errorForm)')
        script.add('    label.Caption = message')
        script.add('    label.Left = 20')
        script.add('    label.Top = 30')
        script.add('    label.Width = 360')
        script.add('    label.Height = 60')
        script.add('    label.Alignment = "taCenter"')
        script.add('    label.Font.Size = 10')
        script.add('    ')
        script.add('    errorForm.show()')
        script.add('    ')
        script.add('    -- Auto-close after 3 seconds')
        script.add('    local closeTimer = createTimer(errorForm)')
        script.add('    closeTimer.Interval = 3000')
        script.add('    closeTimer.OnTimer = function()')
        script.add('      closeTimer.destroy()')
        script.add('      errorForm.close()')
        script.add('    end')
        script.add('    closeTimer.Enabled = true')
        script.add('  end')
        script.add('  ')
        script.add('  -- Try first pattern (exact)')
        script.add('  local instr = AOBScan(pat1, "+X")')
        script.add('  if instr and instr.Count &gt; 0 then')
        script.add('    if instr.Count == 1 then')
        script.add('      -- First pattern is unique, use it')
        script.add('      local addy = instr[0]')
        script.add('      instr.destroy()')
        script.add('      unregisterSymbol(sym)')
        script.add('      registerSymbol(sym, tonumber(addy,16))')
        script.add('      print("Enabled with exact pattern (Pattern 1)")')
        script.add('      return')
        script.add('    else')
        script.add('      -- First pattern found multiple results')
        script.add('      instr.destroy()')
        script.add('      print("Pattern 1 found " .. tostring(instr.Count) .. " results, trying Pattern 2...")')
        script.add('    end')
        script.add('  else')
        script.add('    if instr then instr.destroy() end')
        script.add('    print("Pattern 1 not found, trying Pattern 2...")')
        script.add('  end')
        script.add('  ')
        script.add('  -- Try second pattern (wildcard)')
        script.add('  instr = AOBScan(pat2, "+X")')
        script.add('  if instr and instr.Count &gt; 0 then')
        script.add('    if instr.Count == 1 then')
        script.add('      -- Second pattern is unique, use it')
        script.add('      local addy = instr[0]')
        script.add('      instr.destroy()')
        script.add('      unregisterSymbol(sym)')
        script.add('      registerSymbol(sym, tonumber(addy,16))')
        script.add('      print("Enabled with wildcard pattern (Pattern 2)")')
        script.add('      return')
        script.add('    else')
        script.add('      -- Second pattern found multiple results')
        script.add('      local count = instr.Count')
        script.add('      instr.destroy()')
        script.add('      showErrorMessage("Pattern not unique!\\n\\nPattern 2 found " .. count .. " results.\\nCannot enable script.")')
        script.add('      error("Pattern 2 not unique: found " .. count .. " results")')
        script.add('    end')
        script.add('  else')
        script.add('    if instr then instr.destroy() end')
        script.add('    showErrorMessage("AOB patterns not found!\\n\\nBoth patterns failed to locate the injection point.\\nThe game may have been updated.")')
        script.add('    error("Both AOB patterns failed")')
        script.add('  end')
        script.add('end')
        script.add('')
        script.add('aob_register("' .. symbolName .. '","' .. exactAobString .. '"')
        script.add(', "' .. wildcardAobString .. '")')
        script.add('{$asm}')

        local newMemSymbol = "newmem"
        local codeSymbol = "code"
        local returnSymbol = "return"
        local copySymbol = symbolName .. "Copy"

        -- Calculate size to backup (actualReplacementSize + some extra for safety)
        local backupSize = math.max(actualReplacementSize + 15, 30)

        -- For jmp short, include the symbol name; for jmp far, don't
        if jmpInstruction == "jmp far " then
            script.add("alloc(" .. newMemSymbol .. ",$1000)")
        else
            script.add("alloc(" .. newMemSymbol .. ",$1000," .. symbolName .. ")")
        end
        script.add("alloc(" .. copySymbol .. "," .. backupSize .. ")")
        script.add("registersymbol(" .. copySymbol .. ")")
        script.add("")
        script.add(copySymbol .. ":")
        script.add("  readmem(" .. symbolName .. "," .. backupSize .. ")")
        script.add("")
        script.add("label(" .. codeSymbol .. ")")
        script.add("label(" .. returnSymbol .. ")")
        script.add("")
        script.add(newMemSymbol .. ":")
        script.add("")
        script.add("")
        script.add("")
        script.add(codeSymbol .. ":")
        script.add("  // Original code")
        script.add("  readmem(" .. symbolName .. "," .. actualReplacementSize .. ")")
        script.add("  jmp " .. returnSymbol)
        script.add("")
        script.add(symbolName .. ":")

        if jmpInstruction == "jmp far " then
            script.add("  jmp far " .. newMemSymbol)
            if nopCount &gt; 0 then
                script.add("  nop " .. nopCount)
            end
        else
            script.add("  jmp " .. newMemSymbol)
            if nopCount &gt; 0 then
                script.add("  nop " .. nopCount)
            end
        end

        script.add(returnSymbol .. ":")
        script.add("//registersymbol(" .. symbolName .. ")")
        script.add("")
        script.add("[DISABLE]")
        script.add(symbolName .. ":")
        script.add("  readmem(" .. copySymbol .. "," .. backupSize .. ")")
        script.add("")
        script.add("unregistersymbol(*)")
        script.add("dealloc(*)")
        script.add("")
        script.add("{")

        -- Add context before injection point (500 bytes before)
        local contextBefore = readBytes(startAddress - 500, 500, true)
        if contextBefore then
            for i = 1, #contextBefore, 16 do
                local line = {}
                for j = i, math.min(i+15, #contextBefore) do
                    table.insert(line, string.format("%02X", contextBefore[j]))
                end
                script.add(table.concat(line, " "))
            end
        end

        script.add("")
        script.add('// ORIGINAL CODE - INJECTION POINT: "' .. (moduleName or "") .. '"+' .. string.format("%X", moduleOffset or startAddress))
        script.add("")

        -- Add disassembly context (10 instructions before and after)
        local contextStart = startAddress
        for i = 1, 10 do
            local prevSize = getInstructionSize(contextStart - 1)
            if prevSize and prevSize &gt; 0 then
                contextStart = contextStart - prevSize
            else
                break
            end
        end

        -- Disassemble from context start to injection point + 10 instructions
        local currentAddr = contextStart
        local instructionsAfter = 0
        while currentAddr &lt; startAddress + 100 do
            local size = getInstructionSize(currentAddr)
            if not size or size == 0 then break end

            local dis = disassemble(currentAddr)
            if dis then
                local cleanDis = dis:gsub("^[^-]+-[^-]+-", ""):gsub("^%s+", ""):gsub("%s+$", "")
                local relAddr = (moduleName and (currentAddr - getAddress(moduleName))) or currentAddr

                if currentAddr == startAddress then
                    script.add('// ---------- INJECTING HERE ----------')
                    local bytes = readBytes(currentAddr, size, true)
                    local bytesStr = {}
                    for k = 1, #bytes do
                        table.insert(bytesStr, string.format("%02X", bytes[k]))
                    end
                    script.add('""+' .. string.format("%X", relAddr) .. ': ' .. string.format("%X", currentAddr) .. ' - ' .. cleanDis .. ' - ' .. table.concat(bytesStr, " "))
                    script.add('// ---------- DONE INJECTING  ----------')
                else
                    script.add('""+' .. string.format("%X", relAddr) .. ': ' .. string.format("%X", currentAddr) .. ' - ' .. cleanDis)
                end
            end

            currentAddr = currentAddr + size

            if currentAddr &gt; startAddress then
                instructionsAfter = instructionsAfter + 1
                if instructionsAfter &gt;= 10 then break end
            end
        end

        script.add("")

        -- Add context after injection point (500 bytes from injection point)
        local contextAfter = readBytes(startAddress, 500, true)
        if contextAfter then
            for i = 1, #contextAfter, 16 do
                local line = {}
                for j = i, math.min(i+15, #contextAfter) do
                    table.insert(line, string.format("%02X", contextAfter[j]))
                end
                script.add(table.concat(line, " "))
            end
        end

        script.add("")
        script.add("aobscan(" .. symbolName .. ", " .. wildcardAobString .. ")")
        script.add("}")
    end

    registerAutoAssemblerTemplate(templateName, callback)
    registeredTemplates[templateName] = true
end

local function registerDynamicInjections()
    if not registeredTemplates["Smart Auto Inject Short (64-bit)"] then
        registerDynamicInjection("Smart Auto Inject Short (64-bit)", "jmp ", 5)
    end
    if not registeredTemplates["Smart Auto Inject Far (64-bit)"] then
        registerDynamicInjection("Smart Auto Inject Far (64-bit)", "jmp far ", 14)
    end
end

registerDynamicInjections()

-- UI Functions
local function openAutoAssemble()
    local memView = getMemoryViewForm()
    if not memView then
        return false
    end

    local toolsMenu
    for i = 0, memView.Menu.Items.Count - 1 do
        if memView.Menu.Items[i].Caption == 'Tools' then
            toolsMenu = memView.Menu.Items[i]
            break
        end
    end

    if toolsMenu then
        for i = 0, toolsMenu.Count - 1 do
            if toolsMenu[i].Caption == 'Auto Assemble' then
                toolsMenu[i].OnClick(toolsMenu[i])
                return true
            end
        end
    end
    return false
end

local function findAutoAssemblerForm()
    for i = 0, getFormCount()-1 do
        local form = getForm(i)
        if form then
            local caption = form.Caption:lower()
            if caption:find("auto") and caption:find("assemble") then
                return form
            end
        end
    end
    return nil
end

local autoInjectForm = nil

local function createMainForm()
    if autoInjectForm and not autoInjectForm.Destroyed then
        autoInjectForm.show()
        return autoInjectForm
    end

    local form = createForm(nil)
    form.Caption = 'Smart Auto Inject Tool (64-bit)'
    form.Width = 300
    form.Height = 180
    form.Position = poScreenCenter
    form.BorderStyle = bsDialog

    -- Injection type selection
    local cbShort = createCheckBox(form)
    cbShort.Caption = 'Auto Inject Short (jmp)'
    cbShort.Left = 20
    cbShort.Top = 20
    cbShort.Width = 200
    cbShort.Checked = true

    local cbFar = createCheckBox(form)
    cbFar.Caption = 'Auto Inject Far (jmp far)'
    cbFar.Left = 20
    cbFar.Top = 50
    cbFar.Width = 200

    cbShort.OnChange = function()
        if cbShort.Checked then cbFar.Checked = false end
    end

    cbFar.OnChange = function()
        if cbFar.Checked then cbShort.Checked = false end
    end

    -- Wildcard setting
    local cbWildcard = createCheckBox(form)
    cbWildcard.Caption = 'Use Wildcards in AOB'
    cbWildcard.Left = 20
    cbWildcard.Top = 80
    cbWildcard.Width = 200
    cbWildcard.Checked = true

    -- Generate button
    local btnGenerate = createButton(form)
    btnGenerate.Caption = 'Generate AoB Code'
    btnGenerate.Left = 20
    btnGenerate.Top = 120
    btnGenerate.Width = 120
    btnGenerate.Height = 30

    btnGenerate.OnClick = function()
        lastWildcardSetting = cbWildcard.Checked

        if not openAutoAssemble() then return end

        local timer = createTimer()
        timer.Interval = 100
        local attempts = 0

        timer.OnTimer = function(t)
            attempts = attempts + 1
            local aaForm = findAutoAssemblerForm()

            if aaForm and aaForm.Visible then
                t.destroy()

                local templateName = cbShort.Checked and
                    "Smart Auto Inject Short (64-bit)" or
                    "Smart Auto Inject Far (64-bit)"

                -- First try with menu
                local executed = false
                for i = 0, aaForm.Menu.Items.Count - 1 do
                    local item = aaForm.Menu.Items[i]
                    if item.Caption == 'Templates' or item.Caption:lower():find("template") then
                        for j = 0, item.Count - 1 do
                            if item[j].Caption == templateName then
                                item[j].OnClick(item[j])
                                executed = true
                                break
                            end
                        end
                        if executed then break end
                    end
                end

                -- Direct fallback if not found in menu
                if not executed then
                    local callback = getAutoAssemblerTemplate(templateName)
                    if callback then
                        callback(aaForm.Memo1.Lines, nil)
                    else
                        showMessage("Template callback not found: " .. templateName)
                    end
                end
            elseif attempts &gt; 30 then
                t.destroy()
                showMessage("Auto Assembler not found after 30 attempts")
            end
        end
    end

    -- Close button
    local btnClose = createButton(form)
    btnClose.Caption = 'Close'
    btnClose.Left = 150
    btnClose.Top = 120
    btnClose.Width = 120
    btnClose.Height = 30
    btnClose.OnClick = function()
        form.close()
    end

    form.OnClose = function()
        autoInjectForm = nil
        return caFree
    end

    autoInjectForm = form
    return form
end

local function addGenerateAOBButton()
    local memoryView = getMemoryViewForm()
    if not memoryView then
        return false
    end

    -- Check if button already added
    for i = 0, memoryView.Menu.Items.Count - 1 do
        local item = memoryView.Menu.Items[i]
        if item.Caption == 'AoB Generator (64-bit)' then
            return true
        end
    end

    -- Create new menu item
    local parent = memoryView.Menu.Items
    local generateMenuItem = createMenuItem(parent)
    generateMenuItem.Caption = "AoB Generator (64-bit)"
    generateMenuItem.OnClick = function()
        local form = createMainForm()
        form.show()
    end

    parent.add(generateMenuItem)
    return true
end

local function initializeButtonAdder()
    local timer = createTimer(nil, false)
    timer.Interval = 1000
    timer.OnTimer = function(t)
        if addGenerateAOBButton() then
            t.destroy()
        end
    end
    timer.Enabled = true
end

initializeButtonAdder()

{$asm}

[DISABLE]

{$lua}



{$asm}
</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>17723</ID>
          <Description>"Script generator 64-bit"</Description>
          <Options moHideChildren="1"/>
          <Color>00FF00</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]

{$lua}

-- Global table to track registered templates
local registeredTemplates = {}
local lastWildcardSetting = true  -- Default setting: wildcards enabled

-- Funzione per trovare la finestra Auto Assembler
local function findAutoAssemblerForm()
    for i = 0, getFormCount()-1 do
        local form = getForm(i)
        if form then
            local caption = form.Caption:lower()
            if caption:find("auto") and caption:find("assemble") then
                return form
            end
        end
    end
    return nil
end

local function formatAddress(address, useModules)
    if not useModules then
        return string.format("%.8x", address)
    end

    -- Find module for address
    local modules = enumModules()
    if not modules then return string.format("%.8x", address) end

    for i, module in ipairs(modules) do
        local base = module.Address
        local size = module.Size
        if address &gt;= base and address &lt; (base + size) then
            return module.Name .. "+" .. string.format("%.8x", address - base)
        end
    end

    return string.format("%.8x", address)
end

local function parseAddressInput(input)
    -- Check if input is in module+offset format
    local moduleName, offsetStr = string.match(input, "(.+)%+([%x]+)")
    if moduleName and offsetStr then
        local offset = tonumber(offsetStr, 16)
        if not offset then return nil end

        -- Find module
        local modules = enumModules()
        if not modules then return nil end

        for i, module in ipairs(modules) do
            if module.Name:lower() == moduleName:lower() then
                return module.Address + offset, module.Name, offset
            end
        end
        return nil -- Module not found
    else
        -- Input is a plain address
        local address = tonumber(input, 16)
        if not address then return nil end

        -- Check if address belongs to any module
        local modules = enumModules()
        if modules then
            for i, module in ipairs(modules) do
                local base = module.Address
                local size = getModuleSize(module.Name)
                if address &gt;= base and address &lt; (base + size) then
                    return address, module.Name, address - base
                end
            end
        end

        return address, nil, nil -- Address without module
    end
end

local function createProgressDialog(title, message)
    local progressForm = createForm(false)
    progressForm.Caption = title
    progressForm.Width = 400
    progressForm.Height = 150
    progressForm.Position = 'poScreenCenter'
    progressForm.BorderStyle = 'bsDialog'
    progressForm.FormStyle = 'fsStayOnTop'

    local messageLabel = createLabel(progressForm)
    messageLabel.Caption = message
    messageLabel.Left = 20
    messageLabel.Top = 20
    messageLabel.Width = 360
    messageLabel.Height = 30
    messageLabel.Alignment = 'taCenter'
    messageLabel.Font.Size = 10
    messageLabel.Font.Style = 'fsBold'

    local statusLabel = createLabel(progressForm)
    statusLabel.Caption = "Initializing..."
    statusLabel.Left = 20
    statusLabel.Top = 60
    statusLabel.Width = 360
    statusLabel.Height = 20
    statusLabel.Alignment = 'taCenter'
    statusLabel.Font.Size = 9

    local progressBar = createProgressBar(progressForm)
    progressBar.Left = 20
    progressBar.Top = 90
    progressBar.Width = 360
    progressBar.Height = 20
    progressBar.Min = 0
    progressBar.Max = 100
    progressBar.Position = 0
    progressBar.Style = 'pbstMarquee'

    progressForm.show()

    local function updateProgress(status, percentage)
        if progressForm and not progressForm.Destroyed then
            statusLabel.Caption = status or "Processing..."
            if percentage then
                progressBar.Style = 'pbstNormal'
                progressBar.Position = percentage
            else
                progressBar.Style = 'pbstMarquee'
            end
            progressForm.repaint()
            sleep(1)
        end
    end

    local function closeProgress()
        if progressForm and not progressForm.Destroyed then
            progressForm.close()
            progressForm.destroy()
        end
    end

    return updateProgress, closeProgress
end

local function createUniqueAOBPattern(startAddress, endAddress, minimalSize, moduleName)
    local updateProgress, closeProgress = createProgressDialog("Smart Auto Inject", "Searching for Unique AOB Patterns...")

    updateProgress("Initializing pattern search...", 0)

    local currentAddress = startAddress
    local instructions = {}

    updateProgress("Collecting instructions from memory...", 10)

    -- Collect many more instructions to allow for very long patterns
    local maxInstructions = 500
    while currentAddress &lt; startAddress + 2000 and #instructions &lt; maxInstructions do
        local instSize = getInstructionSize(currentAddress)
        if not instSize or instSize == 0 then break end

        local bytes = readBytes(currentAddress, instSize, true)
        if not bytes then break end

        table.insert(instructions, {
            address = currentAddress,
            size = instSize,
            bytes = bytes
        })

        currentAddress = currentAddress + instSize

        if #instructions % 50 == 0 then
            local progressPercent = 10 + (30 * #instructions / maxInstructions)
            updateProgress("Collected " .. #instructions .. " instructions...", progressPercent)
        end
    end

    updateProgress("Collected " .. #instructions .. " instructions. Preparing pattern generation...", 40)

    -- Function to test if AOB pattern is unique
    local function testAOBPattern(pattern, targetModule)
        local results

        if targetModule then
            results = AOBScan(pattern, targetModule)
        end

        if not results or (results and results.Count == 0) then
            if results then
                results.destroy()
            end
            results = AOBScan(pattern)
        end

        local count = 0
        if results then
            if results.Count then
                count = results.Count
            elseif type(results) == "table" then
                for k, v in pairs(results) do
                    count = count + 1
                end
            end

            if results.destroy then
                results.destroy()
            end
        end

        return count == 1, count
    end

    -- Function to create exact pattern (no wildcards)
    local function createExactPattern(instructionCount)
        local patternTable = {}

        for i = 1, instructionCount do
            if i &gt; #instructions then break end
            local inst = instructions[i]
            if inst and inst.bytes then
                for j = 1, #inst.bytes do
                    table.insert(patternTable, string.format("%02X", inst.bytes[j]))
                end
            end
        end

        return table.concat(patternTable, " ")
    end

    -- Function to create wildcarded pattern
    local function createWildcardPattern(instructionCount)
        local patternTable = {}

        for i = 1, instructionCount do
            if i &gt; #instructions then break end
            local inst = instructions[i]
            if inst and inst.bytes then
                -- First byte exact, rest wildcard
                table.insert(patternTable, string.format("%02X", inst.bytes[1]))
                for j = 2, #inst.bytes do
                    table.insert(patternTable, "??")
                end
            end
        end

        return table.concat(patternTable, " ")
    end

    -- Progressive search for both exact and wildcard patterns
    updateProgress("Starting pattern uniqueness testing...", 50)

    local startInstructionCount = 5
    local currentInstructionCount = startInstructionCount
    local maxAttempts = 10
    local attempt = 1
    local finalExactPattern = nil
    local finalWildcardPattern = nil

    -- First, try to find unique exact pattern
    updateProgress("Searching for unique exact pattern...", 50)
    while attempt &lt;= maxAttempts and currentInstructionCount &lt;= #instructions do
        local attemptProgress = 50 + (20 * attempt / maxAttempts)
        updateProgress("Testing exact pattern with " .. currentInstructionCount .. " instructions...", attemptProgress)

        local pattern = createExactPattern(currentInstructionCount)

        if pattern and string.len(pattern) &gt; 0 then
            local isUnique, matchCount = testAOBPattern(pattern, moduleName)

            if isUnique then
                finalExactPattern = pattern
                updateProgress("Found unique exact pattern!", 70)
                break
            end
        end

        currentInstructionCount = currentInstructionCount * 2
        attempt = attempt + 1
    end

    -- If no unique exact pattern found, create a fallback
    if not finalExactPattern then
        local fallbackInstructionCount = math.min(30, #instructions)
        finalExactPattern = createExactPattern(fallbackInstructionCount)
    end

    -- Reset for wildcard pattern search
    currentInstructionCount = startInstructionCount
    attempt = 1

    -- Now find unique wildcard pattern
    updateProgress("Searching for unique wildcard pattern...", 75)
    while attempt &lt;= maxAttempts and currentInstructionCount &lt;= #instructions do
        local attemptProgress = 75 + (20 * attempt / maxAttempts)
        updateProgress("Testing wildcard pattern with " .. currentInstructionCount .. " instructions...", attemptProgress)

        local pattern = createWildcardPattern(currentInstructionCount)

        if pattern and string.len(pattern) &gt; 0 then
            local isUnique, matchCount = testAOBPattern(pattern, moduleName)

            if isUnique then
                finalWildcardPattern = pattern
                updateProgress("Found unique wildcard pattern!", 95)
                break
            end
        end

        currentInstructionCount = currentInstructionCount * 2
        attempt = attempt + 1
    end

    -- If no unique wildcard pattern found, create a fallback
    if not finalWildcardPattern then
        local fallbackInstructionCount = math.min(30, #instructions)
        finalWildcardPattern = createWildcardPattern(fallbackInstructionCount)
    end

    updateProgress("Pattern generation complete", 100)
    sleep(300)
    closeProgress()

    return finalExactPattern, finalWildcardPattern
end

local function createScriptInMainMenu(scriptContent, symbolName)
    local al = getAddressList()
    if not al then return false end

    -- Find the next available number for the script name
    local nextNumber = 1
    local existingNumbers = {}

    -- Collect all existing numbers from "Injection Script" records
    for i = 0, al.Count - 1 do
        local desc = al[i].Description
        local num = desc:match("^Injection Script (%d+)$")
        if num then
            existingNumbers[tonumber(num)] = true
        end
    end

    -- Find the first available number
    while existingNumbers[nextNumber] do
        nextNumber = nextNumber + 1
    end

    -- Create the Auto Assembler record
    local memrec = al.createMemoryRecord()
    memrec.Description = string.format("Injection Script %d - %s", nextNumber, symbolName)
    memrec.Type = vtAutoAssembler
    memrec.Script = scriptContent
    memrec.Active = false

    return true
end

local function registerDynamicInjection(templateName, jmpInstruction, requiredSize)
    if registeredTemplates[templateName] then
        return
    end

    local callback = function(script, sender)
        local memoryView = getMemoryViewForm()
        local disassemblerView = memoryView.DisassemblerView
        local startAddress = disassemblerView.SelectedAddress
        local endAddress = disassemblerView.SelectedAddress2 or startAddress

        if startAddress &gt; endAddress then
            startAddress, endAddress = endAddress, startAddress
        end

        local selectedAddress = inputQuery('Code injection template', 'On what address do you want the jump? (Can use ModuleName+Offset format)', string.format('%08X', startAddress))
        if selectedAddress then
            address, moduleName, moduleOffset = parseAddressInput(selectedAddress)
            if not address then
                error("Invalid address format")
                return
            end
            useModule = moduleName ~= nil
        else
            return
        end

        local symbolName = inputQuery('Code injection template', 'What do you want to name the symbol for the injection point?', 'INJECT')
        if not symbolName then return end

        -- Calculate actual replacement size
        local actualReplacementSize = 0
        local instCount = 0
        local currentAddress = startAddress
        while actualReplacementSize &lt; requiredSize do
            local instSize = getInstructionSize(currentAddress)
            if not instSize then break end
            actualReplacementSize = actualReplacementSize + instSize
            instCount = instCount + 1
            currentAddress = currentAddress + instSize
        end

        local exactAobString, wildcardAobString = createUniqueAOBPattern(startAddress, startAddress + actualReplacementSize + 20, 15, moduleName)

        -- Calculate size to backup (actualReplacementSize + some extra for safety)
        local backupSize = math.max(actualReplacementSize + 15, 30)
        local nopCount = actualReplacementSize - requiredSize

        -- Generate the script content as a string
        local scriptLines = {}

       -- table.insert(scriptLines, "{ Game   : " .. (moduleName or "Unknown") .. "")
      --  table.insert(scriptLines, "  Version: ")
      --  table.insert(scriptLines, "  Date   : " .. os.date("%Y-%m-%d"))
      --  table.insert(scriptLines, "  Author : Smart Auto Inject 64-bit")
      --  table.insert(scriptLines, "")
      --  table.insert(scriptLines, "  This script injects code at the selected area")
      --  table.insert(scriptLines, "}")
        table.insert(scriptLines, "")

        table.insert(scriptLines, "[ENABLE]")
        table.insert(scriptLines, '{$lua}')
        table.insert(scriptLines, "if syntaxcheck then return end")

        -- AOB registration function with multiple pattern support and error dialog
        table.insert(scriptLines, 'function aob_register(sym, pat1, pat2)')
        table.insert(scriptLines, '  -- Function to show error message')
        table.insert(scriptLines, '  local function showErrorMessage(message)')
        table.insert(scriptLines, '    local errorForm = createForm(false)')
        table.insert(scriptLines, '    errorForm.Caption = "AOB Registration Error"')
        table.insert(scriptLines, '    errorForm.Width = 400')
        table.insert(scriptLines, '    errorForm.Height = 150')
        table.insert(scriptLines, '    errorForm.Position = "poScreenCenter"')
        table.insert(scriptLines, '    errorForm.BorderStyle = "bsDialog"')
        table.insert(scriptLines, '    errorForm.FormStyle = "fsStayOnTop"')
        table.insert(scriptLines, '    ')
        table.insert(scriptLines, '    local label = createLabel(errorForm)')
        table.insert(scriptLines, '    label.Caption = message')
        table.insert(scriptLines, '    label.Left = 20')
        table.insert(scriptLines, '    label.Top = 30')
        table.insert(scriptLines, '    label.Width = 360')
        table.insert(scriptLines, '    label.Height = 60')
        table.insert(scriptLines, '    label.Alignment = "taCenter"')
        table.insert(scriptLines, '    label.Font.Size = 10')
        table.insert(scriptLines, '    ')
        table.insert(scriptLines, '    errorForm.show()')
        table.insert(scriptLines, '    ')
        table.insert(scriptLines, '    -- Auto-close after 3 seconds')
        table.insert(scriptLines, '    local closeTimer = createTimer(errorForm)')
        table.insert(scriptLines, '    closeTimer.Interval = 3000')
        table.insert(scriptLines, '    closeTimer.OnTimer = function()')
        table.insert(scriptLines, '      closeTimer.destroy()')
        table.insert(scriptLines, '      errorForm.close()')
        table.insert(scriptLines, '    end')
        table.insert(scriptLines, '    closeTimer.Enabled = true')
        table.insert(scriptLines, '  end')
        table.insert(scriptLines, '  ')
        table.insert(scriptLines, '  -- Try first pattern (exact)')
        table.insert(scriptLines, '  local instr = AOBScan(pat1, "+X")')
        table.insert(scriptLines, '  if instr and instr.Count &gt; 0 then')
        table.insert(scriptLines, '    if instr.Count == 1 then')
        table.insert(scriptLines, '      -- First pattern is unique, use it')
        table.insert(scriptLines, '      local addy = instr[0]')
        table.insert(scriptLines, '      instr.destroy()')
        table.insert(scriptLines, '      unregisterSymbol(sym)')
        table.insert(scriptLines, '      registerSymbol(sym, tonumber(addy,16))')
       --- table.insert(scriptLines, '      print("Enabled with exact pattern (Pattern 1)")')
        table.insert(scriptLines, '      return')
        table.insert(scriptLines, '    else')
        table.insert(scriptLines, '      -- First pattern found multiple results')
        table.insert(scriptLines, '      instr.destroy()')
        table.insert(scriptLines, '      print("Pattern 1 found " .. tostring(instr.Count) .. " results, trying Pattern 2...")')
        table.insert(scriptLines, '    end')
        table.insert(scriptLines, '  else')
        table.insert(scriptLines, '    if instr then instr.destroy() end')
        table.insert(scriptLines, '    print("Pattern 1 not found, trying Pattern 2...")')
        table.insert(scriptLines, '  end')
        table.insert(scriptLines, '  ')
        table.insert(scriptLines, '  -- Try second pattern (wildcard)')
        table.insert(scriptLines, '  instr = AOBScan(pat2, "+X")')
        table.insert(scriptLines, '  if instr and instr.Count &gt; 0 then')
        table.insert(scriptLines, '    if instr.Count == 1 then')
        table.insert(scriptLines, '      -- Second pattern is unique, use it')
        table.insert(scriptLines, '      local addy = instr[0]')
        table.insert(scriptLines, '      instr.destroy()')
        table.insert(scriptLines, '      unregisterSymbol(sym)')
        table.insert(scriptLines, '      registerSymbol(sym, tonumber(addy,16))')
        table.insert(scriptLines, '      print("Enabled with wildcard pattern (Pattern 2)")')
        table.insert(scriptLines, '      return')
        table.insert(scriptLines, '    else')
        table.insert(scriptLines, '      -- Second pattern found multiple results')
        table.insert(scriptLines, '      local count = instr.Count')
        table.insert(scriptLines, '      instr.destroy()')
        table.insert(scriptLines, '      showErrorMessage("Pattern not unique!\\n\\nPattern 2 found " .. count .. " results.\\nCannot enable script.")')
        table.insert(scriptLines, '      error("Pattern 2 not unique: found " .. count .. " results")')
        table.insert(scriptLines, '    end')
        table.insert(scriptLines, '  else')
        table.insert(scriptLines, '    if instr then instr.destroy() end')
        table.insert(scriptLines, '    showErrorMessage("AOB patterns not found!\\n\\nBoth patterns failed to locate the injection point.\\nThe game may have been updated.")')
        table.insert(scriptLines, '    error("Both AOB patterns failed")')
        table.insert(scriptLines, '  end')
        table.insert(scriptLines, 'end')
        table.insert(scriptLines, '')
        table.insert(scriptLines, 'aob_register("' .. symbolName .. '","' .. exactAobString .. '"')
        table.insert(scriptLines, ', "' .. wildcardAobString .. '")')
        table.insert(scriptLines, '{$asm}')

        local newMemSymbol = "newmem"
        local codeSymbol = "code"
        local returnSymbol = "return"
        local copySymbol = symbolName .. "Copy"

        -- Calculate size to backup (actualReplacementSize + some extra for safety)
        local backupSize = math.max(actualReplacementSize + 15, 30)

        -- For jmp short, include the symbol name; for jmp far, don't
        if jmpInstruction == "jmp far " then
            table.insert(scriptLines, "alloc(" .. newMemSymbol .. ",$1000)")
        else
            table.insert(scriptLines, "alloc(" .. newMemSymbol .. ",$1000," .. symbolName .. ")")
        end
        table.insert(scriptLines, "alloc(" .. copySymbol .. "," .. backupSize .. ")")
        table.insert(scriptLines, "registersymbol(" .. copySymbol .. ")")
        table.insert(scriptLines, "")
        table.insert(scriptLines, copySymbol .. ":")
        table.insert(scriptLines, "  readmem(" .. symbolName .. "," .. backupSize .. ")")
        table.insert(scriptLines, "")
        table.insert(scriptLines, "label(" .. codeSymbol .. ")")
        table.insert(scriptLines, "label(" .. returnSymbol .. ")")
        table.insert(scriptLines, "")
        table.insert(scriptLines, newMemSymbol .. ":")
        table.insert(scriptLines, "")
        table.insert(scriptLines, "")
        table.insert(scriptLines, "")
        table.insert(scriptLines, codeSymbol .. ":")
        table.insert(scriptLines, "  // Original code")
        table.insert(scriptLines, "  readmem(" .. symbolName .. "," .. actualReplacementSize .. ")")
        table.insert(scriptLines, "  jmp " .. returnSymbol)
        table.insert(scriptLines, "")
        table.insert(scriptLines, symbolName .. ":")

        if jmpInstruction == "jmp far " then
            table.insert(scriptLines, "  jmp far " .. newMemSymbol)
            if nopCount &gt; 0 then
                table.insert(scriptLines, "  nop " .. nopCount)
            end
        else
            table.insert(scriptLines, "  jmp " .. newMemSymbol)
            if nopCount &gt; 0 then
                table.insert(scriptLines, "  nop " .. nopCount)
            end
        end

        table.insert(scriptLines, returnSymbol .. ":")
        table.insert(scriptLines, "//registersymbol(" .. symbolName .. ")")
        table.insert(scriptLines, "")
        table.insert(scriptLines, "[DISABLE]")
        table.insert(scriptLines, symbolName .. ":")
        table.insert(scriptLines, "  readmem(" .. copySymbol .. "," .. backupSize .. ")")
        table.insert(scriptLines, "")
        table.insert(scriptLines, "unregistersymbol(*)")
        table.insert(scriptLines, "dealloc(*)")
        table.insert(scriptLines, "")
        table.insert(scriptLines, "{")

        -- Add context before injection point (500 bytes before)
        local contextBefore = readBytes(startAddress - 500, 500, true)
        if contextBefore then
            for i = 1, #contextBefore, 16 do
                local line = {}
                for j = i, math.min(i+15, #contextBefore) do
                    table.insert(line, string.format("%02X", contextBefore[j]))
                end
                table.insert(scriptLines, table.concat(line, " "))
            end
        end

        table.insert(scriptLines, "")
        table.insert(scriptLines, '// ORIGINAL CODE - INJECTION POINT: "' .. (moduleName or "") .. '"+' .. string.format("%X", moduleOffset or startAddress))
        table.insert(scriptLines, "")

        -- Add disassembly context (10 instructions before and after)
        local contextStart = startAddress
        for i = 1, 10 do
            local prevSize = getInstructionSize(contextStart - 1)
            if prevSize and prevSize &gt; 0 then
                contextStart = contextStart - prevSize
            else
                break
            end
        end

        -- Disassemble from context start to injection point + 10 instructions
        local currentAddr = contextStart
        local instructionsAfter = 0
        while currentAddr &lt; startAddress + 100 do
            local size = getInstructionSize(currentAddr)
            if not size or size == 0 then break end

            local dis = disassemble(currentAddr)
            if dis then
                local cleanDis = dis:gsub("^[^-]+-[^-]+-", ""):gsub("^%s+", ""):gsub("%s+$", "")
                local relAddr = (moduleName and (currentAddr - getAddress(moduleName))) or currentAddr

                if currentAddr == startAddress then
                    table.insert(scriptLines, '// ---------- INJECTING HERE ----------')
                    local bytes = readBytes(currentAddr, size, true)
                    local bytesStr = {}
                    for k = 1, #bytes do
                        table.insert(bytesStr, string.format("%02X", bytes[k]))
                    end
                    table.insert(scriptLines, '""+' .. string.format("%X", relAddr) .. ': ' .. string.format("%X", currentAddr) .. ' - ' .. cleanDis .. ' - ' .. table.concat(bytesStr, " "))
                    table.insert(scriptLines, '// ---------- DONE INJECTING  ----------')
                else
                    table.insert(scriptLines, '""+' .. string.format("%X", relAddr) .. ': ' .. string.format("%X", currentAddr) .. ' - ' .. cleanDis)
                end
            end

            currentAddr = currentAddr + size

            if currentAddr &gt; startAddress then
                instructionsAfter = instructionsAfter + 1
                if instructionsAfter &gt;= 10 then break end
            end
        end

        table.insert(scriptLines, "")

        -- Add context after injection point (500 bytes from injection point)
        local contextAfter = readBytes(startAddress, 500, true)
        if contextAfter then
            for i = 1, #contextAfter, 16 do
                local line = {}
                for j = i, math.min(i+15, #contextAfter) do
                    table.insert(line, string.format("%02X", contextAfter[j]))
                end
                table.insert(scriptLines, table.concat(line, " "))
            end
        end

        table.insert(scriptLines, "")
        table.insert(scriptLines, "aobscan(" .. symbolName .. ", " .. wildcardAobString .. ")")
        table.insert(scriptLines, "}")

        -- Convert the script lines to a single string
        local scriptContent = table.concat(scriptLines, "\n")

        -- Create the script in the main menu
        if createScriptInMainMenu(scriptContent, symbolName) then
            -- Close the Auto Assembler window using the global function
            local aaForm = findAutoAssemblerForm()
            if aaForm then
                aaForm.close()
            end
           --- showMessage("Script successfully created in the main menu!")
        else
            showMessage("Error creating script in the main menu!")
        end
    end

    registerAutoAssemblerTemplate(templateName, callback)
    registeredTemplates[templateName] = true
end

local function registerDynamicInjections()
    if not registeredTemplates["Smart Auto Inject Short (64-bit)"] then
        registerDynamicInjection("Smart Auto Inject Short (64-bit)", "jmp ", 5)
    end
    if not registeredTemplates["Smart Auto Inject Far (64-bit)"] then
        registerDynamicInjection("Smart Auto Inject Far (64-bit)", "jmp far ", 14)
    end
end

registerDynamicInjections()

-- UI Functions
local function openAutoAssemble()
    local memView = getMemoryViewForm()
    if not memView then
        return false
    end

    local toolsMenu
    for i = 0, memView.Menu.Items.Count - 1 do
        if memView.Menu.Items[i].Caption == 'Tools' then
            toolsMenu = memView.Menu.Items[i]
            break
        end
    end

    if toolsMenu then
        for i = 0, toolsMenu.Count - 1 do
            if toolsMenu[i].Caption == 'Auto Assemble' then
                toolsMenu[i].OnClick(toolsMenu[i])
                return true
            end
        end
    end
    return false
end

local autoInjectForm = nil

local function createMainForm()
    if autoInjectForm and not autoInjectForm.Destroyed then
        autoInjectForm.show()
        return autoInjectForm
    end

    local form = createForm(nil)
    form.Caption = 'Smart Auto Inject Tool (64-bit)'
    form.Width = 300
    form.Height = 180
    form.Position = poScreenCenter
    form.BorderStyle = bsDialog

    -- Injection type selection
    local cbShort = createCheckBox(form)
    cbShort.Caption = 'Auto Inject Short (jmp)'
    cbShort.Left = 20
    cbShort.Top = 20
    cbShort.Width = 200
    cbShort.Checked = true

    local cbFar = createCheckBox(form)
    cbFar.Caption = 'Auto Inject Far (jmp far)'
    cbFar.Left = 20
    cbFar.Top = 50
    cbFar.Width = 200

    cbShort.OnChange = function()
        if cbShort.Checked then cbFar.Checked = false end
    end

    cbFar.OnChange = function()
        if cbFar.Checked then cbShort.Checked = false end
    end

    -- Wildcard setting
    local cbWildcard = createCheckBox(form)
    cbWildcard.Caption = 'Use Wildcards in AOB'
    cbWildcard.Left = 20
    cbWildcard.Top = 80
    cbWildcard.Width = 200
    cbWildcard.Checked = true

    -- Generate button
    local btnGenerate = createButton(form)
    btnGenerate.Caption = 'Generate AoB Code'
    btnGenerate.Left = 20
    btnGenerate.Top = 120
    btnGenerate.Width = 120
    btnGenerate.Height = 30

    btnGenerate.OnClick = function()
        lastWildcardSetting = cbWildcard.Checked

        if not openAutoAssemble() then return end

        local timer = createTimer()
        timer.Interval = 100
        local attempts = 0

        timer.OnTimer = function(t)
            attempts = attempts + 1
            local aaForm = findAutoAssemblerForm()

            if aaForm and aaForm.Visible then
                t.destroy()

                local templateName = cbShort.Checked and
                    "Smart Auto Inject Short (64-bit)" or
                    "Smart Auto Inject Far (64-bit)"

                -- First try with menu
                local executed = false
                for i = 0, aaForm.Menu.Items.Count - 1 do
                    local item = aaForm.Menu.Items[i]
                    if item.Caption == 'Templates' or item.Caption:lower():find("template") then
                        for j = 0, item.Count - 1 do
                            if item[j].Caption == templateName then
                                item[j].OnClick(item[j])
                                executed = true
                                break
                            end
                        end
                        if executed then break end
                    end
                end

                -- Direct fallback if not found in menu
                if not executed then
                    local callback = getAutoAssemblerTemplate(templateName)
                    if callback then
                        callback(aaForm.Memo1.Lines, nil)
                    else
                        showMessage("Template callback not found: " .. templateName)
                    end
                end
            elseif attempts &gt; 30 then
                t.destroy()
                showMessage("Auto Assembler not found after 30 attempts")
            end
        end
    end

    -- Close button
    local btnClose = createButton(form)
    btnClose.Caption = 'Close'
    btnClose.Left = 150
    btnClose.Top = 120
    btnClose.Width = 120
    btnClose.Height = 30
    btnClose.OnClick = function()
        form.close()
    end

    form.OnClose = function()
        autoInjectForm = nil
        return caFree
    end

    autoInjectForm = form
    return form
end

local function addGenerateAOBButton()
    local memoryView = getMemoryViewForm()
    if not memoryView then
        return false
    end

    -- Check if button already added
    for i = 0, memoryView.Menu.Items.Count - 1 do
        local item = memoryView.Menu.Items[i]
        if item.Caption == 'AoB Generator (64-bit)' then
            return true
        end
    end

    -- Create new menu item
    local parent = memoryView.Menu.Items
    local generateMenuItem = createMenuItem(parent)
    generateMenuItem.Caption = "AoB Generator (64-bit)"
    generateMenuItem.OnClick = function()
        local form = createMainForm()
        form.show()
    end

    parent.add(generateMenuItem)
    return true
end

local function initializeButtonAdder()
    local timer = createTimer(nil, false)
    timer.Interval = 1000
    timer.OnTimer = function(t)
        if addGenerateAOBButton() then
            t.destroy()
        end
    end
    timer.Enabled = true
end

initializeButtonAdder()

{$asm}

[DISABLE]

{$lua}



{$asm}
</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>17441</ID>
          <Description>"magicCrystalCount"</Description>
          <Options moHideChildren="1"/>
          <Color>00FF00</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

function aob_register(sym, ...)
  local patterns = {...}
  local found = false
  local addy = nil
  
  for i, pat in ipairs(patterns) do
    local instr = AOBScan(pat, "+X")
    if instr and instr.Count == 1 then
      addy = instr[0]
      instr.destroy()
      found = true
      break
    end
    if instr then instr.destroy() end
  end
  
  if not found then
    for i, pat in ipairs(patterns) do
      local instr = AOBScan(pat)
      if instr and instr.Count == 1 then
        addy = instr[0]
        instr.destroy()
        found = true
        break
      end
      if instr then instr.destroy() end
    end
  end
  
  if not found then
    error('None of the patterns found a unique match!')
  end
  
  unregisterSymbol(sym)
  registerSymbol(sym, tonumber(addy,16))
end

function getInstructionLength(address)
  local addr
  if type(address) == "string" then
    addr = tonumber(address, 16)
  else
    addr = address
  end

  local result = disassemble(addr)
  if result then
    local bytes_section = result:match("- ([%x%s]+) -")
    if bytes_section then
      local cleaned = bytes_section:gsub("%s", "")
      local byte_count = #cleaned / 2
      if byte_count &gt; 0 and byte_count &lt;= 15 then
        return math.floor(byte_count)
      end
    end
  end

  local firstByte = readBytes(addr, 1)
  if not firstByte then
    error("Cannot read memory at address: " .. string.format("%X", addr))
  end

  local opcode = firstByte
  if opcode == 0x66 or opcode == 0x67 or opcode == 0xF2 or opcode == 0xF3 then
    local secondByte = readBytes(addr + 1, 1)
    if secondByte == 0x0F then
      return 5
    end
  end

  if opcode == 0xE9 then return 5 end
  if opcode == 0xEB then return 2 end
  if opcode == 0xE8 then return 5 end

  for len = 1, 15 do
    local testAddr = addr + len
    local disasm2 = disassemble(testAddr)
    if disasm2 and not disasm2:match("??") then
      return len
    end
  end

  return 5
end

-- Global variables to store analyzed instruction details
local originalInstruction = ""
local sourceRegister = ""
local destinationRegister = ""
local memoryBase = ""
local memoryOffset = ""
local detectedXMMRegs = {}
local detectedGPRegs = {}
local detectedMemoryRefs = {}

function analyzeOriginalCode(address, length)
  -- Reset detection arrays
  detectedXMMRegs = {}
  detectedGPRegs = {}
  detectedMemoryRefs = {}
  sourceRegister = ""
  destinationRegister = ""
  memoryBase = ""
  memoryOffset = ""

  local disasm = disassemble(address)
  if not disasm then
    return
  end

  -- Extract the instruction part after the bytes
  local instructionPart = disasm:match("-%s+([^-]+)$")
  if not instructionPart then
    instructionPart = disasm:match("-%s+(.+)")
  end

  if instructionPart then
    instructionPart = instructionPart:gsub("^%s+", ""):gsub("%s+$", "")
    originalInstruction = instructionPart

    -- Detect all memory references first (including dword ptr, qword ptr, etc.)
    for memRef in originalInstruction:gmatch("%[([^%]]+)%]") do
      table.insert(detectedMemoryRefs, memRef)

      -- Extract base and offset from memory reference
      local base, offset = memRef:match("([^%+%-]+)%+([^%+%-]+)")
      if base and offset then
        if memoryBase == "" then memoryBase = base end
        if memoryOffset == "" then memoryOffset = offset end
      else
        -- Single register case
        if memoryBase == "" then memoryBase = memRef end
      end
    end

    -- Detect all GP registers (including 64-bit, 32-bit, 16-bit, 8-bit)
    local gpRegisterPattern = "r[abc]x|r[def]x|r[sb]p|r[sd]i|r[89]|r1[0-5]|[er]?[abc]x|[er]?[def]x|[er]?[sb]p|[er]?[sd]i|[abcd]l|[abcd]h|sil|dil|bpl|spl|r[89][dwb]|r1[0-5][dwb]"
    for reg in originalInstruction:gmatch(gpRegisterPattern) do
      if not table.concat(detectedGPRegs, ","):find(reg) then
        table.insert(detectedGPRegs, reg)
      end
    end

    -- Detect all XMM registers
    local xmmRegisterPattern = "[xyz]mm[0-9]+"
    for reg in originalInstruction:gmatch(xmmRegisterPattern) do
      if not table.concat(detectedXMMRegs, ","):find(reg) then
        table.insert(detectedXMMRegs, reg)
      end
    end

    -- Analyze instruction patterns to determine source and destination

    -- Pattern 1: instruction dest,src - Register to Register
    local dest, src = originalInstruction:match("^%w+%s+([^%s,]+),([^%s,]+)$")
    if dest and src and not dest:match("%[") and not src:match("%[") then
      destinationRegister = dest
      sourceRegister = src
    end

    -- Pattern 2: instruction dest,[mem] - Memory to Register
    local dest2, mem = originalInstruction:match("^%w+%s+([^%s,]+),[^%[]*%[([^%]]+)%]")
    if dest2 and mem then
      destinationRegister = dest2
      -- Extract base and offset from memory
      local base, offset = mem:match("([^%+%-]+)%+([^%+%-]+)")
      if base and offset then
        memoryBase = base
        memoryOffset = offset
      else
        memoryBase = mem
      end
    end

    -- Pattern 3: instruction [mem],src - Register to Memory
    local mem2, src2 = originalInstruction:match("^%w+%s+[^%[]*%[([^%]]+)%],([^%s,]+)")
    if mem2 and src2 then
      sourceRegister = src2
      -- Extract base and offset from memory
      local base, offset = mem2:match("([^%+%-]+)%+([^%+%-]+)")
      if base and offset then
        memoryBase = base
        memoryOffset = offset
      else
        memoryBase = mem2
      end
    end
  end
end

function getAppropriateRegister(instruction, context, position)

  -- For Pattern A and B: mov/movss [%s+%s],(type)value - position 1 is memory base, position 2 is offset
  if context == "memory" and position == 1 then
    if memoryBase ~= "" then
      return memoryBase
    end
  end

  if context == "offset" and position == 2 then
    if memoryOffset ~= "" then
      return memoryOffset
    end
  end

  -- For Pattern C: mov/movss %s,(type)value - loading value into register
  if context == "destination" then
    if destinationRegister ~= "" then
      return destinationRegister
    end
    if sourceRegister ~= "" then
      return sourceRegister
    end
  end

  -- For Pattern E: mov %s,[setValue] - loading value FROM memory TO register
  if context == "load" then
    if destinationRegister ~= "" then
      return destinationRegister
    end
    if sourceRegister ~= "" then
      return sourceRegister
    end
  end

  -- For Pattern F: mov [seeValue],%s - storing value FROM register TO memory
  if context == "see" then
    if memoryBase ~= "" then
      return memoryBase
    end
    if sourceRegister ~= "" then
      return sourceRegister
    end
    if destinationRegister ~= "" then
      return destinationRegister
    end
  end

  -- For single memory reference patterns like mov [%s],(int)1
  if context == "single_memory" then
    if memoryBase ~= "" then
      return memoryBase
    end
  end

  -- Default fallback based on instruction type
  if instruction:match("movss") or instruction:match("movsd") or instruction:match("addss") or instruction:match("subss") or instruction:match("mulss") or instruction:match("divss") then
    if #detectedXMMRegs &gt; 0 then
      return detectedXMMRegs[1]
    end
  end

  if #detectedGPRegs &gt; 0 then
    return detectedGPRegs[1]
  end

  if #detectedXMMRegs &gt; 0 then
    return detectedXMMRegs[1]
  end

  return "rax"
end

function processAssemblyLine(line)

  -- Trim whitespace
  line = line:gsub("^%s*(.-)%s*$", "%1")

  if not line:find("%%s") then
    return line
  end

  -- Extract instruction name
  local instruction = line:match("^(%w+)")
  if not instruction then
    instruction = "mov"
  end

  -- Pattern A: mov [%s+%s],(type)value
  if line:match("^%w+%s+%[%%s%+%%s%],%(" ) then
    local prefix, middle, suffix = line:match("^(%w+%s+%[)%%s(%+)%%s(%],.*)$")
    if prefix and middle and suffix then
      local reg1 = getAppropriateRegister(instruction, "memory", 1)
      local reg2 = getAppropriateRegister(instruction, "offset", 2)
      local result = prefix .. reg1 .. middle .. reg2 .. suffix
      return result
    end
  end

  -- Pattern B: movss [%s+%s],(type)value
  if line:match("^movs[sd]%s+%[%%s%+%%s%],%(" ) then
    local inst, prefix, middle, suffix = line:match("^(movs[sd])(%s+%[)%%s(%+)%%s(%],.*)$")
    if inst and prefix and middle and suffix then
      local reg1 = getAppropriateRegister(inst, "memory", 1)
      local reg2 = getAppropriateRegister(inst, "offset", 2)
      local result = inst .. prefix .. reg1 .. middle .. reg2 .. suffix
      return result
    end
  end

  -- Pattern C: mov %s,(type)value
  if line:match("^%w+%s+%%s,%(" ) then
    local prefix, suffix = line:match("^(%w+%s+)%%s(.*)$")
    if prefix and suffix then
      local reg = getAppropriateRegister(instruction, "destination", 1)
      local result = prefix .. reg .. suffix
      return result
    end
  end

  -- Pattern D: mov [%s+%s],register (without parentheses)
  if line:match("^%w+%s+%[%%s%+%%s%]," ) and not line:match("%(" ) then
    local prefix, middle, suffix = line:match("^(%w+%s+%[)%%s(%+)%%s(%],.*)$")
    if prefix and middle and suffix then
      local reg1 = getAppropriateRegister(instruction, "memory", 1)
      local reg2 = getAppropriateRegister(instruction, "offset", 2)
      local result = prefix .. reg1 .. middle .. reg2 .. suffix
      return result
    end
  end

  -- Pattern E: mov %s,[setValue]
  if line:match("^%w+%s+%%s,%[" ) then
    local reg = getAppropriateRegister(instruction, "load", 1)
    local result = line:gsub("%%s", reg)
    return result
  end

  -- Pattern F: mov [seeValue],%s
  if line:match("^%w+%s+%[[^%]]*%],%%s" ) then
    local reg = getAppropriateRegister(instruction, "see", 1)
    local result = line:gsub("%%s", reg)
    return result
  end

  -- Pattern G: mov [%s],(type)value - single memory reference
  if line:match("^%w+%s+%[%%s%],%(" ) then
    local reg = getAppropriateRegister(instruction, "single_memory", 1)
    local result = line:gsub("%%s", reg)
    return result
  end

  -- Pattern H: mov [%s],register - single memory reference without parentheses
  if line:match("^%w+%s+%[%%s%]," ) and not line:match("%(" ) then
    local reg = getAppropriateRegister(instruction, "single_memory", 1)
    local result = line:gsub("%%s", reg)
    return result
  end

  -- Generic %s replacement
  local reg = getAppropriateRegister(instruction, "destination", 1)
  return line:gsub("%%s", reg)
end

-- Register the symbol with wildcard and exact patterns
aob_register("GemsOnpickUpB", "48 63 80 F4 01 00 00 85 C0 7D 19 48 B9 30 9C A5 29 FC 01 00 00 66 90 49 BB EB 31 EB B3 FB 01 00 00 41 FF D3", "48 ?? ?? ?? ?? ?? ?? 85 ?? 7D ?? 48 ?? ?? ?? ?? ?? ?? ?? ?? ?? 66 ?? 49 ?? ?? ?? ?? ?? ?? ?? ?? ?? 41 ?? ??")

-- Get address and instruction length
local expAddr = getAddress("GemsOnpickUpB")
local instrLength = getInstructionLength(expAddr)

-- Analyze the original code to detect registers and offsets
analyzeOriginalCode(expAddr, instrLength)

-- Define the newmem content with processing
local newmemContent = [[


]]

-- Process each line in newmem content
local lines = {}
for line in newmemContent:gmatch("([^\r\n]*)") do
  if line and line ~= "" then
    local processedLine = processAssemblyLine(line)
    if processedLine and processedLine ~= "" then
      table.insert(lines, "  " .. processedLine)
    end
  end
end

local processedNewmem = table.concat(lines, "\n")

-- Generate assembly code with detected length
return [[
alloc(newmem,$1000,GemsOnpickUpB)
alloc(GemsOnpickUpBCopy,30)
registersymbol(GemsOnpickUpBCopy)

GemsOnpickUpBCopy:
  readmem(GemsOnpickUpB,30)

label(code)
label(return)


newmem:
]] .. processedNewmem .. [[

code:
  readmem(GemsOnpickUpB,]] .. instrLength .. [[)
  jmp return



GemsOnpickUpB:
  jmp newmem
  db 90 90
return:
]]

