              <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

-- Check if Script 1 is active
if not _G.unlimitedExtraMoveSpeedZaTimer then
  error("Script 1 (Primary Array) must be activated first!")
end

function aob_register(sym, patterns)
    if type(patterns) == "string" then
        patterns = {patterns}
    end

    local lastError = ""
    for _, pat in ipairs(patterns) do
        local instr = AOBScan(pat, "+X")
        if instr and instr.Count &gt; 0 then
            local addy = instr[0]
            instr.destroy()
            unregisterSymbol(sym)
            registerSymbol(sym, tonumber(addy,16))
            return true
        else
            if instr then instr.destroy() end
            lastError = lastError .. "Pattern not found: " .. pat .. "\n"
        end
    end

    error('No patterns found!\n' .. lastError)
end

aob_register("BodySizeWhenFallDownInHoleA", {"F3 0F 59 B0 70"
, "F3 0F ?? ?? ?? 02 00 00 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 00 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 00 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 00 00 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 48 8B"
, "F3 0F ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 48 8B ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 72 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 0F ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 48"
, "F3 ?? ?? ?? ?? ?? ?? ?? 33 ?? 48 8B ?? F3 ?? ?? ?? ?? ?? ?? ?? E8 ?? ?? ?? ?? 48 85 ?? 0F 84 ?? ?? ?? ?? F3"
, "F3 ?? ?? ?? ?? ?? ?? ?? 33 ?? 48 ?? ?? F3 ?? ?? ?? ?? ?? ?? ?? E8 ?? ?? ?? ?? 48 ?? ?? 0F ?? ?? ?? ?? ?? F3 ?? ?? ?? ?? ?? ?? ?? 0F ?? ?? ?? ?? ?? ?? 76 ??"})
{$asm}

alloc(BodySizeWhenFallDownInHoleACopy,30)
registersymbol(BodySizeWhenFallDownInHoleACopy)
alloc(seeBodySizeWhenFallDownInHoleAStatus,8)
registersymbol(seeBodySizeWhenFallDownInHoleAStatus)
seeBodySizeWhenFallDownInHoleAStatus:
dq 0

BodySizeWhenFallDownInHoleACopy:
  readmem(BodySizeWhenFallDownInHoleA,30)

{$lua}
-- Register list (same as Script 1)
local ExtraMoveSpeedZaRegs = { "rax", "rbx", "rcx", "rdx", "rsi", "rdi",  "r8",  "r9",  "r10",  "r11",  "r12",  "r13",  "r14",  "r15", "rbp",  "rsp"  }

-- Store references
_G.BodySizeWhenFallDownInHoleAAddressEntry = nil
_G.BodySizeWhenFallDownInHoleAOriginalStaticAddress = nil
_G.LastBodySizeWhenFallDownInHoleAInjectionCheck = 0

local function findOrCreateBodySizeWhenFallDownInHoleAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setBodySizeWhenFallDownInHoleAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addBodySizeWhenFallDownInHoleAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subBodySizeWhenFallDownInHoleAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.BodySizeWhenFallDownInHoleAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "BodySizeWhenFallDownInHoleA Value (See)"
  entry.Type = vtSingle
  entry.Address = valueSymbolName
  _G.BodySizeWhenFallDownInHoleAValueAddressEntry = entry
  return entry
end

local function scanForBodySizeWhenFallDownInHoleAOffset(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(ExtraMoveSpeedZaRegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return tonumber(hexOffset,16) end
        for _, reg2 in ipairs(ExtraMoveSpeedZaRegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              return tonumber(hexOffset2,16)
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return 0
end

local function BodySizeWhenFallDownInHoleAArrayMonitor()
  -- Check if Script 1 is still active
  if not _G.unlimitedExtraMoveSpeedZaTimer then
   -- print("Warning: Script 1 is no longer active!")
    return
  end

  local BodySizeWhenFallDownInHoleAInjectionAddr = getAddressSafe("BodySizeWhenFallDownInHoleACopy")
  if not BodySizeWhenFallDownInHoleAInjectionAddr then return end

  -- Check if BodySizeWhenFallDownInHoleA array has been executed recently (event occurred)
  local currentBodySizeWhenFallDownInHoleACheck = readInteger(BodySizeWhenFallDownInHoleAInjectionAddr)

  -- If BodySizeWhenFallDownInHoleA array was executed (new event), update cached offset
  if currentBodySizeWhenFallDownInHoleACheck ~= _G.LastBodySizeWhenFallDownInHoleAInjectionCheck then
    local foundBodySizeWhenFallDownInHoleAOffset = scanForBodySizeWhenFallDownInHoleAOffset(BodySizeWhenFallDownInHoleAInjectionAddr, 8)
    if foundBodySizeWhenFallDownInHoleAOffset and foundBodySizeWhenFallDownInHoleAOffset ~= 0 then
      _G.CachedBodySizeWhenFallDownInHoleAOffset = foundBodySizeWhenFallDownInHoleAOffset
      --print(string.format("BodySizeWhenFallDownInHoleA offset found and cached: 0x%X", foundBodySizeWhenFallDownInHoleAOffset))
    --  print("Script 1 will now handle BodySizeWhenFallDownInHoleA value using See operation with this offset!")

      -- Store the original static address for cleanup
      if not _G.BodySizeWhenFallDownInHoleAOriginalStaticAddress then
        _G.BodySizeWhenFallDownInHoleAOriginalStaticAddress = getAddressSafe("seeBodySizeWhenFallDownInHoleAStatus")
      end
    end
    _G.LastBodySizeWhenFallDownInHoleAInjectionCheck = currentBodySizeWhenFallDownInHoleACheck
  end
end

-- Cleanup any existing secondary timer first
if _G.BodySizeWhenFallDownInHoleAArrayTimer and _G.BodySizeWhenFallDownInHoleAArrayTimer.destroy then
  _G.BodySizeWhenFallDownInHoleAArrayTimer.destroy()
  _G.BodySizeWhenFallDownInHoleAArrayTimer = nil
end

-- Reset variables
_G.BodySizeWhenFallDownInHoleAAddressEntry = nil
_G.BodySizeWhenFallDownInHoleAOriginalStaticAddress = nil
_G.LastBodySizeWhenFallDownInHoleAInjectionCheck = 0

-- Create secondary monitoring timer
if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.BodySizeWhenFallDownInHoleAArrayTimer = createTimer(nil, false)
    _G.BodySizeWhenFallDownInHoleAArrayTimer.Interval = 25
    _G.BodySizeWhenFallDownInHoleAArrayTimer.OnTimer = BodySizeWhenFallDownInHoleAArrayMonitor
    _G.BodySizeWhenFallDownInHoleAArrayTimer.Enabled = true

    findOrCreateBodySizeWhenFallDownInHoleAValueEntry()

    --print("Script 2 (BodySizeWhenFallDownInHoleA) is now monitoring for events...")
    --print("Values will be handled by Script 1 using See operation when offset is found.")
  end
  startupTimer.Enabled = true
end
{$asm}

[DISABLE]

{$lua}
-- Stop and destroy secondary timer
if _G.BodySizeWhenFallDownInHoleAArrayTimer and _G.BodySizeWhenFallDownInHoleAArrayTimer.destroy then
  _G.BodySizeWhenFallDownInHoleAArrayTimer.destroy()
  _G.BodySizeWhenFallDownInHoleAArrayTimer = nil
end

-- IMPORTANT: Reset the secondary symbol to its original static address
if _G.BodySizeWhenFallDownInHoleAOriginalStaticAddress then
  unregisterSymbol("seeBodySizeWhenFallDownInHoleAStatus")
  registerSymbol("seeBodySizeWhenFallDownInHoleAStatus", _G.BodySizeWhenFallDownInHoleAOriginalStaticAddress)

  -- Find and force refresh any existing secondary entry
  local addrList = getAddressList()
  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeBodySizeWhenFallDownInHoleAStatus" then
      -- Force refresh the entry to use the static address
      entry.Address = string.format("0x%X", _G.BodySizeWhenFallDownInHoleAOriginalStaticAddress)
      sleep(1)
      entry.Address = "seeBodySizeWhenFallDownInHoleAStatus"
      break
    end
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeBodySizeWhenFallDownInHoleAStatus")
  if allocatedAddr then
    unregisterSymbol("seeBodySizeWhenFallDownInHoleAStatus")
    registerSymbol("seeBodySizeWhenFallDownInHoleAStatus", allocatedAddr)

  -- Force refresh any existing entry
  local addrList = getAddressList()
  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeBodySizeWhenFallDownInHoleAStatus" then
      entry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      entry.Address = "seeBodySizeWhenFallDownInHoleAStatus"
      break
    end
  end
  end
end

-- Don't remove value entry from address list to keep it visible
if _G.BodySizeWhenFallDownInHoleAValueAddressEntry then
  _G.BodySizeWhenFallDownInHoleAValueAddressEntry = nil
end

-- Reset secondary variables
_G.BodySizeWhenFallDownInHoleAAddressEntry = nil
_G.BodySizeWhenFallDownInHoleAOriginalStaticAddress = nil
_G.LastBodySizeWhenFallDownInHoleAInjectionCheck = 0
_G.lastBodySizeWhenFallDownInHoleAValue = nil

-- Clear the cached offset so Script 1 stops handling secondary values
_G.CachedBodySizeWhenFallDownInHoleAOffset = nil

--print("Script 2 (BodySizeWhenFallDownInHoleA) disabled. Secondary pointer reset to static address.")
{$asm}

