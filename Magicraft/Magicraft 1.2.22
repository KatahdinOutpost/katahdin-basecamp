-- Fixed: Banners can now be dragged from anywhere when unlocked
-- Allows creating customizable banners in the Main Menu with true transparency

-- Configuration variables
local banners = {}
local selectedBanner = nil
local isDragging = false
local isResizing = false
local dragStartX, dragStartY = 0, 0
local originalX, originalY = 0, 0
local managerFormInstance = nil
local mainForm = nil
local originalMainFormWidth = 0
local originalMainFormHeight = 0
local bannerLocked = false
local positionTimer = nil -- Timer for tracking window position

-- Helper function to get mouse position in a compatible way
function getMousePosition()
    local success, x, y = pcall(function()
        return getMousePos()
    end)

    if success then
        if type(x) == "table" then
            return x.x or x[1], x.y or x[2]
        else
            return x, y
        end
    else
        return 100, 100
    end
end

-- Alternative shellExecute function if not available
if not shellExecute then
    function shellExecute(url)
        if openURL then
            openURL(url)
        else
            executeCodeLocal('shellExecute("' .. url .. '")')
        end
    end
end

-- Function to save configuration in a CE script
function saveBannerConfig()
    -- Create or retrieve the configuration script
    local addressList = getAddressList()
    local scriptRecord = addressList.getMemoryRecordByDescription('BannerTool_Config')

    if not scriptRecord then
        scriptRecord = addressList.createMemoryRecord()
        scriptRecord.Description = 'BannerTool_Config'
        scriptRecord.Type = vtAutoAssembler
    end

    -- Prepare configuration data
    local configScript = "// Banner Tool Configuration Script\n"
    configScript = configScript .. "// This script contains the banner configuration data\n\n"
    configScript = configScript .. "{$lua}\n"
    configScript = configScript .. "if not bannerConfig then\n"
    configScript = configScript .. "  bannerConfig = {}\n"
    configScript = configScript .. "end\n\n"
    configScript = configScript .. "bannerConfig.bannerLocked = " .. tostring(bannerLocked) .. "\n"
    configScript = configScript .. "bannerConfig.banners = {\n"

    for i, banner in ipairs(banners) do
        -- Save relative positions instead of absolute ones
        local relX = (banner.form.Left - mainForm.Left) / mainForm.Width
        local relY = (banner.form.Top - mainForm.Top) / mainForm.Height
        local relWidth = banner.form.Width / mainForm.Width
        local relHeight = banner.form.Height / mainForm.Height

        configScript = configScript .. "  {\n"
        configScript = configScript .. "    relX = " .. tostring(relX) .. ",\n"
        configScript = configScript .. "    relY = " .. tostring(relY) .. ",\n"
        configScript = configScript .. "    relWidth = " .. tostring(relWidth) .. ",\n"
        configScript = configScript .. "    relHeight = " .. tostring(relHeight) .. ",\n"
        configScript = configScript .. "    contentType = [[" .. tostring(banner.contentType) .. "]],\n"
        configScript = configScript .. "    content = [[" .. tostring(banner.content):gsub("\\", "\\\\") .. "]],\n"
        configScript = configScript .. "    bgColor = " .. tostring(banner.bgColor) .. ",\n"
        configScript = configScript .. "    textColor = " .. tostring(banner.textColor) .. ",\n"
        configScript = configScript .. "    fontSize = " .. tostring(banner.fontSize) .. ",\n"
        configScript = configScript .. "    textAlignment = [[" .. tostring(banner.textAlignment) .. "]],\n"
        configScript = configScript .. "    bgAlpha = " .. tostring(banner.bgAlpha or 255) .. ",\n"
        configScript = configScript .. "    locked = " .. tostring(banner.locked) .. "\n"
        configScript = configScript .. "  }"

        if i &lt; #banners then
            configScript = configScript .. ",\n"
        else
            configScript = configScript .. "\n"
        end
    end

    configScript = configScript .. "}\n"
    configScript = configScript .. "{$asm}\n\n"
    configScript = configScript .. "// End of Banner Tool Configuration"

    -- Save the script
    scriptRecord.Script = configScript

    -- Execute the script to initialize the configuration
    scriptRecord.Active = false
    scriptRecord.Active = true
end

-- Function to load configuration from the CE script
function loadBannerConfig()
    local addressList = getAddressList()
    local scriptRecord = addressList.getMemoryRecordByDescription('BannerTool_Config')

    if not scriptRecord then
        return {}
    end

    -- Execute the script to load the configuration
    if not scriptRecord.Active then
        scriptRecord.Active = true
    end

    -- Return the configuration if it exists
    if bannerConfig then
        return bannerConfig
    end

    return {}
end

-- Function to update the resize grip position
function updateResizeGripPosition(banner)
    if banner and banner.resizeGrip and banner.panel then
        banner.resizeGrip.Left = banner.panel.Width - 15
        banner.resizeGrip.Top = banner.panel.Height - 15
        banner.resizeGrip.Visible = not (banner.locked or bannerLocked)
    end
end

-- Function to update banner position and size based on window resizing/moving
function updateBannersPosition()
    if not mainForm then return end

    for _, banner in ipairs(banners) do
        if banner.relativeX and banner.relativeY then
            banner.form.Left = mainForm.Left + (banner.relativeX * mainForm.Width)
            banner.form.Top = mainForm.Top + (banner.relativeY * mainForm.Height)
        end

        if banner.relativeWidth and banner.relativeHeight then
            banner.form.Width = banner.relativeWidth * mainForm.Width
            banner.form.Height = banner.relativeHeight * mainForm.Height
            banner.panel.Width = banner.form.Width
            banner.panel.Height = banner.form.Height

            banner.label.Width = banner.panel.Width - 10
            banner.label.Height = banner.panel.Height - 20
            banner.textbox.Width = banner.panel.Width - 10
            banner.textbox.Height = banner.panel.Height - 20
            banner.image.Width = banner.panel.Width - 10
            banner.image.Height = banner.panel.Height - 20

            updateResizeGripPosition(banner)
        end
    end
end

-- Function to enable/disable dragging and resizing
function toggleBannerLock()
    bannerLocked = not bannerLocked

    for _, banner in ipairs(banners) do
        banner.locked = bannerLocked
        updateResizeGripPosition(banner)

        if bannerLocked then
            banner.panel.Cursor = -2
            banner.resizeGrip.Cursor = -2
        else
            banner.panel.Cursor = -21
            banner.resizeGrip.Cursor = -8
        end
    end

    saveBannerConfig()
    return bannerLocked
end

-- Function to apply text alignment
function applyTextAlignment(label, alignment)
    if alignment == "taLeftJustify" or alignment == "taLeft" then
        label.Alignment = "taLeftJustify"
        label.Layout = "tlTop"
        label.Align = alNone
        label.Left = 5
        label.Top = 5
    elseif alignment == "taRight" or alignment == "taRightJustify" then
        label.Alignment = "taRightJustify"
        label.Layout = "tlTop"
        label.Align = alNone
        label.Left = 5
        label.Top = 5
    else -- taCenter
        label.Alignment = "taCenter"
        label.Layout = "tlCenter"
        label.Align = alNone
        label.Left = 5
        label.Top = 5

        local parent = label.Parent
        if parent then
            label.Top = (parent.Height - label.Height) / 2
        end
    end
end

-- Function to handle mouse down on any banner component
function handleBannerMouseDown(banner, button, x, y)
    if button == mbLeft and not bannerLocked and not banner.locked then
        selectedBanner = banner
        isDragging = true
        local mx, my = getMousePosition()
        dragStartX = mx or 0
        dragStartY = my or 0
        originalX = banner.form.Left
        originalY = banner.form.Top
        banner.form.BringToFront()
    elseif button == mbRight then
        showBannerMenu(banner)
    end
end

-- Function to handle mouse move on any banner component
function handleBannerMouseMove(banner, shift, x, y)
    if isDragging and selectedBanner == banner and not bannerLocked and not banner.locked then
        local mx, my = getMousePosition()
        if mx and my then
            local deltaX = mx - dragStartX
            local deltaY = my - dragStartY
            banner.form.Left = originalX + deltaX
            banner.form.Top = originalY + deltaY

            banner.relativeX = (banner.form.Left - mainForm.Left) / mainForm.Width
            banner.relativeY = (banner.form.Top - mainForm.Top) / mainForm.Height
        end
    end
end

-- Function to handle mouse up on any banner component
function handleBannerMouseUp(banner, button, x, y)
    if button == mbLeft then
        if isDragging then
            isDragging = false
            saveBannerConfig()
        end
    end
end

-- Banner Class
function createBanner(parent, x, y, width, height)
    local banner = {}
    banner.locked = bannerLocked

    -- Create a transparent form for the banner
    banner.form = createForm(false)
    banner.form.Width = width or 300
    banner.form.Height = height or 150
    banner.form.Position = "poDesigned"
    banner.form.BorderStyle = "bsNone"
    banner.form.Caption = "Banner"
    banner.form.FormStyle = "fsStayOnTop"
    banner.form.ShowInTaskBar = "stNever"

    -- Set position relative to main form
    banner.form.Left = (x or 50) + parent.Left
    banner.form.Top = (y or 50) + parent.Top

    -- Enable transparency
    banner.bgAlpha = 255 -- Default to fully opaque
    banner.form.AlphaBlend = true
    banner.form.AlphaBlendValue = banner.bgAlpha

    -- Create the main banner panel
    banner.panel = createPanel(banner.form)
    banner.panel.Left = 0
    banner.panel.Top = 0
    banner.panel.Width = banner.form.Width
    banner.panel.Height = banner.form.Height
    banner.panel.BevelOuter = "bvRaised"
    banner.panel.BorderStyle = "bsSingle"
    banner.panel.Color = 0xFFFFFF
    banner.panel.DragMode = "dmAutomatic"

    -- Save relative positions
    banner.relativeX = (banner.form.Left - parent.Left) / parent.Width
    banner.relativeY = (banner.form.Top - parent.Top) / parent.Height
    banner.relativeWidth = banner.form.Width / parent.Width
    banner.relativeHeight = banner.form.Height / parent.Height

    -- Content variables
    banner.contentType = "text"
    banner.content = "Select 'Banner Tool' then 'Manage banners...'"
    banner.bgColor = 0xFFFFFF
    banner.textColor = 0x000000
    banner.fontSize = 12
    banner.textAlignment = "taCenter"

    -- Create resize grip
    banner.resizeGrip = createPanel(banner.panel)
    banner.resizeGrip.Width = 15
    banner.resizeGrip.Height = 15
    banner.resizeGrip.Left = banner.panel.Width - 15
    banner.resizeGrip.Top = banner.panel.Height - 15
    banner.resizeGrip.Color = 0x808080
    banner.resizeGrip.Cursor = -8
    banner.resizeGrip.Visible = not bannerLocked

    -- Textbox for text input
    banner.textbox = createEdit(banner.panel)
    banner.textbox.Left = 5
    banner.textbox.Top = 5
    banner.textbox.Width = banner.panel.Width - 10
    banner.textbox.Height = banner.panel.Height - 20
    banner.textbox.Text = banner.content
    banner.textbox.Font.Size = banner.fontSize
    banner.textbox.Font.Color = banner.textColor
    banner.textbox.Color = banner.bgColor
    banner.textbox.Visible = false
    banner.textbox.Multiline = true
    banner.textbox.ScrollBars = "ssVertical"

    -- Label for display (non-editable)
    banner.label = createLabel(banner.panel)
    banner.label.Left = 5
    banner.label.Top = 5
    banner.label.Width = banner.panel.Width - 10
    banner.label.Height = banner.panel.Height - 10
    banner.label.Caption = banner.content
    banner.label.Font.Size = banner.fontSize
    banner.label.Font.Color = banner.textColor
    banner.label.WordWrap = true
    banner.label.AutoSize = false
    banner.label.Visible = true

    -- Apply initial alignment
    applyTextAlignment(banner.label, banner.textAlignment)

    -- Image for images
    banner.image = createImage(banner.panel)
    banner.image.Left = 5
    banner.image.Top = 5
    banner.image.Width = banner.panel.Width - 10
    banner.image.Height = banner.panel.Height - 20
    banner.image.Stretch = true
    banner.image.Visible = false

    -- Function to update content
    function banner:updateContent()
        if self.contentType == "text" then
            self.label.Visible = true
            self.textbox.Visible = false
            self.image.Visible = false
            self.label.Caption = self.content
            self.label.Font.Color = self.textColor
            self.label.Font.Size = self.fontSize
            self.label.Font.Style = ""

            self.label.Width = self.panel.Width - 10
            self.label.Height = self.panel.Height - 10

            applyTextAlignment(self.label, self.textAlignment)

            self.label.Cursor = -2
        elseif self.contentType == "image" then
            self.label.Visible = false
            self.textbox.Visible = false
            self.image.Visible = true
            if self.content and self.content ~= "" then
                pcall(function()
                    self.image.Picture.loadFromFile(self.content)
                end)
            end
        elseif self.contentType == "link" then
            self.label.Visible = true
            self.textbox.Visible = false
            self.image.Visible = false
            self.label.Caption = "🔗 " .. self.content
            self.label.Font.Color = 0x0000FF
            self.label.Font.Style = "[fsUnderline]"

            self.label.Width = self.panel.Width - 10
            self.label.Height = self.panel.Height - 10

            applyTextAlignment(self.label, self.textAlignment)

            self.label.Cursor = -21
        elseif self.contentType == "edit" then
            self.label.Visible = false
            self.textbox.Visible = true
            self.image.Visible = false
            self.textbox.Text = self.content
            self.textbox.Font.Color = self.textColor
            self.textbox.Font.Size = self.fontSize
            self.textbox.Color = self.bgColor
        end

        self.panel.Color = self.bgColor
    end

    -- EVENT HANDLERS FOR DRAGGING FROM ANYWHERE
    -- Panel events
    banner.panel.OnMouseDown = function(sender, button, x, y)
        handleBannerMouseDown(banner, button, x, y)
    end

    banner.panel.OnMouseMove = function(sender, shift, x, y)
        handleBannerMouseMove(banner, shift, x, y)
    end

    banner.panel.OnMouseUp = function(sender, button, x, y)
        handleBannerMouseUp(banner, button, x, y)
    end

    -- Label events (for dragging from text)
    banner.label.OnMouseDown = function(sender, button, x, y)
        if banner.contentType == "link" and button == mbLeft then
            -- Handle link click
            shellExecute(banner.content)
        else
            handleBannerMouseDown(banner, button, x, y)
        end
    end

    banner.label.OnMouseMove = function(sender, shift, x, y)
        handleBannerMouseMove(banner, shift, x, y)
    end

    banner.label.OnMouseUp = function(sender, button, x, y)
        handleBannerMouseUp(banner, button, x, y)
    end

    -- Image events (for dragging from images)
    banner.image.OnMouseDown = function(sender, button, x, y)
        handleBannerMouseDown(banner, button, x, y)
    end

    banner.image.OnMouseMove = function(sender, shift, x, y)
        handleBannerMouseMove(banner, shift, x, y)
    end

    banner.image.OnMouseUp = function(sender, button, x, y)
        handleBannerMouseUp(banner, button, x, y)
    end

    -- Textbox events (for dragging from editable text)
    banner.textbox.OnMouseDown = function(sender, button, x, y)
        -- Only allow dragging if not clicking to edit text
        if not banner.textbox.Focused then
            handleBannerMouseDown(banner, button, x, y)
        end
    end

    banner.textbox.OnMouseMove = function(sender, shift, x, y)
        if not banner.textbox.Focused then
            handleBannerMouseMove(banner, shift, x, y)
        end
    end

    banner.textbox.OnMouseUp = function(sender, button, x, y)
        if not banner.textbox.Focused then
            handleBannerMouseUp(banner, button, x, y)
        end
    end

    -- Resizing
    local resizeStartX, resizeStartY
    local originalWidth, originalHeight

    banner.resizeGrip.OnMouseDown = function(sender, button, x, y)
        if button == mbLeft and not bannerLocked and not banner.locked then
            isResizing = true
            selectedBanner = banner
            local mx, my = getMousePosition()
            resizeStartX = mx or 0
            resizeStartY = my or 0
            originalWidth = banner.form.Width
            originalHeight = banner.form.Height
        end
    end

    banner.resizeGrip.OnMouseMove = function(sender, shift, x, y)
        if isResizing and selectedBanner == banner and not bannerLocked and not banner.locked then
            local mx, my = getMousePosition()
            if mx and my then
                local deltaX = mx - resizeStartX
                local deltaY = my - resizeStartY

                local newWidth = math.max(55, originalWidth + deltaX)
                local newHeight = math.max(10, originalHeight + deltaY)

                banner.form.Width = newWidth
                banner.form.Height = newHeight
                banner.panel.Width = newWidth
                banner.panel.Height = newHeight
                banner.label.Width = newWidth - 10
                banner.label.Height = newHeight - 10
                banner.textbox.Width = newWidth - 10
                banner.textbox.Height = newHeight - 20
                banner.image.Width = newWidth - 10
                banner.image.Height = newHeight - 20
                updateResizeGripPosition(banner)

                applyTextAlignment(banner.label, banner.textAlignment)

                banner.relativeWidth = newWidth / mainForm.Width
                banner.relativeHeight = newHeight / mainForm.Height
            end
        end
    end

    banner.resizeGrip.OnMouseUp = function(sender, button, x, y)
        if button == mbLeft then
            if isResizing then
                isResizing = false
                saveBannerConfig()
            end
        end
    end

    -- Double click for editing
    banner.label.OnDblClick = function()
        showBannerMenu(banner)
    end

    banner.panel.OnDblClick = function()
        showBannerMenu(banner)
    end

    -- Save text when textbox loses focus
    banner.textbox.OnExit = function(sender)
        banner.content = sender.Text
        saveBannerConfig()
    end

    -- Drag &amp; drop for images
    banner.panel.OnDragOver = function(sender, source, x, y, state)
        return true
    end

    banner.panel.OnDragDrop = function(sender, source, x, y)
        if source and source.Files and source.Files.Count &gt; 0 then
            local fileName = source.Files[0]
            if fileName:lower():match("%.(png|jpg|jpeg|bmp|gif)$") then
                banner.contentType = "image"
                banner.content = fileName
                banner:updateContent()
                saveBannerConfig()
            end
        end
    end

    -- Make form visible
    banner.form.Visible = true
    banner.form.BringToFront()

    -- Initialize
    banner:updateContent()
    return banner
end

-- Context menu for banner
function showBannerMenu(banner)
    local popup = createPopupMenu(nil)
    if not popup then return end

    local menuEdit = createMenuItem(popup)
    menuEdit.Caption = "Edit content"
    menuEdit.OnClick = function() editBannerContent(banner) end

    local menuEditText = createMenuItem(popup)
    menuEditText.Caption = "Edit text directly"
    menuEditText.OnClick = function()
        local form = createForm()
        form.Caption = "Edit Text"
        form.Width = 400
        form.Height = 300
        form.Position = "poScreenCenter"
        form.BorderStyle = "bsDialog"
        form.Visible = false

        local memo = createMemo(form)
        memo.Left = 10
        memo.Top = 10
        memo.Width = 380
        memo.Height = 200
        memo.Lines.Text = banner.content
        memo.ScrollBars = "ssVertical"

        local btnOK = createButton(form)
        btnOK.Left = 220
        btnOK.Top = 220
        btnOK.Width = 75
        btnOK.Caption = "OK"
        btnOK.ModalResult = mrOK

        local btnCancel = createButton(form)
        btnCancel.Left = 305
        btnCancel.Top = 220
        btnCancel.Width = 75
        btnCancel.Caption = "Cancel"
        btnCancel.ModalResult = mrCancel

        if form.showModal() == mrOK then
            banner.content = memo.Lines.Text
            banner:updateContent()
            saveBannerConfig()
        end
        form.destroy()
    end

    local menuColor = createMenuItem(popup)
    menuColor.Caption = "Change background color"
    menuColor.OnClick = function()
        local colorDialog = createColorDialog(nil)
        colorDialog.Color = banner.bgColor
        if colorDialog.execute() then
            banner.bgColor = colorDialog.Color
            banner.panel.Color = banner.bgColor
            banner.textbox.Color = banner.bgColor
            saveBannerConfig()
        end
    end

    local menuTextColor = createMenuItem(popup)
    menuTextColor.Caption = "Change text color"
    menuTextColor.OnClick = function()
        local colorDialog = createColorDialog(nil)
        colorDialog.Color = banner.textColor
        if colorDialog.execute() then
            banner.textColor = colorDialog.Color
            banner.label.Font.Color = colorDialog.Color
            banner.textbox.Font.Color = colorDialog.Color
            saveBannerConfig()
        end
    end

    local menuFontSize = createMenuItem(popup)
    menuFontSize.Caption = "Font size"
    menuFontSize.OnClick = function()
        local form = createForm()
        form.Caption = "Font Size"
        form.Width = 300
        form.Height = 150
        form.Position = "poScreenCenter"
        form.BorderStyle = "bsDialog"
        form.Visible = false

        local trackBar = createTrackBar(form)
        trackBar.Left = 10
        trackBar.Top = 10
        trackBar.Width = 280
        trackBar.Min = 8
        trackBar.Max = 32
        trackBar.Position = banner.fontSize

        local lblSize = createLabel(form)
        lblSize.Left = 10
        lblSize.Top = 40
        lblSize.Caption = "Size: " .. trackBar.Position

        trackBar.OnChange = function()
            lblSize.Caption = "Size: " .. trackBar.Position
        end

        local btnOK = createButton(form)
        btnOK.Left = 120
        btnOK.Top = 80
        btnOK.Width = 75
        btnOK.Caption = "OK"
        btnOK.ModalResult = mrOK

        if form.showModal() == mrOK then
            banner.fontSize = trackBar.Position
            banner:updateContent()
            saveBannerConfig()
        end
        form.destroy()
    end

    local menuTextMode = createMenuItem(popup)
    menuTextMode.Caption = "Editable text mode"
    menuTextMode.OnClick = function()
        banner.contentType = "edit"
        banner:updateContent()
        saveBannerConfig()
    end

    local menuViewMode = createMenuItem(popup)
    menuViewMode.Caption = "View mode"
    menuViewMode.OnClick = function()
        banner.contentType = "text"
        banner:updateContent()
        saveBannerConfig()
    end

    local menuAlignment = createMenuItem(popup)
    menuAlignment.Caption = "Text alignment"
    menuAlignment.OnClick = function()
        local form = createForm()
        form.Caption = "Text Alignment"
        form.Width = 300
        form.Height = 150
        form.Position = "poScreenCenter"
        form.BorderStyle = "bsDialog"
        form.Visible = false

        local radioLeft = createRadioButton(form)
        radioLeft.Left = 20
        radioLeft.Top = 20
        radioLeft.Caption = "Left"
        radioLeft.Width = 100

        local radioCenter = createRadioButton(form)
        radioCenter.Left = 20
        radioCenter.Top = 50
        radioCenter.Caption = "Center"
        radioCenter.Width = 100

        local radioRight = createRadioButton(form)
        radioRight.Left = 20
        radioRight.Top = 80
        radioRight.Caption = "Right"
        radioRight.Width = 100

        if banner.textAlignment == "taLeftJustify" or banner.textAlignment == "taLeft" then
            radioLeft.Checked = true
        elseif banner.textAlignment == "taRight" or banner.textAlignment == "taRightJustify" then
            radioRight.Checked = true
        else
            radioCenter.Checked = true
        end

        local btnOK = createButton(form)
        btnOK.Left = 120
        btnOK.Top = 110
        btnOK.Width = 75
        btnOK.Caption = "OK"
        btnOK.ModalResult = mrOK

        local btnCancel = createButton(form)
        btnCancel.Left = 205
        btnCancel.Top = 110
        btnCancel.Width = 75
        btnCancel.Caption = "Cancel"
        btnCancel.ModalResult = mrCancel

        if form.showModal() == mrOK then
            if radioLeft.Checked then
                banner.textAlignment = "taLeftJustify"
            elseif radioCenter.Checked then
                banner.textAlignment = "taCenter"
            elseif radioRight.Checked then
                banner.textAlignment = "taRight"
            end
            banner:updateContent()
            saveBannerConfig()
        end
        form.destroy()
    end

    local menuLock = createMenuItem(popup)
    menuLock.Caption = banner.locked and "Unlock banner" or "Lock banner"
    menuLock.OnClick = function()
        banner.locked = not banner.locked
        updateResizeGripPosition(banner)
        saveBannerConfig()
    end

    local menuSep = createMenuItem(popup)
    menuSep.Caption = "-"

    local menuDelete = createMenuItem(popup)
    menuDelete.Caption = "Delete banner"
    menuDelete.OnClick = function()
        for i, b in ipairs(banners) do
            if b == banner then
                b.form.destroy()
                table.remove(banners, i)
                saveBannerConfig()
                break
            end
        end
    end

    popup.Items.add(menuEdit)
    popup.Items.add(menuEditText)
    popup.Items.add(menuColor)
    popup.Items.add(menuTextColor)
    popup.Items.add(menuFontSize)
    popup.Items.add(menuTextMode)
    popup.Items.add(menuViewMode)
    popup.Items.add(menuAlignment)
    popup.Items.add(menuLock)
    popup.Items.add(menuSep)
    popup.Items.add(menuDelete)

    local mx, my = getMousePosition()

    if popup.Popup then
        popup.Popup(mx, my)
    elseif popup.doPopup then
        popup.doPopup(mx, my)
    else
        local form = createForm()
        form.Visible = false
        form.PopupMenu = popup
        form.Left = mx
        form.Top = my
        form.Width = 1
        form.Height = 1
        form.Visible = true

        local timer = createTimer()
        timer.Interval = 100
        timer.OnTimer = function(t)
            t.destroy()
            form.destroy()
        end
    end
end

-- Dialog to edit banner content
function editBannerContent(banner)
    local form = createForm()
    form.Caption = "Edit Banner"
    form.Width = 450
    form.Height = 550
    form.Position = "poScreenCenter"
    form.BorderStyle = "bsDialog"
    form.Visible = false

    local lblType = createLabel(form)
    lblType.Left = 20
    lblType.Top = 20
    lblType.Caption = "Content type:"

    local comboType = createComboBox(form)
    comboType.Left = 20
    comboType.Top = 40
    comboType.Width = 200
    comboType.Items.add("Text")
    comboType.Items.add("Image")
    comboType.Items.add("Link")
    comboType.Items.add("Editable Text")

    if banner.contentType == "text" then
        comboType.ItemIndex = 0
    elseif banner.contentType == "image" then
        comboType.ItemIndex = 1
    elseif banner.contentType == "link" then
        comboType.ItemIndex = 2
    elseif banner.contentType == "edit" then
        comboType.ItemIndex = 3
    else
        comboType.ItemIndex = 0
    end

    local lblContent = createLabel(form)
    lblContent.Left = 20
    lblContent.Top = 80
    lblContent.Caption = "Content:"

    local editContent = createMemo(form)
    editContent.Left = 20
    editContent.Top = 100
    editContent.Width = 400
    editContent.Height = 100
    editContent.Lines.Text = banner.content
    editContent.ScrollBars = "ssVertical"

    local btnBrowse = createButton(form)
    btnBrowse.Left = 330
    btnBrowse.Top = 205
    btnBrowse.Width = 90
    btnBrowse.Caption = "Browse..."
    btnBrowse.OnClick = function()
        local openDialog = createOpenDialog(form)
        openDialog.Filter = "Images|*.png;*.jpg;*.jpeg;*.bmp;*.gif|All files|*.*"
        if openDialog.execute() then
            editContent.Lines.Text = openDialog.FileName
        end
    end

    local lblFontSize = createLabel(form)
    lblFontSize.Left = 20
    lblFontSize.Top = 220
    lblFontSize.Caption = "Font size:"

    local editFontSize = createEdit(form)
    editFontSize.Left = 20
    editFontSize.Top = 240
    editFontSize.Width = 80
    editFontSize.Text = tostring(banner.fontSize)

    local textColorPreview = createPanel(form)
    textColorPreview.Left = 215
    textColorPreview.Top = 240
    textColorPreview.Width = 20
    textColorPreview.Height = 20
    textColorPreview.Color = banner.textColor

    local bgColorPreview = createPanel(form)
    bgColorPreview.Left = 345
    bgColorPreview.Top = 240
    bgColorPreview.Width = 20
    bgColorPreview.Height = 20
    bgColorPreview.Color = banner.bgColor

    local lblTextColor = createLabel(form)
    lblTextColor.Left = 120
    lblTextColor.Top = 220
    lblTextColor.Caption = "Text color:"

    local btnTextColor = createButton(form)
    btnTextColor.Left = 120
    btnTextColor.Top = 240
    btnTextColor.Width = 90
    btnTextColor.Caption = "Choose..."
    btnTextColor.OnClick = function()
        local colorDialog = createColorDialog(form)
        colorDialog.Color = banner.textColor
        if colorDialog.execute() then
            banner.textColor = colorDialog.Color
            textColorPreview.Color = banner.textColor
        end
    end

    local lblBgColor = createLabel(form)
    lblBgColor.Left = 250
    lblBgColor.Top = 220
    lblBgColor.Caption = "Background color:"

    local btnBgColor = createButton(form)
    btnBgColor.Left = 250
    btnBgColor.Top = 240
    btnBgColor.Width = 90
    btnBgColor.Caption = "Choose..."
    btnBgColor.OnClick = function()
        local colorDialog = createColorDialog(form)
        colorDialog.Color = banner.bgColor
        if colorDialog.execute() then
            banner.bgColor = colorDialog.Color
            bgColorPreview.Color = banner.bgColor
        end
    end

    local lblAlignment = createLabel(form)
    lblAlignment.Left = 20
    lblAlignment.Top = 270
    lblAlignment.Caption = "Text alignment:"

    local comboAlignment = createComboBox(form)
    comboAlignment.Left = 20
    comboAlignment.Top = 290
    comboAlignment.Width = 150
    comboAlignment.Items.add("Left")
    comboAlignment.Items.add("Center")
    comboAlignment.Items.add("Right")

    if banner.textAlignment == "taLeftJustify" then
        comboAlignment.ItemIndex = 0
    elseif banner.textAlignment == "taRight" then
        comboAlignment.ItemIndex = 2
    else
        comboAlignment.ItemIndex = 1
    end

    -- TRANSPARENCY SLIDER SECTION
    local lblTransparency = createLabel(form)
    lblTransparency.Left = 20
    lblTransparency.Top = 330
    lblTransparency.Caption = "Background Transparency:"

    local alphaSlider = createTrackBar(form)
    alphaSlider.Left = 20
    alphaSlider.Top = 350
    alphaSlider.Width = 350
    alphaSlider.Height = 30
    alphaSlider.Min = 50
    alphaSlider.Max = 255
    alphaSlider.Position = banner.bgAlpha or 255
    alphaSlider.TickStyle = "tsAuto"
    alphaSlider.Frequency = 25

    local lblAlphaValue = createLabel(form)
    lblAlphaValue.Left = 380
    lblAlphaValue.Top = 355
    lblAlphaValue.Caption = tostring(alphaSlider.Position)
    lblAlphaValue.Width = 40

    alphaSlider.OnChange = function()
        lblAlphaValue.Caption = tostring(alphaSlider.Position)
        banner.form.AlphaBlendValue = alphaSlider.Position
    end

    local btnOK = createButton(form)
    btnOK.Left = 280
    btnOK.Top = 400
    btnOK.Width = 75
    btnOK.Caption = "OK"
    btnOK.ModalResult = mrOK

    local btnCancel = createButton(form)
    btnCancel.Left = 365
    btnCancel.Top = 400
    btnCancel.Width = 75
    btnCancel.Caption = "Cancel"
    btnCancel.ModalResult = mrCancel

    if form.showModal() == mrOK then
        local selectedType = comboType.ItemIndex
        if selectedType == 0 then
            banner.contentType = "text"
        elseif selectedType == 1 then
            banner.contentType = "image"
        elseif selectedType == 2 then
            banner.contentType = "link"
        elseif selectedType == 3 then
            banner.contentType = "edit"
        end

        banner.content = editContent.Lines.Text
        banner.fontSize = tonumber(editFontSize.Text) or banner.fontSize
        banner.bgAlpha = alphaSlider.Position
        banner.form.AlphaBlendValue = banner.bgAlpha

        local alignmentIndex = comboAlignment.ItemIndex
        if alignmentIndex == 0 then
            banner.textAlignment = "taLeftJustify"
        elseif alignmentIndex == 1 then
            banner.textAlignment = "taCenter"
        elseif alignmentIndex == 2 then
            banner.textAlignment = "taRight"
        end

        banner:updateContent()
        saveBannerConfig()
    else
        banner.form.AlphaBlendValue = banner.bgAlpha
    end

    form.destroy()
end

-- Create banner management form
function createBannerManager()
    if managerFormInstance and not managerFormInstance.isDestroyed then
        managerFormInstance.bringToFront()
        return
    end

    managerFormInstance = createForm()
    managerFormInstance.Caption = "Banner Manager"
    managerFormInstance.Width = 500
    managerFormInstance.Height = 400
    managerFormInstance.Position = "poScreenCenter"
    managerFormInstance.BorderStyle = "bsDialog"
    managerFormInstance.Visible = false

    local listBox = createListBox(managerFormInstance)
    listBox.Left = 10
    listBox.Top = 10
    listBox.Width = 300
    listBox.Height = 300

    local function updateList()
        listBox.clear()
        for i, banner in ipairs(banners) do
            local lockedStatus = banner.locked and "🔒" or "🔓"
            local alphaText = banner.bgAlpha and (" [α:" .. banner.bgAlpha .. "]") or ""
            local desc = string.format("%s Banner %d - %s (%dx%d)%s",
                lockedStatus, i, banner.contentType,
                banner.form.Width, banner.form.Height, alphaText)
            listBox.Items.add(desc)
        end
    end

    local btnAdd = createButton(managerFormInstance)
    btnAdd.Left = 320
    btnAdd.Top = 10
    btnAdd.Width = 160
    btnAdd.Caption = "Add Banner"
    btnAdd.OnClick = function()
        local banner = createBanner(mainForm, math.random(50, 300), math.random(50, 300), 300, 150)
        banner.locked = bannerLocked
        updateResizeGripPosition(banner)
        table.insert(banners, banner)
        saveBannerConfig()
        updateList()
    end

    local btnEdit = createButton(managerFormInstance)
    btnEdit.Left = 320
    btnEdit.Top = 40
    btnEdit.Width = 160
    btnEdit.Caption = "Edit Selected"
    btnEdit.OnClick = function()
        local idx = listBox.ItemIndex
        if idx &gt;= 0 and banners[idx + 1] then
            editBannerContent(banners[idx + 1])
            updateList()
        end
    end

    local btnDelete = createButton(managerFormInstance)
    btnDelete.Left = 320
    btnDelete.Top = 70
    btnDelete.Width = 160
    btnDelete.Caption = "Delete Selected"
    btnDelete.OnClick = function()
        local idx = listBox.ItemIndex
        if idx &gt;= 0 and banners[idx + 1] then
            banners[idx + 1].form.destroy()
            table.remove(banners, idx + 1)
            saveBannerConfig()
            updateList()
        end
    end

    local btnLock = createButton(managerFormInstance)
    btnLock.Left = 320
    btnLock.Top = 100
    btnLock.Width = 160
    btnLock.Caption = bannerLocked and "Unlock All" or "Lock All"
    btnLock.OnClick = function()
        local newState = toggleBannerLock()
        btnLock.Caption = newState and "Unlock All" or "Lock All"
        updateList()
    end

    local btnClearAll = createButton(managerFormInstance)
    btnClearAll.Left = 320
    btnClearAll.Top = 130
    btnClearAll.Width = 160
    btnClearAll.Caption = "Remove All"
    btnClearAll.OnClick = function()
        if messageDialog("Remove all banners?", mtConfirmation, mbYes, mbNo) == mrYes then
            for _, banner in ipairs(banners) do
                banner.form.destroy()
            end
            banners = {}
            saveBannerConfig()
            updateList()
        end
    end

    local lblInfo = createLabel(managerFormInstance)
    lblInfo.Left = 10
    lblInfo.Top = 320
    lblInfo.Width = 470
    lblInfo.Height = 40
    lblInfo.Caption = "Double click on banners to edit. Drag images onto banners. Use transparency slider for glass effect."
    lblInfo.WordWrap = true

    local btnClose = createButton(managerFormInstance)
    btnClose.Left = 405
    btnClose.Top = 360
    btnClose.Width = 75
    btnClose.Caption = "Close"
    btnClose.OnClick = function()
        managerFormInstance.close()
    end

    managerFormInstance.OnClose = function(sender)
        sender.destroy()
        managerFormInstance = nil
    end

    updateList()
    managerFormInstance.show()
end

-- Function to start position tracking timer
function startPositionTracking()
    if positionTimer then
        positionTimer.destroy()
    end

    positionTimer = createTimer()
    positionTimer.Interval = 50

    local lastX = mainForm.Left
    local lastY = mainForm.Top

    positionTimer.OnTimer = function()
        if mainForm then
            local currentX = mainForm.Left
            local currentY = mainForm.Top

            if currentX ~= lastX or currentY ~= lastY then
                updateBannersPosition()
                lastX = currentX
                lastY = currentY
            end
        end
    end

    positionTimer.Enabled = true
end

-- Initialize the tool
function initBannerTool()
    mainForm = getMainForm()

    if not mainForm then
        showMessage("Error: Unable to find Cheat Engine MainForm")
        return
    end

    originalMainFormWidth = mainForm.Width
    originalMainFormHeight = mainForm.Height

    mainForm.OnResize = function(sender)
        updateBannersPosition()
    end

    startPositionTracking()

    local config = loadBannerConfig()

    if config.bannerLocked ~= nil then
        bannerLocked = config.bannerLocked
    end

    if config.banners then
        for i, data in ipairs(config.banners) do
            local x = (data.relX or 0.1) * mainForm.Width
            local y = (data.relY or 0.1) * mainForm.Height
            local width = (data.relWidth or 0.3) * mainForm.Width
            local height = (data.relHeight or 0.2) * mainForm.Height

            local banner = createBanner(mainForm, x, y, width, height)
            banner.contentType = data.contentType or "text"
            banner.content = data.content or ""
            banner.bgColor = data.bgColor or 0xFFFFFF
            banner.textColor = data.textColor or 0x000000
            banner.fontSize = data.fontSize or 12
            banner.textAlignment = data.textAlignment or "taCenter"
            banner.bgAlpha = data.bgAlpha or 255
            banner.locked = data.locked or false

            banner.panel.Color = banner.bgColor
            banner.form.AlphaBlendValue = banner.bgAlpha
            banner:updateContent()

            banner.relativeX = data.relX or (x / mainForm.Width)
            banner.relativeY = data.relY or (y / mainForm.Height)
            banner.relativeWidth = data.relWidth or (width / mainForm.Width)
            banner.relativeHeight = data.relHeight or (height / mainForm.Height)

            updateResizeGripPosition(banner)

            table.insert(banners, banner)
        end
    end

    local mainMenu = mainForm.Menu
    if mainMenu then
        for i = mainMenu.Items.Count - 1, 0, -1 do
            if mainMenu.Items[i].Caption == "Banner Tool" then
                mainMenu.Items.delete(i)
            end
        end

        local bannerMenu = createMenuItem(mainMenu)
        bannerMenu.Caption = "Banner Tool"

        local addBanner = createMenuItem(bannerMenu)
        addBanner.Caption = "Add new banner"
        addBanner.OnClick = function()
            local banner = createBanner(mainForm, math.random(50, 300), math.random(50, 300), 300, 150)
            banner.locked = bannerLocked
            updateResizeGripPosition(banner)
            table.insert(banners, banner)
            saveBannerConfig()
        end

        local manageMenu = createMenuItem(bannerMenu)
        manageMenu.Caption = "Manage banners..."
        manageMenu.OnClick = function()
            createBannerManager()
        end

        local lockMenu = createMenuItem(bannerMenu)
        lockMenu.Caption = bannerLocked and "Unlock all banners" or "Lock all banners"
        lockMenu.OnClick = function()
            local newState = toggleBannerLock()
            lockMenu.Caption = newState and "Unlock all banners" or "Lock all banners"
        end

        local sep = createMenuItem(bannerMenu)
        sep.Caption = "-"

        local clearBanners = createMenuItem(bannerMenu)
        clearBanners.Caption = "Remove all banners"
        clearBanners.OnClick = function()
            if messageDialog("Remove all banners?", mtConfirmation, mbYes, mbNo) == mrYes then
                for _, banner in ipairs(banners) do
                    banner.form.destroy()
                end
                banners = {}
                saveBannerConfig()
            end
        end

        bannerMenu.add(addBanner)
        bannerMenu.add(manageMenu)
        bannerMenu.add(lockMenu)
        bannerMenu.add(sep)
        bannerMenu.add(clearBanners)
        mainMenu.Items.add(bannerMenu)
    end

  ---  showMessage("Banner Tool v2.2 loaded!\n\n✨ FIXED: Banners can now be dragged from ANYWHERE when unlocked!\n✨ Banners follow window movement\n✨ TRUE TRANSPARENCY SUPPORT!\n\nClick and drag anywhere on unlocked banners to move them\nDouble click on banners to edit\nDrag images to add them\nUse the Banner Manager to lock/unlock banners\nAdjust transparency in Edit Banner dialog")
end

-- Clean up function
function cleanupBannerTool()
    if positionTimer then
        positionTimer.destroy()
        positionTimer = nil
    end

    for _, banner in ipairs(banners) do
        banner.form.destroy()
    end
    banners = {}
end

-- Start the tool
initBannerTool()




</LuaScript>
</CheatTable>
