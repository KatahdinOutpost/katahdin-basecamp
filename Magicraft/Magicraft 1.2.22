_G.ChaosCoreCountWhenChangeAreaAOriginalStaticAddress = nil
_G.ChaosCoreCountWhenChangeAreaABasePointer = nil
_G.ChaosCoreCountWhenChangeAreaACurrentRegister = nil

local function findOrCreateChaosCoreCountWhenChangeAreaAEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeChaosCoreCountWhenChangeAreaAStatus" then
      _G.ChaosCoreCountWhenChangeAreaAAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "ChaosCoreCountWhenChangeAreaA (Primary Array)"
  entry.Type = vtDword
  entry.Address = "seeChaosCoreCountWhenChangeAreaAStatus"
  _G.ChaosCoreCountWhenChangeAreaAAddressEntry = entry
  return entry
end

local function findOrCreateChaosCoreCountWhenChangeAreaAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setChaosCoreCountWhenChangeAreaAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addChaosCoreCountWhenChangeAreaAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subChaosCoreCountWhenChangeAreaAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.ChaosCoreCountWhenChangeAreaAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "ChaosCoreCountWhenChangeAreaA Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.ChaosCoreCountWhenChangeAreaAValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForChaosCoreCountWhenChangeAreaAPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(ChaosCoreCountWhenChangeAreaARegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(ChaosCoreCountWhenChangeAreaARegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handleChaosCoreCountWhenChangeAreaAOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readInteger
  local writeFunc = writeInteger

  if operation == "Set" then
    local valueAddr = getAddressSafe("setChaosCoreCountWhenChangeAreaAValue")
    local value = readInteger(valueAddr)
    writeInteger(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addChaosCoreCountWhenChangeAreaAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastChaosCoreCountWhenChangeAreaAValue then
        _G.lastChaosCoreCountWhenChangeAreaAValue = currentValue
      elseif currentValue &gt; _G.lastChaosCoreCountWhenChangeAreaAValue then
        local newValue = currentValue + value
        writeInteger(addr, newValue)
        _G.lastChaosCoreCountWhenChangeAreaAValue = newValue
      else
        _G.lastChaosCoreCountWhenChangeAreaAValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subChaosCoreCountWhenChangeAreaAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastChaosCoreCountWhenChangeAreaAValue then
        _G.lastChaosCoreCountWhenChangeAreaAValue = currentValue
      elseif currentValue &gt; _G.lastChaosCoreCountWhenChangeAreaAValue then
        local newValue = currentValue - value
        writeInteger(addr, newValue)
        _G.lastChaosCoreCountWhenChangeAreaAValue = newValue
      else
        _G.lastChaosCoreCountWhenChangeAreaAValue = currentValue
      end
    end
  end
end

local function ChaosCoreCountWhenChangeAreaATimerCallback()
  local injectionAddr = getAddressSafe("ChaosCoreCountWhenChangeAreaACopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForChaosCoreCountWhenChangeAreaAPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeChaosCoreCountWhenChangeAreaA")
  if not debugBufferAddr then return end

  local bufferOffset = ChaosCoreCountWhenChangeAreaARegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.ChaosCoreCountWhenChangeAreaABasePointer = pointerBase
  _G.ChaosCoreCountWhenChangeAreaACurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and ChaosCoreCountWhenChangeAreaARegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + ChaosCoreCountWhenChangeAreaARegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.ChaosCoreCountWhenChangeAreaAOriginalStaticAddress then
    _G.ChaosCoreCountWhenChangeAreaAOriginalStaticAddress = getAddressSafe("seeChaosCoreCountWhenChangeAreaAStatus")
  end

  unregisterSymbol("seeChaosCoreCountWhenChangeAreaAStatus")
  registerSymbol("seeChaosCoreCountWhenChangeAreaAStatus", primaryAddr)
  forceRefreshExistingEntry("seeChaosCoreCountWhenChangeAreaAStatus", primaryAddr)
  handleChaosCoreCountWhenChangeAreaAOperation(primaryAddr, "See", "4 Bytes")

  if not _G.ChaosCoreCountWhenChangeAreaAEntryCreated then
    findOrCreateChaosCoreCountWhenChangeAreaAEntry()
    _G.ChaosCoreCountWhenChangeAreaAEntryCreated = true
  end

  if not _G.ChaosCoreCountWhenChangeAreaAValueEntryCreated then
    findOrCreateChaosCoreCountWhenChangeAreaAValueEntry()
    _G.ChaosCoreCountWhenChangeAreaAValueEntryCreated = true
  end
end

if _G.unlimitedChaosCoreCountWhenChangeAreaATimer and _G.unlimitedChaosCoreCountWhenChangeAreaATimer.destroy then
  _G.unlimitedChaosCoreCountWhenChangeAreaATimer.destroy()
  _G.unlimitedChaosCoreCountWhenChangeAreaATimer = nil
end

_G.ChaosCoreCountWhenChangeAreaAEntryCreated = false
_G.ChaosCoreCountWhenChangeAreaAValueEntryCreated = false
_G.ChaosCoreCountWhenChangeAreaAAddressEntry = nil
_G.ChaosCoreCountWhenChangeAreaAOriginalStaticAddress = nil

if not _G.ChaosCoreCountWhenChangeAreaABasePointer then _G.ChaosCoreCountWhenChangeAreaABasePointer = nil end
if not _G.ChaosCoreCountWhenChangeAreaACurrentRegister then _G.ChaosCoreCountWhenChangeAreaACurrentRegister = nil end

if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.unlimitedChaosCoreCountWhenChangeAreaATimer = createTimer(nil, false)
    _G.unlimitedChaosCoreCountWhenChangeAreaATimer.Interval = 555
    _G.unlimitedChaosCoreCountWhenChangeAreaATimer.OnTimer = ChaosCoreCountWhenChangeAreaATimerCallback
    _G.unlimitedChaosCoreCountWhenChangeAreaATimer.Enabled = true
  end
  startupTimer.Enabled = true
end
