local MagicCristalsOnPickUpARegs = { "rbx", "rsi", "rdi", "rcx", "rdx", "rax", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "rbp", "rsp" }
local MagicCristalsOnPickUpARegBufferOffsets = { rbx = 8, rsi = 24, rdi = 40, rcx = 56, rdx = 72, rax = 88, r8 = 104, r9 = 120, r10 = 136, r11 = 152, r12 = 264, r13 = 280, r14 = 296, r15 = 312, rbp = 328, rsp = 344}

-- GLOBAL variables for communication between scripts
_G.MagicCristalsOnPickUpAAddressEntry = nil
_G.MagicCristalsOnPickUpAOriginalStaticAddress = nil
_G.MagicCristalsOnPickUpABasePointer = nil
_G.MagicCristalsOnPickUpACurrentRegister = nil

local function findOrCreateMagicCristalsOnPickUpAEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeMagicCristalsOnPickUpAStatus" then
      _G.MagicCristalsOnPickUpAAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "MagicCristalsOnPickUpA (Primary Array)"
  entry.Type = vtDword
  entry.Address = "seeMagicCristalsOnPickUpAStatus"
  _G.MagicCristalsOnPickUpAAddressEntry = entry
  return entry
end

local function findOrCreateMagicCristalsOnPickUpAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setMagicCristalsOnPickUpAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addMagicCristalsOnPickUpAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subMagicCristalsOnPickUpAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.MagicCristalsOnPickUpAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "MagicCristalsOnPickUpA Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.MagicCristalsOnPickUpAValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForMagicCristalsOnPickUpAPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(MagicCristalsOnPickUpARegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(MagicCristalsOnPickUpARegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handleMagicCristalsOnPickUpAOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readInteger
  local writeFunc = writeInteger

  if operation == "Set" then
    local valueAddr = getAddressSafe("setMagicCristalsOnPickUpAValue")
    local value = readInteger(valueAddr)
    writeInteger(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addMagicCristalsOnPickUpAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastMagicCristalsOnPickUpAValue then
        _G.lastMagicCristalsOnPickUpAValue = currentValue
      elseif currentValue &gt; _G.lastMagicCristalsOnPickUpAValue then
        local newValue = currentValue + value
        writeInteger(addr, newValue)
        _G.lastMagicCristalsOnPickUpAValue = newValue
      else
        _G.lastMagicCristalsOnPickUpAValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subMagicCristalsOnPickUpAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastMagicCristalsOnPickUpAValue then
        _G.lastMagicCristalsOnPickUpAValue = currentValue
      elseif currentValue &gt; _G.lastMagicCristalsOnPickUpAValue then
        local newValue = currentValue - value
        writeInteger(addr, newValue)
        _G.lastMagicCristalsOnPickUpAValue = newValue
      else
        _G.lastMagicCristalsOnPickUpAValue = currentValue
      end
    end
  end
end

local function MagicCristalsOnPickUpATimerCallback()
  local injectionAddr = getAddressSafe("MagicCristalsOnPickUpACopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForMagicCristalsOnPickUpAPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeMagicCristalsOnPickUpA")
  if not debugBufferAddr then return end

  local bufferOffset = MagicCristalsOnPickUpARegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.MagicCristalsOnPickUpABasePointer = pointerBase
  _G.MagicCristalsOnPickUpACurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and MagicCristalsOnPickUpARegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + MagicCristalsOnPickUpARegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.MagicCristalsOnPickUpAOriginalStaticAddress then
    _G.MagicCristalsOnPickUpAOriginalStaticAddress = getAddressSafe("seeMagicCristalsOnPickUpAStatus")
  end

  unregisterSymbol("seeMagicCristalsOnPickUpAStatus")
  registerSymbol("seeMagicCristalsOnPickUpAStatus", primaryAddr)
  forceRefreshExistingEntry("seeMagicCristalsOnPickUpAStatus", primaryAddr)
  handleMagicCristalsOnPickUpAOperation(primaryAddr, "See", "4 Bytes")

  if not _G.MagicCristalsOnPickUpAEntryCreated then
    findOrCreateMagicCristalsOnPickUpAEntry()
    _G.MagicCristalsOnPickUpAEntryCreated = true
  end

  if not _G.MagicCristalsOnPickUpAValueEntryCreated then
    findOrCreateMagicCristalsOnPickUpAValueEntry()
    _G.MagicCristalsOnPickUpAValueEntryCreated = true
  end
end

