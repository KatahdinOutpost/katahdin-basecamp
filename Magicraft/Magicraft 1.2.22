end

if _G.CoinsCountOnPickUpAOriginalStaticAddress then
  unregisterSymbol("seeCoinsCountOnPickUpAStatus")
  registerSymbol("seeCoinsCountOnPickUpAStatus", _G.CoinsCountOnPickUpAOriginalStaticAddress)

  if _G.CoinsCountOnPickUpAAddressEntry then
    _G.CoinsCountOnPickUpAAddressEntry.Address = string.format("0x%X", _G.CoinsCountOnPickUpAOriginalStaticAddress)
    sleep(1)
    _G.CoinsCountOnPickUpAAddressEntry.Address = "seeCoinsCountOnPickUpAStatus"
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeCoinsCountOnPickUpAStatus")
  if allocatedAddr then
    unregisterSymbol("seeCoinsCountOnPickUpAStatus")
    registerSymbol("seeCoinsCountOnPickUpAStatus", allocatedAddr)

    if _G.CoinsCountOnPickUpAAddressEntry then
      _G.CoinsCountOnPickUpAAddressEntry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      _G.CoinsCountOnPickUpAAddressEntry.Address = "seeCoinsCountOnPickUpAStatus"
    end
  end
end

_G.CoinsCountOnPickUpAEntryCreated = false
_G.CoinsCountOnPickUpAValueEntryCreated = false
_G.CoinsCountOnPickUpAAddressEntry = nil
_G.CoinsCountOnPickUpAOriginalStaticAddress = nil

_G.CoinsCountOnPickUpABasePointer = nil
