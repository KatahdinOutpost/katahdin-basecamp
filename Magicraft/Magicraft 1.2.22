{$lua}
local PlayerExtraDamageWhenShootARegs = { "rbx", "rsi", "rdi", "rcx", "rdx", "rax", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "rbp", "rsp" }
local PlayerExtraDamageWhenShootARegBufferOffsets = { rbx = 8, rsi = 24, rdi = 40, rcx = 56, rdx = 72, rax = 88, r8 = 104, r9 = 120, r10 = 136, r11 = 152, r12 = 264, r13 = 280, r14 = 296, r15 = 312, rbp = 328, rsp = 344}

-- GLOBAL variables for communication between scripts
_G.PlayerExtraDamageWhenShootAAddressEntry = nil
_G.PlayerExtraDamageWhenShootAOriginalStaticAddress = nil
_G.PlayerExtraDamageWhenShootABasePointer = nil
_G.PlayerExtraDamageWhenShootACurrentRegister = nil

local function findOrCreatePlayerExtraDamageWhenShootAEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seePlayerExtraDamageWhenShootAStatus" then
      _G.PlayerExtraDamageWhenShootAAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "PlayerExtraDamageWhenShootA (Primary Array)"
  entry.Type = vtSingle
  entry.Address = "seePlayerExtraDamageWhenShootAStatus"
  _G.PlayerExtraDamageWhenShootAAddressEntry = entry
  return entry
end

local function findOrCreatePlayerExtraDamageWhenShootAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setPlayerExtraDamageWhenShootAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addPlayerExtraDamageWhenShootAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subPlayerExtraDamageWhenShootAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.PlayerExtraDamageWhenShootAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "PlayerExtraDamageWhenShootA Value (See)"
  entry.Type = vtSingle
  entry.Address = valueSymbolName
  _G.PlayerExtraDamageWhenShootAValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForPlayerExtraDamageWhenShootAPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(PlayerExtraDamageWhenShootARegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(PlayerExtraDamageWhenShootARegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handlePlayerExtraDamageWhenShootAOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readFloat
  local writeFunc = writeFloat

  if operation == "Set" then
    local valueAddr = getAddressSafe("setPlayerExtraDamageWhenShootAValue")
    local value = readFloat(valueAddr)
    writeFloat(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addPlayerExtraDamageWhenShootAValue")
    local value = readFloat(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastPlayerExtraDamageWhenShootAValue then
        _G.lastPlayerExtraDamageWhenShootAValue = currentValue
      elseif currentValue &gt; _G.lastPlayerExtraDamageWhenShootAValue then
        local newValue = currentValue + value
        writeFloat(addr, newValue)
        _G.lastPlayerExtraDamageWhenShootAValue = newValue
      else
        _G.lastPlayerExtraDamageWhenShootAValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subPlayerExtraDamageWhenShootAValue")
    local value = readFloat(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastPlayerExtraDamageWhenShootAValue then
        _G.lastPlayerExtraDamageWhenShootAValue = currentValue
      elseif currentValue &gt; _G.lastPlayerExtraDamageWhenShootAValue then
        local newValue = currentValue - value
        writeFloat(addr, newValue)
        _G.lastPlayerExtraDamageWhenShootAValue = newValue
      else
        _G.lastPlayerExtraDamageWhenShootAValue = currentValue
      end
    end
  end
end

local function PlayerExtraDamageWhenShootATimerCallback()
  local injectionAddr = getAddressSafe("PlayerExtraDamageWhenShootACopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForPlayerExtraDamageWhenShootAPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seePlayerExtraDamageWhenShootA")
  if not debugBufferAddr then return end

  local bufferOffset = PlayerExtraDamageWhenShootARegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.PlayerExtraDamageWhenShootABasePointer = pointerBase
  _G.PlayerExtraDamageWhenShootACurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and PlayerExtraDamageWhenShootARegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + PlayerExtraDamageWhenShootARegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.PlayerExtraDamageWhenShootAOriginalStaticAddress then
    _G.PlayerExtraDamageWhenShootAOriginalStaticAddress = getAddressSafe("seePlayerExtraDamageWhenShootAStatus")
  end

  unregisterSymbol("seePlayerExtraDamageWhenShootAStatus")
  registerSymbol("seePlayerExtraDamageWhenShootAStatus", primaryAddr)
  forceRefreshExistingEntry("seePlayerExtraDamageWhenShootAStatus", primaryAddr)
  handlePlayerExtraDamageWhenShootAOperation(primaryAddr, "See", "Float")

  if not _G.PlayerExtraDamageWhenShootAEntryCreated then
    findOrCreatePlayerExtraDamageWhenShootAEntry()
    _G.PlayerExtraDamageWhenShootAEntryCreated = true
  end

  if not _G.PlayerExtraDamageWhenShootAValueEntryCreated then
    findOrCreatePlayerExtraDamageWhenShootAValueEntry()
    _G.PlayerExtraDamageWhenShootAValueEntryCreated = true
  end
end

if _G.unlimitedPlayerExtraDamageWhenShootATimer and _G.unlimitedPlayerExtraDamageWhenShootATimer.destroy then
  _G.unlimitedPlayerExtraDamageWhenShootATimer.destroy()
  _G.unlimitedPlayerExtraDamageWhenShootATimer = nil
end

_G.PlayerExtraDamageWhenShootAEntryCreated = false
_G.PlayerExtraDamageWhenShootAValueEntryCreated = false
_G.PlayerExtraDamageWhenShootAAddressEntry = nil
_G.PlayerExtraDamageWhenShootAOriginalStaticAddress = nil

if not _G.PlayerExtraDamageWhenShootABasePointer then _G.PlayerExtraDamageWhenShootABasePointer = nil end
if not _G.PlayerExtraDamageWhenShootACurrentRegister then _G.PlayerExtraDamageWhenShootACurrentRegister = nil end

if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.unlimitedPlayerExtraDamageWhenShootATimer = createTimer(nil, false)
    _G.unlimitedPlayerExtraDamageWhenShootATimer.Interval = 555
    _G.unlimitedPlayerExtraDamageWhenShootATimer.OnTimer = PlayerExtraDamageWhenShootATimerCallback
    _G.unlimitedPlayerExtraDamageWhenShootATimer.Enabled = true
  end
  startupTimer.Enabled = true
end
{$asm}

[DISABLE]

{$lua}
if _G.unlimitedPlayerExtraDamageWhenShootATimer and _G.unlimitedPlayerExtraDamageWhenShootATimer.destroy then
  _G.unlimitedPlayerExtraDamageWhenShootATimer.destroy()
  _G.unlimitedPlayerExtraDamageWhenShootATimer = nil
end

if _G.PlayerExtraDamageWhenShootAOriginalStaticAddress then
  unregisterSymbol("seePlayerExtraDamageWhenShootAStatus")
  registerSymbol("seePlayerExtraDamageWhenShootAStatus", _G.PlayerExtraDamageWhenShootAOriginalStaticAddress)

  if _G.PlayerExtraDamageWhenShootAAddressEntry then
    _G.PlayerExtraDamageWhenShootAAddressEntry.Address = string.format("0x%X", _G.PlayerExtraDamageWhenShootAOriginalStaticAddress)
    sleep(1)
    _G.PlayerExtraDamageWhenShootAAddressEntry.Address = "seePlayerExtraDamageWhenShootAStatus"
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seePlayerExtraDamageWhenShootAStatus")
  if allocatedAddr then
    unregisterSymbol("seePlayerExtraDamageWhenShootAStatus")
    registerSymbol("seePlayerExtraDamageWhenShootAStatus", allocatedAddr)

    if _G.PlayerExtraDamageWhenShootAAddressEntry then
      _G.PlayerExtraDamageWhenShootAAddressEntry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      _G.PlayerExtraDamageWhenShootAAddressEntry.Address = "seePlayerExtraDamageWhenShootAStatus"
    end
  end
end

_G.PlayerExtraDamageWhenShootAEntryCreated = false
_G.PlayerExtraDamageWhenShootAValueEntryCreated = false
_G.PlayerExtraDamageWhenShootAAddressEntry = nil
_G.PlayerExtraDamageWhenShootAOriginalStaticAddress = nil

_G.PlayerExtraDamageWhenShootABasePointer = nil
_G.PlayerExtraDamageWhenShootACurrentRegister = nil
_G.lastPlayerExtraDamageWhenShootAValue = nil

