{$lua}
if syntaxcheck then return end
function aob_register(sym, patterns)
    if type(patterns) == "string" then
        patterns = {patterns}
    end

    local lastError = ""
    for _, pat in ipairs(patterns) do
        local instr = AOBScan(pat, "+X")
        if instr and instr.Count &gt; 0 then
            local addy = instr[0]
            instr.destroy()
            unregisterSymbol(sym)
            registerSymbol(sym, tonumber(addy,16))
            return true
        else
            if instr then instr.destroy() end
            lastError = lastError .. "Pattern not found: " .. pat .. "\n"
        end
    end

    error('No patterns found!\n' .. lastError)
end

function calculateInstructionDetails(address)
    local totalSize = 0
    local instructionCount = 0
    local currentAddr = tonumber(address)

    while totalSize &lt; 5 do
        local size = getInstructionSize(currentAddr)
        if not size or size == 0 then
            error('Could not determine instruction size at address: ' .. string.format('0x%X', currentAddr))
        end
        totalSize = totalSize + size
        currentAddr = currentAddr + size
        instructionCount = instructionCount + 1
    end

    local nopCount = totalSize - 5
    return totalSize, nopCount, instructionCount
end
aob_register("ExtraCriticalChanceWhenShootA", {"F3 0F 10 90 98 02"
, "F3 0F 10 ?? ?? ?? 00 00 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 00 00 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 48 ?? ?? ?? ?? ?? 00 00 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 0F"
, "F3 0F 10 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 48 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 0F ?? ?? ?? 0F ?? ?? F3 0F ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? FF"
, "F3 ?? ?? ?? ?? ?? ?? ?? 48 85 ?? 74 ?? 48 83 ?? ?? ?? ?? ?? ?? 48 8B ?? F3"
, "F3 ?? ?? ?? ?? ?? ?? ?? 48 ?? ?? 74 ?? 48 ?? ?? ?? ?? ?? ?? ?? 48 ?? ?? F3 ?? ?? ?? ?? ?? ?? ?? 74 ?? 48 ?? ?? ?? ?? ?? ?? 66 ?? ?? ?? ?? ?? ?? ?? 48 ?? ??"})
local ExtraCriticalChanceWhenShootAAddr = getAddressSafe("ExtraCriticalChanceWhenShootA")
if not ExtraCriticalChanceWhenShootAAddr then error('ExtraCriticalChanceWhenShootA address not found!') end
local totalBytes, nopCount, instCount = calculateInstructionDetails(ExtraCriticalChanceWhenShootAAddr)
_G.ExtraCriticalChanceWhenShootATotalBytes = totalBytes
_G.ExtraCriticalChanceWhenShootANopCount = nopCount
_G.ExtraCriticalChanceWhenShootAReadmemInstruction = string.format("readmem(ExtraCriticalChanceWhenShootA,%d)", totalBytes)
-- To force bytes manually, uncomment the following line:
-- _G.ExtraCriticalChanceWhenShootAReadmemInstruction = "readmem(ExtraCriticalChanceWhenShootA, 8)" -- Replace 8 with desired byte count
_G.ExtraCriticalChanceWhenShootANopInstructions = ""
if nopCount &gt; 0 then
  for i = 1, nopCount do
    _G.ExtraCriticalChanceWhenShootANopInstructions = _G.ExtraCriticalChanceWhenShootANopInstructions .. "nop\n"
  end
  _G.ExtraCriticalChanceWhenShootANopInstructions = _G.ExtraCriticalChanceWhenShootANopInstructions:sub(1, -2)
end
{$asm}

alloc(newmem,$1000,ExtraCriticalChanceWhenShootA)
alloc(ExtraCriticalChanceWhenShootACopy,30)
