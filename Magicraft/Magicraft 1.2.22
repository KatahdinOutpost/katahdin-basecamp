{$lua}
local CoinsCountOnPickUpARegs = { "rbx", "rsi", "rdi", "rcx", "rdx", "rax", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "rbp", "rsp" }
local CoinsCountOnPickUpARegBufferOffsets = { rbx = 8, rsi = 24, rdi = 40, rcx = 56, rdx = 72, rax = 88, r8 = 104, r9 = 120, r10 = 136, r11 = 152, r12 = 264, r13 = 280, r14 = 296, r15 = 312, rbp = 328, rsp = 344}

-- GLOBAL variables for communication between scripts
_G.CoinsCountOnPickUpAAddressEntry = nil
_G.CoinsCountOnPickUpAOriginalStaticAddress = nil
_G.CoinsCountOnPickUpABasePointer = nil
_G.CoinsCountOnPickUpACurrentRegister = nil

local function findOrCreateCoinsCountOnPickUpAEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeCoinsCountOnPickUpAStatus" then
      _G.CoinsCountOnPickUpAAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "CoinsCountOnPickUpA (Primary Array)"
  entry.Type = vtDword
  entry.Address = "seeCoinsCountOnPickUpAStatus"
  _G.CoinsCountOnPickUpAAddressEntry = entry
  return entry
end

local function findOrCreateCoinsCountOnPickUpAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setCoinsCountOnPickUpAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addCoinsCountOnPickUpAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subCoinsCountOnPickUpAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.CoinsCountOnPickUpAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "CoinsCountOnPickUpA Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.CoinsCountOnPickUpAValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForCoinsCountOnPickUpAPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(CoinsCountOnPickUpARegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(CoinsCountOnPickUpARegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handleCoinsCountOnPickUpAOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readInteger
  local writeFunc = writeInteger

  if operation == "Set" then
    local valueAddr = getAddressSafe("setCoinsCountOnPickUpAValue")
    local value = readInteger(valueAddr)
    writeInteger(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addCoinsCountOnPickUpAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastCoinsCountOnPickUpAValue then
        _G.lastCoinsCountOnPickUpAValue = currentValue
      elseif currentValue &gt; _G.lastCoinsCountOnPickUpAValue then
        local newValue = currentValue + value
        writeInteger(addr, newValue)
        _G.lastCoinsCountOnPickUpAValue = newValue
      else
        _G.lastCoinsCountOnPickUpAValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subCoinsCountOnPickUpAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastCoinsCountOnPickUpAValue then
        _G.lastCoinsCountOnPickUpAValue = currentValue
      elseif currentValue &gt; _G.lastCoinsCountOnPickUpAValue then
        local newValue = currentValue - value
        writeInteger(addr, newValue)
        _G.lastCoinsCountOnPickUpAValue = newValue
      else
        _G.lastCoinsCountOnPickUpAValue = currentValue
      end
    end
  end
end

local function CoinsCountOnPickUpATimerCallback()
  local injectionAddr = getAddressSafe("CoinsCountOnPickUpACopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForCoinsCountOnPickUpAPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeCoinsCountOnPickUpA")
  if not debugBufferAddr then return end

  local bufferOffset = CoinsCountOnPickUpARegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.CoinsCountOnPickUpABasePointer = pointerBase
  _G.CoinsCountOnPickUpACurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and CoinsCountOnPickUpARegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + CoinsCountOnPickUpARegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.CoinsCountOnPickUpAOriginalStaticAddress then
    _G.CoinsCountOnPickUpAOriginalStaticAddress = getAddressSafe("seeCoinsCountOnPickUpAStatus")
  end

  unregisterSymbol("seeCoinsCountOnPickUpAStatus")
  registerSymbol("seeCoinsCountOnPickUpAStatus", primaryAddr)
  forceRefreshExistingEntry("seeCoinsCountOnPickUpAStatus", primaryAddr)
  handleCoinsCountOnPickUpAOperation(primaryAddr, "See", "4 Bytes")

  if not _G.CoinsCountOnPickUpAEntryCreated then
    findOrCreateCoinsCountOnPickUpAEntry()
    _G.CoinsCountOnPickUpAEntryCreated = true
  end

  if not _G.CoinsCountOnPickUpAValueEntryCreated then
    findOrCreateCoinsCountOnPickUpAValueEntry()
    _G.CoinsCountOnPickUpAValueEntryCreated = true
  end
end

if _G.unlimitedCoinsCountOnPickUpATimer and _G.unlimitedCoinsCountOnPickUpATimer.destroy then
  _G.unlimitedCoinsCountOnPickUpATimer.destroy()
  _G.unlimitedCoinsCountOnPickUpATimer = nil
end

_G.CoinsCountOnPickUpAEntryCreated = false
_G.CoinsCountOnPickUpAValueEntryCreated = false
_G.CoinsCountOnPickUpAAddressEntry = nil
_G.CoinsCountOnPickUpAOriginalStaticAddress = nil

if not _G.CoinsCountOnPickUpABasePointer then _G.CoinsCountOnPickUpABasePointer = nil end
if not _G.CoinsCountOnPickUpACurrentRegister then _G.CoinsCountOnPickUpACurrentRegister = nil end

if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.unlimitedCoinsCountOnPickUpATimer = createTimer(nil, false)
    _G.unlimitedCoinsCountOnPickUpATimer.Interval = 555
    _G.unlimitedCoinsCountOnPickUpATimer.OnTimer = CoinsCountOnPickUpATimerCallback
    _G.unlimitedCoinsCountOnPickUpATimer.Enabled = true
  end
  startupTimer.Enabled = true
end
