, "48 ?? ?? ?? ?? ?? ?? 48 ?? ?? B9 ?? ?? ?? ?? 48 ?? ?? 7F ?? 33 ?? 48 ?? ?? E8 ?? ?? ?? ?? 48 ?? ?? 0F ?? ?? ?? ?? ??"})
local KeysCountWhenPickUpOrUseAAddr = getAddressSafe("KeysCountWhenPickUpOrUseA")
if not KeysCountWhenPickUpOrUseAAddr then error('KeysCountWhenPickUpOrUseA address not found!') end
local totalBytes, nopCount, instCount = calculateInstructionDetails(KeysCountWhenPickUpOrUseAAddr)
_G.KeysCountWhenPickUpOrUseATotalBytes = totalBytes
_G.KeysCountWhenPickUpOrUseANopCount = nopCount
_G.KeysCountWhenPickUpOrUseAReadmemInstruction = string.format("readmem(KeysCountWhenPickUpOrUseA,%d)", totalBytes)
