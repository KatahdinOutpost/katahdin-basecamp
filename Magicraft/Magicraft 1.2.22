  <UserdefinedSymbols/>
  <LuaScript>-- SCRIPT 4: Process Monitor (Fixed)
function checkProcessStatus(procName)
    while true do
        if getProcessIDFromProcessName(procName) == nil then
            synchronize(function()
                if getMainForm() and getMainForm().ProcessLabel then
                    getMainForm().ProcessLabel.Caption = "No Process Selected"
                end
            end)
            break
        end
        sleep(1000)
    end
end

function monitorProcess(procName)
    while true do
        if getProcessIDFromProcessName(procName) == nil then
            synchronize(function()
                if getMainForm() and getMainForm().ProcessLabel then
                    getMainForm().ProcessLabel.Caption = "Searching for Process: " .. procName
                end
            end)
        else
            openProcess(procName)
            synchronize(function()
                if getMainForm() and getMainForm().ProcessLabel then
                    getMainForm().ProcessLabel.Caption = "Process Attached: " .. procName
                end
            end)
            checkProcessStatus(procName)
        end
        sleep(1000)
    end
end

local procName = "Magicraft.exe.exe"

createThread(function()
    monitorProcess(procName)
end)






