-- Safe cleanup of previous instance
if LogView and type(LogView) == "table" and LogView.destroy then
    LogView:destroy()
end

-- Initialize LogView
LogView = {
    logs = {},
    maxLogs = 500,
    form = nil,
    logListView = nil,  -- Changed from logMemo to ListView for color support
    statusLabel = nil,
    statusPanel = nil,
    buttonPanel = nil,  -- Separate panel for button that stays visible
    buttonShowLog = nil,
    isVisible = false,
    startTime = os.clock(),
    originalError = error,
    originalPrint = print,
    scriptOriginals = {},
    addressListPopup = nil,
    contextMenu = nil,
    hideTimer = nil,
    lastMessageTime = 0,
    settingsRecord = nil,

    -- Default settings
    settings = {
        autoHideEnabled = true,
        autoHideDelay = 3000, -- milliseconds
        autoScroll = true,
        wordWrap = false,
        colors = {
            INFO = 0xC0C0C0,     -- Gray
            WARNING = 0x00FBFB,  -- Yellow
            ERROR = 0x0000FF,    -- Red
            SUCCESS = 0x00FF00,  -- Bright Green
            DEBUG = 0xFF8000,    -- Blue
            print = 0xFF8080     -- Violet
        }
    }
}

-- Function to save configuration in CE address list (FIXED VERSION)
function LogView:saveSettings()
    local addressList = getAddressList()

    -- Find or create settings record
    local scriptRecord = addressList.getMemoryRecordByDescription('LogView_Config')

    if not scriptRecord then
        scriptRecord = addressList.createMemoryRecord()
        scriptRecord.Description = 'LogView_Config'
        scriptRecord.Type = vtAutoAssembler
    end

    -- Create settings script (following Banner Tool pattern exactly)
    local configScript = "// LogView Configuration Script\n"
    configScript = configScript .. "// This script contains the LogView configuration data\n\n"
    configScript = configScript .. "{$lua}\n"
    configScript = configScript .. "if not LogViewConfig then\n"
    configScript = configScript .. "  LogViewConfig = {}\n"
    configScript = configScript .. "end\n\n"
    configScript = configScript .. "LogViewConfig.autoHideEnabled = " .. tostring(self.settings.autoHideEnabled) .. "\n"
    configScript = configScript .. "LogViewConfig.autoHideDelay = " .. self.settings.autoHideDelay .. "\n"
    configScript = configScript .. "LogViewConfig.autoScroll = " .. tostring(self.settings.autoScroll) .. "\n"
    configScript = configScript .. "LogViewConfig.wordWrap = " .. tostring(self.settings.wordWrap) .. "\n"
    configScript = configScript .. "LogViewConfig.colors = {\n"
    configScript = configScript .. "    INFO = 0x" .. string.format("%06X", self.settings.colors.INFO) .. ",\n"
    configScript = configScript .. "    WARNING = 0x" .. string.format("%06X", self.settings.colors.WARNING) .. ",\n"
    configScript = configScript .. "    ERROR = 0x" .. string.format("%06X", self.settings.colors.ERROR) .. ",\n"
    configScript = configScript .. "    SUCCESS = 0x" .. string.format("%06X", self.settings.colors.SUCCESS) .. ",\n"
    configScript = configScript .. "    DEBUG = 0x" .. string.format("%06X", self.settings.colors.DEBUG) .. ",\n"
    configScript = configScript .. "    print = 0x" .. string.format("%06X", self.settings.colors.print) .. "\n"
    configScript = configScript .. "}\n"
    configScript = configScript .. "{$asm}\n\n"
    configScript = configScript .. "// End of LogView Configuration"

    -- Save the script
    scriptRecord.Script = configScript

    -- Execute the script to initialize the configuration
    scriptRecord.Active = false
    scriptRecord.Active = true
end

-- Function to load configuration from CE address list
function LogView:loadSettings()
    local addressList = getAddressList()
    local scriptRecord = addressList.getMemoryRecordByDescription('LogView_Config')

    if not scriptRecord then
        return -- No saved settings
    end

    -- Execute the script to load the configuration
    if not scriptRecord.Active then
        scriptRecord.Active = true
    end

    -- Apply loaded settings if they exist
    if LogViewConfig then
        if LogViewConfig.autoHideEnabled ~= nil then
            self.settings.autoHideEnabled = LogViewConfig.autoHideEnabled
        end
        if LogViewConfig.autoHideDelay then
            self.settings.autoHideDelay = LogViewConfig.autoHideDelay
        end
        if LogViewConfig.autoScroll ~= nil then
            self.settings.autoScroll = LogViewConfig.autoScroll
        end
        if LogViewConfig.wordWrap ~= nil then
            self.settings.wordWrap = LogViewConfig.wordWrap
        end
        if LogViewConfig.colors then
            for k, v in pairs(LogViewConfig.colors) do
                if self.settings.colors[k] then
                    self.settings.colors[k] = v
                end
            end
        end
    end
end

-- Create auto-hide timer
function LogView:createAutoHideTimer()
    if self.hideTimer then
        self.hideTimer.destroy()
    end

    self.hideTimer = createTimer()
    self.hideTimer.Interval = 100 -- Check every 100ms
    self.hideTimer.OnTimer = function()
        if self.settings.autoHideEnabled and self.statusPanel and not self.statusPanel.Destroyed then
            local currentTime = os.clock() * 1000
            if currentTime - self.lastMessageTime &gt; self.settings.autoHideDelay then
                self.statusPanel.Visible = false
                self.hideTimer.Enabled = false
            end
        end
    end
end

-- Show status panel and reset timer
function LogView:showStatusPanel()
    if self.statusPanel and not self.statusPanel.Destroyed then
        self.statusPanel.Visible = true
        self.lastMessageTime = os.clock() * 1000

        if self.settings.autoHideEnabled and self.hideTimer then
            self.hideTimer.Enabled = true
        end
    end
end

-- Timestamp formatting
function LogView:getTimestamp()
    return string.format("[%s][%.3fs]", os.date("%H:%M:%S"), os.clock() - self.startTime)
end

-- Adds an entry to the log
function LogView:add(logType, message, source)
    local timestamp = self:getTimestamp()
    local entry = {
        time = timestamp,
        type = logType,
        message = tostring(message),
        source = source or "Unknown"
    }

    table.insert(self.logs, entry)

    -- Limit the number of logs
    if #self.logs &gt; self.maxLogs then
        table.remove(self.logs, 1)
    end

    -- Update status label if it exists
    if self.statusLabel and not self.statusLabel.Destroyed then
        self:updateStatusLabel(message)
        self:showStatusPanel() -- Show panel when new message arrives
    end

    -- Update the ListView if visible
    if self.logListView and not self.logListView.Destroyed and self.isVisible then
        self:addToListView(entry)
    end
end

-- Adds an entry to the ListView
function LogView:addToListView(entry)
    if not self.logListView or self.logListView.Destroyed then return end

    local item = self.logListView.Items.add()
    item.Caption = entry.time
    item.SubItems.add(entry.type)
    item.SubItems.add(entry.message)

    -- Set color based on log type
    local color = self.settings.colors[entry.type] or 0x000000
    -- Store the color in the Data property
    item.Data = color

    -- Auto-scroll if enabled
    if self.settings.autoScroll then
        item.MakeVisible(false)
    end

    -- Update counter
    if self.countLabel and not self.countLabel.Destroyed then
        self.countLabel.Caption = "Entries: " .. #self.logs
    end
end

-- Different log types
function LogView:info(message, source)
    self:add("INFO", message, source or debug.getinfo(2, "S").source)
end

function LogView:warning(message, source)
    self:add("WARNING", message, source or debug.getinfo(2, "S").source)
end

function LogView:error(message, source)
    self:add("ERROR", message, source or debug.getinfo(2, "S").source)
end

function LogView:debug(message, source)
    self:add("DEBUG", message, source or debug.getinfo(2, "S").source)
end

function LogView:success(message, source)
    self:add("SUCCESS", message, source or debug.getinfo(2, "S").source)
end

-- Intercept global errors
function LogView:hookErrors()
    -- Override error function
    _G.error = function(message, level)
        LogView:error(message, debug.getinfo(2, "S").source)
        LogView.originalError(message, level)
    end

    -- Override print to capture output
    _G.print = function(...)
        local args = {...}
        local message = table.concat(args, " ")
        LogView:add("print", message, "print")
        LogView.originalPrint(...)
    end

    -- Hook for pcall errors
    local originalPcall = pcall
    _G.pcall = function(f, ...)
        local results = {originalPcall(f, ...)}
        if not results[1] then
            LogView:error("pcall error: " .. tostring(results[2]), debug.getinfo(2, "S").source)
        end
        return table.unpack(results)
    end
end

-- Show find dialog for ListView
function LogView:showFindDialog()
    local findForm = createForm(false)
    findForm.Caption = "Find in Log"
    findForm.Width = 350
    findForm.Height = 120
    findForm.Position = poMainFormCenter
    findForm.BorderStyle = bsDialog

    local lblFind = createLabel(findForm)
    lblFind.Parent = findForm
    lblFind.Caption = "Text to find:"
    lblFind.Left = 10
    lblFind.Top = 15

    local edtFind = createEdit(findForm)
    edtFind.Parent = findForm
    edtFind.Left = 10
    edtFind.Top = 35
    edtFind.Width = 250

    local btnFind = createButton(findForm)
    btnFind.Parent = findForm
    btnFind.Caption = "Find"
    btnFind.Left = 270
    btnFind.Top = 33
    btnFind.Width = 60

    local chkCase = createCheckBox(findForm)
    chkCase.Parent = findForm
    chkCase.Caption = "Case sensitive"
    chkCase.Left = 10
    chkCase.Top = 65

    local lastIndex = -1

    btnFind.OnClick = function()
        local searchText = edtFind.Text
        if searchText == "" then return end

        local caseSensitive = chkCase.Checked
        if not caseSensitive then
            searchText = string.lower(searchText)
        end

        -- Search in ListView items
        local found = false
        local startIndex = lastIndex + 1

        for i = startIndex, self.logListView.Items.Count - 1 do
            local item = self.logListView.Items[i]
            local textToSearch = item.Caption .. " " .. item.SubItems[0] .. " " .. item.SubItems[1]

            if not caseSensitive then
                textToSearch = string.lower(textToSearch)
            end

            if string.find(textToSearch, searchText, 1, true) then
                -- Clear previous selections
                for j = 0, self.logListView.Items.Count - 1 do
                    self.logListView.Items[j].Selected = false
                end

                -- Select and make visible the found item
                item.Selected = true
                item.MakeVisible(false)
                self.logListView.SetFocus()
                lastIndex = i
                found = true
                break
            end
        end

        if not found then
            if lastIndex &gt; -1 then
                -- Start from beginning
                lastIndex = -1
                btnFind.OnClick()
            else
                showMessage("Text not found")
            end
        end
    end

    edtFind.OnKeyDown = function(sender, key)
        if key == VK_RETURN then
            btnFind.OnClick()
        elseif key == VK_ESCAPE then
            findForm.close()
        end
    end

    findForm.show()
end

-- Create context menu for the ListView
function LogView:createContextMenu()
    if self.contextMenu and not self.contextMenu.Destroyed then
        self.contextMenu.destroy()
    end

    self.contextMenu = createPopupMenu(self.form)

    -- Copy selection
    local miCopy = createMenuItem(self.contextMenu)
    miCopy.Caption = "Copy Selection\tCtrl+C"
    miCopy.ShortCut = textToShortCut("Ctrl+C")
    miCopy.OnClick = function()
        self:copySelectedItems()
    end
    self.contextMenu.Items.add(miCopy)

    -- Copy all
    local miCopyAll = createMenuItem(self.contextMenu)
    miCopyAll.Caption = "Copy All\tCtrl+Shift+C"
    miCopyAll.ShortCut = textToShortCut("Ctrl+Shift+C")
    miCopyAll.OnClick = function()
        self:copyAllItems()
    end
    self.contextMenu.Items.add(miCopyAll)

    -- Separator
    local miSep1 = createMenuItem(self.contextMenu)
    miSep1.Caption = "-"
    self.contextMenu.Items.add(miSep1)

    -- Find
    local miFind = createMenuItem(self.contextMenu)
    miFind.Caption = "Find...\tCtrl+F"
    miFind.ShortCut = textToShortCut("Ctrl+F")
    miFind.OnClick = function()
        self:showFindDialog()
    end
    self.contextMenu.Items.add(miFind)

    -- Separator
    local miSep2 = createMenuItem(self.contextMenu)
    miSep2.Caption = "-"
    self.contextMenu.Items.add(miSep2)

    -- Clear log
    local miClear = createMenuItem(self.contextMenu)
    miClear.Caption = "Clear Log"
    miClear.OnClick = function()
        self.logs = {}
        self:refreshListView()
        self:info("Log cleared", "LogView")
    end
    self.contextMenu.Items.add(miClear)

    -- Separator
    local miSep3 = createMenuItem(self.contextMenu)
    miSep3.Caption = "-"
    self.contextMenu.Items.add(miSep3)

    -- Color settings
    local miColors = createMenuItem(self.contextMenu)
    miColors.Caption = "Color Settings..."
    miColors.OnClick = function()
        self:showColorSettingsDialog()
    end
    self.contextMenu.Items.add(miColors)

    return self.contextMenu
end

-- Show color settings dialog
function LogView:showColorSettingsDialog()
    local colorForm = createForm(false)
    colorForm.Caption = "LogView Color Settings"
    colorForm.Width = 400
    colorForm.Height = 400
    colorForm.Position = poMainFormCenter
    colorForm.BorderStyle = bsDialog

    local y = 10
    local colorEdits = {}
    local previewPanels = {}

    -- Create color inputs for each log type
    for logType, color in pairs(self.settings.colors) do
        local label = createLabel(colorForm)
        label.Parent = colorForm
        label.Caption = logType .. " Color (Hex):"
        label.Left = 10
        label.Top = y
        label.Width = 100

        local edit = createEdit(colorForm)
        edit.Parent = colorForm
        edit.Left = 120
        edit.Top = y - 2
        edit.Width = 100
        edit.Text = string.format("%06X", color)
        colorEdits[logType] = edit

        -- Color picker button
        local btnPick = createButton(colorForm)
        btnPick.Parent = colorForm
        btnPick.Left = 225
        btnPick.Top = y - 2
        btnPick.Width = 30
        btnPick.Caption = "..."
        btnPick.OnClick = function()
            local colorDialog = createColorDialog(nil)
            colorDialog.Color = tonumber("0x" .. edit.Text) or color
            if colorDialog.execute() then
                edit.Text = string.format("%06X", colorDialog.Color)
                previewPanels[logType].Color = colorDialog.Color
            end
        end

        -- Preview panel
        local preview = createPanel(colorForm)
        preview.Parent = colorForm
        preview.Left = 260
        preview.Top = y - 2
        preview.Width = 120
        preview.Height = 20
        preview.Caption = "Sample " .. logType
        preview.Color = 0xFFFFFF
        preview.Font.Color = color
        previewPanels[logType] = preview

        y = y + 30
    end

    -- Auto-hide settings
    y = y + 20
    local lblAutoHide = createLabel(colorForm)
    lblAutoHide.Parent = colorForm
    lblAutoHide.Caption = "Auto-Hide Settings:"
    lblAutoHide.Left = 10
    lblAutoHide.Top = y
    lblAutoHide.Font.Style = "[fsBold]"

    y = y + 25
    local chkAutoHide = createCheckBox(colorForm)
    chkAutoHide.Parent = colorForm
    chkAutoHide.Caption = "Enable Auto-Hide"
    chkAutoHide.Left = 10
    chkAutoHide.Top = y
    chkAutoHide.Checked = self.settings.autoHideEnabled

    y = y + 25
    local lblDelay = createLabel(colorForm)
    lblDelay.Parent = colorForm
    lblDelay.Caption = "Hide Delay (ms):"
    lblDelay.Left = 10
    lblDelay.Top = y

    local editDelay = createEdit(colorForm)
    editDelay.Parent = colorForm
    editDelay.Left = 120
    editDelay.Top = y - 2
    editDelay.Width = 100
    editDelay.Text = tostring(self.settings.autoHideDelay)

    -- Buttons
    y = y + 40
    local btnOK = createButton(colorForm)
    btnOK.Parent = colorForm
    btnOK.Caption = "OK"
    btnOK.Left = 100
    btnOK.Top = y
    btnOK.Width = 80

    local btnCancel = createButton(colorForm)
    btnCancel.Parent = colorForm
    btnCancel.Caption = "Cancel"
    btnCancel.Left = 200
    btnCancel.Top = y
    btnCancel.Width = 80

    btnOK.OnClick = function()
        -- Save colors
        for logType, edit in pairs(colorEdits) do
            local hexValue = edit.Text
            local color = tonumber("0x" .. hexValue) or self.settings.colors[logType]
            self.settings.colors[logType] = color
        end

        -- Save auto-hide settings
        self.settings.autoHideEnabled = chkAutoHide.Checked
        self.settings.autoHideDelay = tonumber(editDelay.Text) or 3000

        -- Save to address list
        self:saveSettings()

        -- Refresh display
        self:refreshListView()

        -- Update auto-hide timer
        if self.hideTimer then
            if self.settings.autoHideEnabled then
                self.hideTimer.Enabled = true
            else
                self.hideTimer.Enabled = false
                if self.statusPanel then
                    self.statusPanel.Visible = true
                end
            end
        end

        colorForm.close()
        self:info("Settings saved", "LogView")
    end

    btnCancel.OnClick = function()
        colorForm.close()
    end

    colorForm.show()
end

-- Copy selected items from ListView
function LogView:copySelectedItems()
    if not self.logListView or self.logListView.Destroyed then return end

    local text = ""
    for i = 0, self.logListView.Items.Count - 1 do
        local item = self.logListView.Items[i]
        if item.Selected then
            text = text .. string.format("%s [%s] %s\n",
                item.Caption,
                item.SubItems[0],
                item.SubItems[1])
        end
    end

    if text ~= "" then
        writeToClipboard(text)
        self:info("Selected items copied to clipboard", "LogView")
    end
end

-- Copy all items from ListView
function LogView:copyAllItems()
    local text = ""
    for i, log in ipairs(self.logs) do
        text = text .. string.format("%s [%s] %s\n", log.time, log.type, log.message)
    end

    writeToClipboard(text)
    self:info("All logs copied to clipboard", "LogView")
end

-- Create custom ListView with color support (FIXED VERSION)
function LogView:createColoredListView(parent)
    local listView = createListView(parent)
    listView.Parent = parent
    listView.Align = alClient
    listView.ViewStyle = vsReport
    listView.ReadOnly = true
    listView.RowSelect = true
    listView.GridLines = true
    listView.MultiSelect = true

    -- Add columns
    local col1 = listView.Columns.add()
    col1.Caption = "Time"
    col1.Width = 140

    local col2 = listView.Columns.add()
    col2.Caption = "Type"
    col2.Width = 80

    local col3 = listView.Columns.add()
    col3.Caption = "Message"
    col3.Width = 500
    col3.AutoSize = true

    -- Custom draw event for colors (FIXED)
    listView.OnCustomDrawItem = function(sender, item, state, defaultDraw)
        if item.Data then
            -- Force canvas update
            sender.Canvas.Brush.Style = bsClear
            sender.Canvas.Font.Color = item.Data

            -- Handle selection state
            if item.Selected then
                sender.Canvas.Brush.Color = clHighlight
                sender.Canvas.Brush.Style = bsSolid
                sender.Canvas.Font.Color = clHighlightText
            end
        end
        return defaultDraw
    end

    listView.OnCustomDrawSubItem = function(sender, item, subItem, state, defaultDraw)
        if item.Data then
            -- Force canvas update
            sender.Canvas.Brush.Style = bsClear
            sender.Canvas.Font.Color = item.Data

            -- Handle selection state
            if item.Selected then
                sender.Canvas.Brush.Color = clHighlight
                sender.Canvas.Brush.Style = bsSolid
                sender.Canvas.Font.Color = clHighlightText
            else
                -- Ensure color is applied even when not selected
                sender.Canvas.Font.Color = item.Data
            end
        end
        return defaultDraw
    end

    -- Force redraw when items are added
    listView.OnChange = function(sender, item, change)
        if change == ctState then
            sender.Invalidate()
        end
    end

    return listView
end

-- Alternative approach: Use OwnerDraw instead of CustomDraw
function LogView:createColoredListViewAlternative(parent)
    local listView = createListView(parent)
    listView.Parent = parent
    listView.Align = alClient
    listView.ViewStyle = vsReport
    listView.ReadOnly = true
    listView.RowSelect = true
    listView.GridLines = true
    listView.MultiSelect = true
    listView.OwnerDraw = true  -- Enable owner draw mode

    -- Add columns
    local col1 = listView.Columns.add()
    col1.Caption = "Time"
    col1.Width = 140

    local col2 = listView.Columns.add()
    col2.Caption = "Type"
    col2.Width = 80

    local col3 = listView.Columns.add()
    col3.Caption = "Message"
    col3.Width = 500
    col3.AutoSize = true

    -- Owner draw event (more reliable)
    listView.OnDrawItem = function(sender, item, rect, state)
        local canvas = sender.Canvas
        local color = item.Data or 0x000000

        -- Clear the rectangle
        canvas.Brush.Style = bsSolid

        -- Handle selection
        if item.Selected then
            canvas.Brush.Color = clHighlight
            canvas.Font.Color = clHighlightText
        else
            canvas.Brush.Color = clWindow
            canvas.Font.Color = color
        end

        -- Fill background
        canvas.FillRect(rect)

        -- Draw text with proper spacing
        local textRect = {}
        textRect.Left = rect.Left + 2
        textRect.Top = rect.Top + 2
        textRect.Right = rect.Right - 2
        textRect.Bottom = rect.Bottom - 2

        -- Draw each column
        local x = textRect.Left
        local colWidths = {140, 80, sender.Width - 220}
        local texts = {item.Caption, item.SubItems[0] or "", item.SubItems[1] or ""}

        for i = 1, 3 do
            local colRect = {}
            colRect.Left = x
            colRect.Top = textRect.Top
            colRect.Right = x + colWidths[i] - 4
            colRect.Bottom = textRect.Bottom

            canvas.TextRect(colRect, colRect.Left, colRect.Top, texts[i])
            x = x + colWidths[i]
        end

        -- Draw grid lines if enabled
        if sender.GridLines then
            canvas.Pen.Color = clBtnShadow
            canvas.MoveTo(rect.Left, rect.Bottom - 1)
            canvas.LineTo(rect.Right, rect.Bottom - 1)
        end
    end

    return listView
end

-- Additional fix: Force refresh after adding items
function LogView:addToListView(entry)
    if not self.logListView or self.logListView.Destroyed then return end

    local item = self.logListView.Items.add()
    item.Caption = entry.time
    item.SubItems.add(entry.type)
    item.SubItems.add(entry.message)

    -- Set color based on log type
    local color = self.settings.colors[entry.type] or 0x000000
    -- Store the color in the Data property
    item.Data = color

    -- Force immediate redraw of the item (FIX)
    self.logListView.Items.BeginUpdate()
    self.logListView.Items.EndUpdate()

    -- Alternative: Force complete refresh
    -- self.logListView.Invalidate()

    -- Auto-scroll if enabled
    if self.settings.autoScroll then
        item.MakeVisible(false)
    end

    -- Update counter
    if self.countLabel and not self.countLabel.Destroyed then
        self.countLabel.Caption = "Entries: " .. #self.logs
    end
end

-- Refresh ListView with proper color handling
function LogView:refreshListView()
    if not self.logListView or self.logListView.Destroyed then return end

    -- Begin update to prevent flickering
    self.logListView.Items.BeginUpdate()

    self.logListView.Items.clear()
    for i, log in ipairs(self.logs) do
        local item = self.logListView.Items.add()
        item.Caption = log.time
        item.SubItems.add(log.type)
        item.SubItems.add(log.message)

        -- Set color
        local color = self.settings.colors[log.type] or 0x000000
        item.Data = color
    end

    -- End update and force redraw
    self.logListView.Items.EndUpdate()
    self.logListView.Invalidate()  -- Force complete redraw

    -- Auto-scroll
    if self.settings.autoScroll and self.logListView.Items.Count &gt; 0 then
        self.logListView.Items[self.logListView.Items.Count - 1].MakeVisible(false)
    end

    -- Update counter
    if self.countLabel and not self.countLabel.Destroyed then
        self.countLabel.Caption = "Entries: " .. #self.logs
    end
end

-- Create the main log form
function LogView:createLogForm()
    if self.form and not self.form.Destroyed then
        self.form.destroy()
    end

    local mainForm = getMainForm()

    -- Create form as child of main form
    self.form = createForm(false)
    self.form.Caption = "LogView - Advanced Logging System v2.0"
    self.form.Width = 900
    self.form.Height = 500
    self.form.BorderStyle = bsSizeable

    -- Position form below CE main window
    self.form.Left = mainForm.Left
    self.form.Top = mainForm.Top + mainForm.Height

    -- Top panel with controls
    local topPanel = createPanel(self.form)
    topPanel.Parent = self.form
    topPanel.Align = alTop
    topPanel.Height = 40

    -- Button to clear logs
    local btnClear = createButton(topPanel)
    btnClear.Parent = topPanel
    btnClear.Caption = "Clear Log"
    btnClear.Left = 10
    btnClear.Top = 8
    btnClear.Width = 100
    btnClear.OnClick = function()
        self.logs = {}
        self:refreshListView()
        self:info("Log cleared", "LogView")
    end

    -- Button to save logs
    local btnSave = createButton(topPanel)
    btnSave.Parent = topPanel
    btnSave.Caption = "Save Log"
    btnSave.Left = 120
    btnSave.Top = 8
    btnSave.Width = 100
    btnSave.OnClick = function()
        self:saveLogToFile()
    end

    -- Button to copy all
    local btnCopyAll = createButton(topPanel)
    btnCopyAll.Parent = topPanel
    btnCopyAll.Caption = "Copy All"
    btnCopyAll.Left = 230
    btnCopyAll.Top = 8
    btnCopyAll.Width = 100
    btnCopyAll.OnClick = function()
        self:copyAllItems()
    end

    -- Button to restore original scripts
    local btnRestore = createButton(topPanel)
    btnRestore.Parent = topPanel
    btnRestore.Caption = "Restore Scripts"
    btnRestore.Left = 340
    btnRestore.Top = 8
    btnRestore.Width = 120
    btnRestore.OnClick = function()
        self:restoreScriptOriginals()
    end

    -- Button for color settings
    local btnColors = createButton(topPanel)
    btnColors.Parent = topPanel
    btnColors.Caption = "Settings"
    btnColors.Left = 470
    btnColors.Top = 8
    btnColors.Width = 80
    btnColors.OnClick = function()
        self:showColorSettingsDialog()
    end

    -- Label with counter
    local lblCount = createLabel(topPanel)
    lblCount.Parent = topPanel
    lblCount.Left = 560
    lblCount.Top = 12
    lblCount.Caption = "Entries: " .. #self.logs
    self.countLabel = lblCount

    -- Checkbox for auto-scroll
    local chkAutoScroll = createCheckBox(topPanel)
    chkAutoScroll.Parent = topPanel
    chkAutoScroll.Left = 650
    chkAutoScroll.Top = 10
    chkAutoScroll.Caption = "Auto-scroll"
    chkAutoScroll.Checked = self.settings.autoScroll
    chkAutoScroll.OnChange = function()
        self.settings.autoScroll = chkAutoScroll.Checked
        self:saveSettings()
    end

    -- Checkbox for auto-hide
    local chkAutoHide = createCheckBox(topPanel)
    chkAutoHide.Parent = topPanel
    chkAutoHide.Left = 750
    chkAutoHide.Top = 10
    chkAutoHide.Caption = "Auto-hide"
    chkAutoHide.Checked = self.settings.autoHideEnabled
    chkAutoHide.OnChange = function()
        self.settings.autoHideEnabled = chkAutoHide.Checked
        self:saveSettings()
        if self.hideTimer then
            if self.settings.autoHideEnabled then
                self.hideTimer.Enabled = true
            else
                self.hideTimer.Enabled = false
                if self.statusPanel then
                    self.statusPanel.Visible = true
                end
            end
        end
    end

    -- Create colored ListView
    self.logListView = self:createColoredListView(self.form)

    -- Set context menu
    self.logListView.PopupMenu = self:createContextMenu()

    -- Handler for keyboard shortcuts
    self.logListView.OnKeyDown = function(sender, key)
        if key == VK_C and isKeyPressed(VK_CONTROL) then
            if isKeyPressed(VK_SHIFT) then
                self:copyAllItems()
            else
                self:copySelectedItems()
            end
        elseif key == VK_A and isKeyPressed(VK_CONTROL) then
            -- Select all
            for i = 0, sender.Items.Count - 1 do
                sender.Items[i].Selected = true
            end
        elseif key == VK_F and isKeyPressed(VK_CONTROL) then
            -- Find
            self:showFindDialog()
        end
    end

    -- Update ListView with existing logs
    self:refreshListView()

    -- Event handler for closing
    self.form.OnClose = function()
        self.isVisible = false
        return caHide
    end
end

-- Update ListView with all logs
function LogView:refreshListView()
    if not self.logListView or self.logListView.Destroyed then return end

    self.logListView.Items.clear()
    for i, log in ipairs(self.logs) do
        local item = self.logListView.Items.add()
        item.Caption = log.time
        item.SubItems.add(log.type)
        item.SubItems.add(log.message)

        -- Set color
        local color = self.settings.colors[log.type] or 0x000000
        item.Data = color
    end

    -- Auto-scroll
    if self.settings.autoScroll and self.logListView.Items.Count &gt; 0 then
        self.logListView.Items[self.logListView.Items.Count - 1].MakeVisible(false)
    end

    -- Update counter
    if self.countLabel and not self.countLabel.Destroyed then
        self.countLabel.Caption = "Entries: " .. #self.logs
    end
end

-- Create status bar in main window
function LogView:createStatusBar()
    local mainForm = getMainForm()

    -- Container panel for both status and button
    local containerPanel = createPanel(mainForm)
    containerPanel.Parent = mainForm
    containerPanel.Align = alBottom
    containerPanel.Height = 30
    containerPanel.BevelOuter = bvNone

    -- Status panel (can be hidden)
    self.statusPanel = createPanel(containerPanel)
    self.statusPanel.Parent = containerPanel
    self.statusPanel.Align = alClient
    self.statusPanel.BevelOuter = bvLowered
    self.statusPanel.Visible = not self.settings.autoHideEnabled -- Initially hidden if auto-hide is enabled

    -- Label to show last log
    self.statusLabel = createLabel(self.statusPanel)
    self.statusLabel.Parent = self.statusPanel
    self.statusLabel.Left = 10
    self.statusLabel.Top = 7
    self.statusLabel.Width = self.statusPanel.Width - 120
    self.statusLabel.Caption = "LogView: Ready"
    self.statusLabel.Font.Name = "Consolas"
    self.statusLabel.Font.Size = 8

    -- Button panel (always visible)
    self.buttonPanel = createPanel(containerPanel)
    self.buttonPanel.Parent = containerPanel
    self.buttonPanel.Align = alRight
    self.buttonPanel.Width = 110
    self.buttonPanel.BevelOuter = bvLowered

    -- Button to show/hide log (always visible)
    self.buttonShowLog = createButton(self.buttonPanel)
    self.buttonShowLog.Parent = self.buttonPanel
    self.buttonShowLog.Caption = "Show Log"
    self.buttonShowLog.Width = 100
    self.buttonShowLog.Height = 24
    self.buttonShowLog.Top = 3
    self.buttonShowLog.Left = 5

    self.buttonShowLog.OnClick = function()
        self:toggleLogWindow()
    end

    -- Create auto-hide timer
    self:createAutoHideTimer()
end

-- Update status label
function LogView:updateStatusLabel(message)
    if self.statusLabel and not self.statusLabel.Destroyed then
        local truncated = message
        if #message &gt; 80 then
            truncated = string.sub(message, 1, 77) .. "..."
        end
        self.statusLabel.Caption = "LogView: " .. truncated
    end
end

-- Toggle log window
function LogView:toggleLogWindow()
    if not self.form or self.form.Destroyed then
        self:createLogForm()
    end

    if self.isVisible then
        self.form.hide()
        self.buttonShowLog.Caption = "Show Log"
    else
        self.form.show()
        self.buttonShowLog.Caption = "Hide Log"
        self:refreshListView()
    end
    self.isVisible = not self.isVisible
end

-- Save log to file
function LogView:saveLogToFile()
    local dialog = createSaveDialog()
    dialog.Filter = "Text files (*.txt)|*.txt|All files (*.*)|*.*"
    dialog.DefaultExt = "txt"
    dialog.FileName = "logview_" .. os.date("%Y%m%d_%H%M%S") .. ".txt"

    if dialog.execute() then
        local file = io.open(dialog.FileName, "w")
        if file then
            file:write("LogView Export - " .. os.date("%Y-%m-%d %H:%M:%S") .. "\n")
            file:write(string.rep("=", 80) .. "\n\n")

            for i, log in ipairs(self.logs) do
                file:write(string.format("%s [%s] %s\n", log.time, log.type, log.message))
            end

            file:close()
            self:success("Log saved to: " .. dialog.FileName, "LogView")
        else
            self:error("Unable to save file", "LogView")
        end
    end
    dialog.destroy()
end

-- Function to monitor AOBScan loading
function LogView:logAOBScan(name, pattern, success)
    if success then
        self:success("AOBScan '" .. name .. "' found with pattern: " .. pattern, "AOBScan")
    else
        self:error("AOBScan '" .. name .. "' not found. Pattern: " .. pattern, "AOBScan")
    end
end

-- Function to monitor symbols
function LogView:logSymbol(name, address)
    if address then
        self:success("Symbol '" .. name .. "' resolved to: " .. string.format("%X", address), "Symbol")
    else
        self:warning("Symbol '" .. name .. "' not found", "Symbol")
    end
end

-- Find main context menu for errors
function LogView:findAddressListPopup()
    local mainForm = getMainForm()
    if mainForm then
        for i = 0, mainForm.ComponentCount - 1 do
            local comp = mainForm.Component[i]
            if comp.ClassName == "TPopupMenu" and comp.Name == "PopupMenu2" then
                self.addressListPopup = comp
                break
            end
        end
    end
end

-- Search only for error message in menu
function LogView:findErrorMessage(menu)
    local items = menu.Items
    for i = 0, items.Count - 1 do
        local item = items[i]
        if item.Visible and item.Caption and item.Caption ~= "" then
            -- Search only for entries containing "error" or "Lua" (case insensitive)
            if string.find(string.lower(item.Caption), "error") or
               string.find(string.lower(item.Caption), "lua") then
                return item.Caption
            end

            -- Also search in submenus
            if item.Count &gt; 0 then
                for j = 0, item.Count - 1 do
                    local subItem = item[j]
                    if subItem.Visible and subItem.Caption and subItem.Caption ~= "" then
                        if string.find(string.lower(subItem.Caption), "error") or
                           string.find(string.lower(subItem.Caption), "lua") then
                            return subItem.Caption
                        end
                    end
                end
            end
        end
    end
    return "No error message found"
end

-- Wrapper for scripts
function LogView:makeScriptWrapper(mr)
    return function(record, before, currentstate)
        if before then
            self:info("Attempting to activate: " .. (record.Description or "No name"), "ScriptActivation")
        else
            if currentstate then
                self:success("Script activated: " .. (record.Description or "No name"), "ScriptActivation")
            else
                self:error("Script NOT activated: " .. (record.Description or "No name"), "ScriptActivation")

                -- If script doesn't activate, search only for error message
                if self.addressListPopup then
                    -- Select script in list
                    local al = getAddressList()
                    al.selectedRecord = record

                    -- Force open context menu
                    self.addressListPopup.PopupComponent = al
                    self.addressListPopup.OnPopup()

                    -- Search only for error message
                    local errorMessage = self:findErrorMessage(self.addressListPopup)
                    self:error("Error message: " .. errorMessage, "ScriptActivation")
                else
                    self:error("Context menu not found!", "ScriptActivation")
                end
            end
        end

        -- Call original if it exists
        local orig = self.scriptOriginals[tostring(mr)]
        if orig then
            return orig(record, before, currentstate)
        end

        return true
    end
end

-- Apply wrapper to all scripts
function LogView:hookScriptActivations()
    self:findAddressListPopup()

    local al = getAddressList()
    for i = 0, al.Count - 1 do
        local mr = al[i]
        if mr.Type == vtAutoAssembler then
            local key = tostring(mr)
            if not self.scriptOriginals[key] then
                self.scriptOriginals[key] = mr.OnActivate
                mr.OnActivate = self:makeScriptWrapper(mr)
            end
        end
    end

    if not self.addressListPopup then
        self:warning("Context menu not found!", "ScriptActivation")
    end

    self:info("Script Activation Logger enabled", "ScriptActivation")
end

-- Restore original OnActivate functions
function LogView:restoreScriptOriginals()
    local al = getAddressList()
    for i = 0, al.Count - 1 do
        local mr = al[i]
        if mr.Type == vtAutoAssembler then
            local key = tostring(mr)
            if self.scriptOriginals[key] then
                mr.OnActivate = self.scriptOriginals[key]
                self.scriptOriginals[key] = nil
            end
        end
    end

    self.scriptOriginals = {}
    self:info("Script Activation Logger disabled - originals restored", "ScriptActivation")
end

-- Initialization
function LogView:init()
    -- Load settings first
    self:loadSettings()

    -- Create UI components
    self:createStatusBar()
    self:hookErrors()
    self:hookScriptActivations()

    -- Log initialization
    self:info("LogView initialized successfully", "LogView")
    self:info("Version: 2.0.0 (with auto-hide, colors, and persistent settings)", "LogView")
    self:info("Settings are saved in the Address List", "LogView")

    -- Show current settings
    if self.settings.autoHideEnabled then
        self:info("Auto-hide enabled (delay: " .. self.settings.autoHideDelay .. "ms)", "LogView")
    else
        self:info("Auto-hide disabled", "LogView")
    end

    -- Example of different log types with colors
    self:success("Color support enabled", "LogView")
    self:warning("This is a warning example", "LogView")
    self:error("This is an error example", "LogView")
    self:debug("Debug mode active", "LogView")

    -- Show keyboard shortcuts
    self:info("Keyboard shortcuts: Ctrl+F (Find), Ctrl+C (Copy), Ctrl+A (Select All)", "LogView")

    -- Test timer functionality
    if self.settings.autoHideEnabled and self.statusPanel then
        self:info("Status panel will auto-hide after " .. (self.settings.autoHideDelay/1000) .. " seconds of inactivity", "LogView")
    end
end

-- Destroy everything when CE closes or script reloads
function LogView:destroy()
    -- Save settings before destroying
    self:saveSettings()

    -- Clean up UI components
    if self.form and not self.form.Destroyed then
        self.form.destroy()
    end
    if self.contextMenu and not self.contextMenu.Destroyed then
        self.contextMenu.destroy()
    end
    if self.hideTimer and not self.hideTimer.Destroyed then
        self.hideTimer.destroy()
    end

    -- Restore original functions
    _G.error = self.originalError
    _G.print = self.originalPrint
    self:restoreScriptOriginals()

    -- Don't destroy the settings record - keep it for next load
end

-- Initialize the system
LogView:init()




