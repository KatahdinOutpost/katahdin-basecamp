{$lua}
local ExtraMpRecoveryZaRegs = { "rbx", "rsi", "rdi", "rcx", "rdx", "rax", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "rbp", "rsp" }
local ExtraMpRecoveryZaRegBufferOffsets = { rbx = 8, rsi = 24, rdi = 40, rcx = 56, rdx = 72, rax = 88, r8 = 104, r9 = 120, r10 = 136, r11 = 152, r12 = 264, r13 = 280, r14 = 296, r15 = 312, rbp = 328, rsp = 344}

-- GLOBAL variables for communication between scripts
_G.ExtraMpRecoveryZaAddressEntry = nil
_G.ExtraMpRecoveryZaOriginalStaticAddress = nil
_G.ExtraMpRecoveryZaBasePointer = nil
_G.ExtraMpRecoveryZaCurrentRegister = nil

local function findOrCreateExtraMpRecoveryZaEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeExtraMpRecoveryZaStatus" then
      _G.ExtraMpRecoveryZaAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "ExtraMpRecoveryZa (Primary Array)"
  entry.Type = vtDword
  entry.Address = "seeExtraMpRecoveryZaStatus"
  _G.ExtraMpRecoveryZaAddressEntry = entry
  return entry
end

local function findOrCreateExtraMpRecoveryZaValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setExtraMpRecoveryZaValue"
  elseif "See" == "Add" then
    valueSymbolName = "addExtraMpRecoveryZaValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subExtraMpRecoveryZaValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.ExtraMpRecoveryZaValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "ExtraMpRecoveryZa Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.ExtraMpRecoveryZaValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForExtraMpRecoveryZaPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(ExtraMpRecoveryZaRegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(ExtraMpRecoveryZaRegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handleExtraMpRecoveryZaOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readInteger
  local writeFunc = writeInteger

  if operation == "Set" then
    local valueAddr = getAddressSafe("setExtraMpRecoveryZaValue")
    local value = readInteger(valueAddr)
    writeInteger(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addExtraMpRecoveryZaValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastExtraMpRecoveryZaValue then
        _G.lastExtraMpRecoveryZaValue = currentValue
      elseif currentValue &gt; _G.lastExtraMpRecoveryZaValue then
        local newValue = currentValue + value
        writeInteger(addr, newValue)
        _G.lastExtraMpRecoveryZaValue = newValue
      else
        _G.lastExtraMpRecoveryZaValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subExtraMpRecoveryZaValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastExtraMpRecoveryZaValue then
        _G.lastExtraMpRecoveryZaValue = currentValue
      elseif currentValue &gt; _G.lastExtraMpRecoveryZaValue then
        local newValue = currentValue - value
        writeInteger(addr, newValue)
        _G.lastExtraMpRecoveryZaValue = newValue
      else
        _G.lastExtraMpRecoveryZaValue = currentValue
      end
    end
  end
end

local function ExtraMpRecoveryZaTimerCallback()
  local injectionAddr = getAddressSafe("ExtraMpRecoveryZaCopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForExtraMpRecoveryZaPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeExtraMpRecoveryZa")
  if not debugBufferAddr then return end

  local bufferOffset = ExtraMpRecoveryZaRegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.ExtraMpRecoveryZaBasePointer = pointerBase
  _G.ExtraMpRecoveryZaCurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and ExtraMpRecoveryZaRegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + ExtraMpRecoveryZaRegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.ExtraMpRecoveryZaOriginalStaticAddress then
    _G.ExtraMpRecoveryZaOriginalStaticAddress = getAddressSafe("seeExtraMpRecoveryZaStatus")
  end

  unregisterSymbol("seeExtraMpRecoveryZaStatus")
  registerSymbol("seeExtraMpRecoveryZaStatus", primaryAddr)
  forceRefreshExistingEntry("seeExtraMpRecoveryZaStatus", primaryAddr)
  handleExtraMpRecoveryZaOperation(primaryAddr, "See", "4 Bytes")

  if not _G.ExtraMpRecoveryZaEntryCreated then
    findOrCreateExtraMpRecoveryZaEntry()
    _G.ExtraMpRecoveryZaEntryCreated = true
  end

  if not _G.ExtraMpRecoveryZaValueEntryCreated then
    findOrCreateExtraMpRecoveryZaValueEntry()
    _G.ExtraMpRecoveryZaValueEntryCreated = true
  end
end

if _G.unlimitedExtraMpRecoveryZaTimer and _G.unlimitedExtraMpRecoveryZaTimer.destroy then
  _G.unlimitedExtraMpRecoveryZaTimer.destroy()
  _G.unlimitedExtraMpRecoveryZaTimer = nil
end

_G.ExtraMpRecoveryZaEntryCreated = false
_G.ExtraMpRecoveryZaValueEntryCreated = false
_G.ExtraMpRecoveryZaAddressEntry = nil
_G.ExtraMpRecoveryZaOriginalStaticAddress = nil

if not _G.ExtraMpRecoveryZaBasePointer then _G.ExtraMpRecoveryZaBasePointer = nil end
if not _G.ExtraMpRecoveryZaCurrentRegister then _G.ExtraMpRecoveryZaCurrentRegister = nil end

if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.unlimitedExtraMpRecoveryZaTimer = createTimer(nil, false)
    _G.unlimitedExtraMpRecoveryZaTimer.Interval = 555
    _G.unlimitedExtraMpRecoveryZaTimer.OnTimer = ExtraMpRecoveryZaTimerCallback
    _G.unlimitedExtraMpRecoveryZaTimer.Enabled = true
  end
  startupTimer.Enabled = true
end
{$asm}

[DISABLE]

{$lua}
if _G.unlimitedExtraMpRecoveryZaTimer and _G.unlimitedExtraMpRecoveryZaTimer.destroy then
  _G.unlimitedExtraMpRecoveryZaTimer.destroy()
  _G.unlimitedExtraMpRecoveryZaTimer = nil
end

if _G.ExtraMpRecoveryZaOriginalStaticAddress then
  unregisterSymbol("seeExtraMpRecoveryZaStatus")
  registerSymbol("seeExtraMpRecoveryZaStatus", _G.ExtraMpRecoveryZaOriginalStaticAddress)

  if _G.ExtraMpRecoveryZaAddressEntry then
    _G.ExtraMpRecoveryZaAddressEntry.Address = string.format("0x%X", _G.ExtraMpRecoveryZaOriginalStaticAddress)
    sleep(1)
    _G.ExtraMpRecoveryZaAddressEntry.Address = "seeExtraMpRecoveryZaStatus"
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeExtraMpRecoveryZaStatus")
  if allocatedAddr then
    unregisterSymbol("seeExtraMpRecoveryZaStatus")
    registerSymbol("seeExtraMpRecoveryZaStatus", allocatedAddr)

    if _G.ExtraMpRecoveryZaAddressEntry then
      _G.ExtraMpRecoveryZaAddressEntry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      _G.ExtraMpRecoveryZaAddressEntry.Address = "seeExtraMpRecoveryZaStatus"
    end
  end
end

_G.ExtraMpRecoveryZaEntryCreated = false
_G.ExtraMpRecoveryZaValueEntryCreated = false
_G.ExtraMpRecoveryZaAddressEntry = nil
_G.ExtraMpRecoveryZaOriginalStaticAddress = nil

_G.ExtraMpRecoveryZaBasePointer = nil
_G.ExtraMpRecoveryZaCurrentRegister = nil
_G.lastExtraMpRecoveryZaValue = nil

{$asm}

ExtraMpRecoveryZa:
{$lua}
local totalBytes = _G.ExtraMpRecoveryZaTotalBytes or 8
return string.format("readmem(ExtraMpRecoveryZaCopy, %d)", totalBytes)
{$asm}
