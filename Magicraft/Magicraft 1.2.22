return:

{$lua}
local PlayerIDRegs = { "rbx", "rsi", "rdi", "rcx", "rdx", "rax", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "rbp", "rsp" }
local PlayerIDRegBufferOffsets = { rbx = 8, rsi = 24, rdi = 40, rcx = 56, rdx = 72, rax = 88, r8 = 104, r9 = 120, r10 = 136, r11 = 152, r12 = 264, r13 = 280, r14 = 296, r15 = 312, rbp = 328, rsp = 344}

-- GLOBAL variables for communication between scripts
_G.PlayerIDAddressEntry = nil
_G.PlayerIDOriginalStaticAddress = nil
_G.PlayerIDBasePointer = nil
_G.PlayerIDCurrentRegister = nil

local function findOrCreatePlayerIDEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seePlayerIDStatus" then
      _G.PlayerIDAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "PlayerID (Primary Array)"
  entry.Type = vtSingle
  entry.Address = "seePlayerIDStatus"
  _G.PlayerIDAddressEntry = entry
  return entry
end

local function findOrCreatePlayerIDValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setPlayerIDValue"
  elseif "See" == "Add" then
    valueSymbolName = "addPlayerIDValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subPlayerIDValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.PlayerIDValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "PlayerID Value (See)"
  entry.Type = vtSingle
  entry.Address = valueSymbolName
  _G.PlayerIDValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForPlayerIDPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(PlayerIDRegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(PlayerIDRegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handlePlayerIDOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readFloat
  local writeFunc = writeFloat

  if operation == "Set" then
    local valueAddr = getAddressSafe("setPlayerIDValue")
    local value = readFloat(valueAddr)
    writeFloat(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addPlayerIDValue")
    local value = readFloat(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastPlayerIDValue then
        _G.lastPlayerIDValue = currentValue
      elseif currentValue &gt; _G.lastPlayerIDValue then
        local newValue = currentValue + value
        writeFloat(addr, newValue)
        _G.lastPlayerIDValue = newValue
      else
        _G.lastPlayerIDValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subPlayerIDValue")
    local value = readFloat(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastPlayerIDValue then
        _G.lastPlayerIDValue = currentValue
      elseif currentValue &gt; _G.lastPlayerIDValue then
        local newValue = currentValue - value
        writeFloat(addr, newValue)
        _G.lastPlayerIDValue = newValue
      else
        _G.lastPlayerIDValue = currentValue
      end
    end
  end
end

local function PlayerIDTimerCallback()
  local injectionAddr = getAddressSafe("PlayerIDCopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForPlayerIDPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seePlayerID")
  if not debugBufferAddr then return end

  local bufferOffset = PlayerIDRegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.PlayerIDBasePointer = pointerBase
  _G.PlayerIDCurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and PlayerIDRegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + PlayerIDRegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.PlayerIDOriginalStaticAddress then
    _G.PlayerIDOriginalStaticAddress = getAddressSafe("seePlayerIDStatus")
  end

  unregisterSymbol("seePlayerIDStatus")
  registerSymbol("seePlayerIDStatus", primaryAddr)
  forceRefreshExistingEntry("seePlayerIDStatus", primaryAddr)
  handlePlayerIDOperation(primaryAddr, "See", "Float")

  if not _G.PlayerIDEntryCreated then
    findOrCreatePlayerIDEntry()
    _G.PlayerIDEntryCreated = true
  end

  if not _G.PlayerIDValueEntryCreated then
    findOrCreatePlayerIDValueEntry()
    _G.PlayerIDValueEntryCreated = true
  end
end

if _G.unlimitedPlayerIDTimer and _G.unlimitedPlayerIDTimer.destroy then
  _G.unlimitedPlayerIDTimer.destroy()
  _G.unlimitedPlayerIDTimer = nil
end

_G.PlayerIDEntryCreated = false
_G.PlayerIDValueEntryCreated = false
_G.PlayerIDAddressEntry = nil
_G.PlayerIDOriginalStaticAddress = nil

if not _G.PlayerIDBasePointer then _G.PlayerIDBasePointer = nil end
if not _G.PlayerIDCurrentRegister then _G.PlayerIDCurrentRegister = nil end

if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.unlimitedPlayerIDTimer = createTimer(nil, false)
    _G.unlimitedPlayerIDTimer.Interval = 555
    _G.unlimitedPlayerIDTimer.OnTimer = PlayerIDTimerCallback
    _G.unlimitedPlayerIDTimer.Enabled = true
  end
  startupTimer.Enabled = true
end
{$asm}

[DISABLE]

{$lua}
if _G.unlimitedPlayerIDTimer and _G.unlimitedPlayerIDTimer.destroy then
  _G.unlimitedPlayerIDTimer.destroy()
  _G.unlimitedPlayerIDTimer = nil
end

if _G.PlayerIDOriginalStaticAddress then
  unregisterSymbol("seePlayerIDStatus")
  registerSymbol("seePlayerIDStatus", _G.PlayerIDOriginalStaticAddress)

  if _G.PlayerIDAddressEntry then
    _G.PlayerIDAddressEntry.Address = string.format("0x%X", _G.PlayerIDOriginalStaticAddress)
    sleep(1)
    _G.PlayerIDAddressEntry.Address = "seePlayerIDStatus"
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seePlayerIDStatus")
  if allocatedAddr then
    unregisterSymbol("seePlayerIDStatus")
    registerSymbol("seePlayerIDStatus", allocatedAddr)

    if _G.PlayerIDAddressEntry then
      _G.PlayerIDAddressEntry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      _G.PlayerIDAddressEntry.Address = "seePlayerIDStatus"
    end
  end
end

_G.PlayerIDEntryCreated = false
_G.PlayerIDValueEntryCreated = false
_G.PlayerIDAddressEntry = nil
_G.PlayerIDOriginalStaticAddress = nil

_G.PlayerIDBasePointer = nil
_G.PlayerIDCurrentRegister = nil
_G.lastPlayerIDValue = nil

{$asm}

PlayerID:
{$lua}
local totalBytes = _G.PlayerIDTotalBytes or 8
return string.format("readmem(PlayerIDCopy, %d)", totalBytes)
{$asm}
unregistersymbol(*)
dealloc(*)

{$lua}
_G.PlayerIDTotalBytes = nil
_G.PlayerIDNopCount = nil
_G.PlayerIDReadmemInstruction = nil
_G.PlayerIDNopInstructions = nil
{$asm}


