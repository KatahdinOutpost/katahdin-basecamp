local function findOrCreateAncientBloodOnPickUpAaEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeAncientBloodOnPickUpAaStatus" then
      _G.AncientBloodOnPickUpAaAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "AncientBloodOnPickUpAa (Primary Array)"
  entry.Type = vtDword
  entry.Address = "seeAncientBloodOnPickUpAaStatus"
  _G.AncientBloodOnPickUpAaAddressEntry = entry
  return entry
end

local function findOrCreateAncientBloodOnPickUpAaValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setAncientBloodOnPickUpAaValue"
  elseif "See" == "Add" then
    valueSymbolName = "addAncientBloodOnPickUpAaValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subAncientBloodOnPickUpAaValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.AncientBloodOnPickUpAaValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "AncientBloodOnPickUpAa Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.AncientBloodOnPickUpAaValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForAncientBloodOnPickUpAaPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(AncientBloodOnPickUpAaRegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(AncientBloodOnPickUpAaRegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handleAncientBloodOnPickUpAaOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readInteger
  local writeFunc = writeInteger

  if operation == "Set" then
    local valueAddr = getAddressSafe("setAncientBloodOnPickUpAaValue")
    local value = readInteger(valueAddr)
    writeInteger(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addAncientBloodOnPickUpAaValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastAncientBloodOnPickUpAaValue then
        _G.lastAncientBloodOnPickUpAaValue = currentValue
      elseif currentValue &gt; _G.lastAncientBloodOnPickUpAaValue then
        local newValue = currentValue + value
        writeInteger(addr, newValue)
        _G.lastAncientBloodOnPickUpAaValue = newValue
      else
        _G.lastAncientBloodOnPickUpAaValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subAncientBloodOnPickUpAaValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastAncientBloodOnPickUpAaValue then
        _G.lastAncientBloodOnPickUpAaValue = currentValue
      elseif currentValue &gt; _G.lastAncientBloodOnPickUpAaValue then
        local newValue = currentValue - value
        writeInteger(addr, newValue)
        _G.lastAncientBloodOnPickUpAaValue = newValue
      else
        _G.lastAncientBloodOnPickUpAaValue = currentValue
      end
    end
  end
end

local function AncientBloodOnPickUpAaTimerCallback()
  local injectionAddr = getAddressSafe("AncientBloodOnPickUpAaCopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForAncientBloodOnPickUpAaPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeAncientBloodOnPickUpAa")
  if not debugBufferAddr then return end

  local bufferOffset = AncientBloodOnPickUpAaRegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.AncientBloodOnPickUpAaBasePointer = pointerBase
  _G.AncientBloodOnPickUpAaCurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and AncientBloodOnPickUpAaRegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + AncientBloodOnPickUpAaRegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.AncientBloodOnPickUpAaOriginalStaticAddress then
    _G.AncientBloodOnPickUpAaOriginalStaticAddress = getAddressSafe("seeAncientBloodOnPickUpAaStatus")
  end

  unregisterSymbol("seeAncientBloodOnPickUpAaStatus")
  registerSymbol("seeAncientBloodOnPickUpAaStatus", primaryAddr)
  forceRefreshExistingEntry("seeAncientBloodOnPickUpAaStatus", primaryAddr)
  handleAncientBloodOnPickUpAaOperation(primaryAddr, "See", "4 Bytes")

  if not _G.AncientBloodOnPickUpAaEntryCreated then
    findOrCreateAncientBloodOnPickUpAaEntry()
    _G.AncientBloodOnPickUpAaEntryCreated = true
  end

  if not _G.AncientBloodOnPickUpAaValueEntryCreated then
    findOrCreateAncientBloodOnPickUpAaValueEntry()
    _G.AncientBloodOnPickUpAaValueEntryCreated = true
  end
end

