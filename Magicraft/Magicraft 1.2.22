alloc(CoinCountWhenChangeAreaACopy,30)
registersymbol(CoinCountWhenChangeAreaACopy)
alloc(seeCoinCountWhenChangeAreaAStatus,8)
registersymbol(seeCoinCountWhenChangeAreaAStatus)
seeCoinCountWhenChangeAreaAStatus:
dq 0

CoinCountWhenChangeAreaACopy:
  readmem(CoinCountWhenChangeAreaA,30)

{$lua}
-- Register list (same as Script 1)
local ExtraMoveSpeedZaRegs = { "rax", "rbx", "rcx", "rdx", "rsi", "rdi",  "r8",  "r9",  "r10",  "r11",  "r12",  "r13",  "r14",  "r15", "rbp",  "rsp"  }

-- Store references
_G.CoinCountWhenChangeAreaAAddressEntry = nil
_G.CoinCountWhenChangeAreaAOriginalStaticAddress = nil
_G.LastCoinCountWhenChangeAreaAInjectionCheck = 0

local function findOrCreateCoinCountWhenChangeAreaAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setCoinCountWhenChangeAreaAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addCoinCountWhenChangeAreaAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subCoinCountWhenChangeAreaAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.CoinCountWhenChangeAreaAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "CoinCountWhenChangeAreaA Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.CoinCountWhenChangeAreaAValueAddressEntry = entry
  return entry
end

local function scanForCoinCountWhenChangeAreaAOffset(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(ExtraMoveSpeedZaRegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return tonumber(hexOffset,16) end
        for _, reg2 in ipairs(ExtraMoveSpeedZaRegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              return tonumber(hexOffset2,16)
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return 0
end

local function CoinCountWhenChangeAreaAArrayMonitor()
  -- Check if Script 1 is still active
  if not _G.unlimitedExtraMoveSpeedZaTimer then
   -- print("Warning: Script 1 is no longer active!")
    return
  end

  local CoinCountWhenChangeAreaAInjectionAddr = getAddressSafe("CoinCountWhenChangeAreaACopy")
  if not CoinCountWhenChangeAreaAInjectionAddr then return end

  -- Check if CoinCountWhenChangeAreaA array has been executed recently (event occurred)
  local currentCoinCountWhenChangeAreaACheck = readInteger(CoinCountWhenChangeAreaAInjectionAddr)

  -- If CoinCountWhenChangeAreaA array was executed (new event), update cached offset
  if currentCoinCountWhenChangeAreaACheck ~= _G.LastCoinCountWhenChangeAreaAInjectionCheck then
    local foundCoinCountWhenChangeAreaAOffset = scanForCoinCountWhenChangeAreaAOffset(CoinCountWhenChangeAreaAInjectionAddr, 8)
    if foundCoinCountWhenChangeAreaAOffset and foundCoinCountWhenChangeAreaAOffset ~= 0 then
      _G.CachedCoinCountWhenChangeAreaAOffset = foundCoinCountWhenChangeAreaAOffset
      --print(string.format("CoinCountWhenChangeAreaA offset found and cached: 0x%X", foundCoinCountWhenChangeAreaAOffset))
    --  print("Script 1 will now handle CoinCountWhenChangeAreaA value using See operation with this offset!")

      -- Store the original static address for cleanup
      if not _G.CoinCountWhenChangeAreaAOriginalStaticAddress then
        _G.CoinCountWhenChangeAreaAOriginalStaticAddress = getAddressSafe("seeCoinCountWhenChangeAreaAStatus")
      end
    end
    _G.LastCoinCountWhenChangeAreaAInjectionCheck = currentCoinCountWhenChangeAreaACheck
  end
end

-- Cleanup any existing secondary timer first
if _G.CoinCountWhenChangeAreaAArrayTimer and _G.CoinCountWhenChangeAreaAArrayTimer.destroy then
  _G.CoinCountWhenChangeAreaAArrayTimer.destroy()
  _G.CoinCountWhenChangeAreaAArrayTimer = nil
end

-- Reset variables
_G.CoinCountWhenChangeAreaAAddressEntry = nil
_G.CoinCountWhenChangeAreaAOriginalStaticAddress = nil
_G.LastCoinCountWhenChangeAreaAInjectionCheck = 0

-- Create secondary monitoring timer
if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.CoinCountWhenChangeAreaAArrayTimer = createTimer(nil, false)
    _G.CoinCountWhenChangeAreaAArrayTimer.Interval = 25
    _G.CoinCountWhenChangeAreaAArrayTimer.OnTimer = CoinCountWhenChangeAreaAArrayMonitor
    _G.CoinCountWhenChangeAreaAArrayTimer.Enabled = true

    findOrCreateCoinCountWhenChangeAreaAValueEntry()

    --print("Script 3 (CoinCountWhenChangeAreaA) is now monitoring for events...")
    --print("Values will be handled by Script 1 using See operation when offset is found.")
  end
  startupTimer.Enabled = true
end
{$asm}

[DISABLE]

{$lua}
-- Stop and destroy secondary timer
if _G.CoinCountWhenChangeAreaAArrayTimer and _G.CoinCountWhenChangeAreaAArrayTimer.destroy then
  _G.CoinCountWhenChangeAreaAArrayTimer.destroy()
  _G.CoinCountWhenChangeAreaAArrayTimer = nil
end

-- IMPORTANT: Reset the secondary symbol to its original static address
if _G.CoinCountWhenChangeAreaAOriginalStaticAddress then
  unregisterSymbol("seeCoinCountWhenChangeAreaAStatus")
  registerSymbol("seeCoinCountWhenChangeAreaAStatus", _G.CoinCountWhenChangeAreaAOriginalStaticAddress)

  -- Find and force refresh any existing secondary entry
  local addrList = getAddressList()
  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeCoinCountWhenChangeAreaAStatus" then
      -- Force refresh the entry to use the static address
      entry.Address = string.format("0x%X", _G.CoinCountWhenChangeAreaAOriginalStaticAddress)
      sleep(1)
      entry.Address = "seeCoinCountWhenChangeAreaAStatus"
      break
    end
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeCoinCountWhenChangeAreaAStatus")
  if allocatedAddr then
    unregisterSymbol("seeCoinCountWhenChangeAreaAStatus")
    registerSymbol("seeCoinCountWhenChangeAreaAStatus", allocatedAddr)

  -- Force refresh any existing entry
  local addrList = getAddressList()
  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeCoinCountWhenChangeAreaAStatus" then
      entry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      entry.Address = "seeCoinCountWhenChangeAreaAStatus"
      break
    end
  end
  end
end

-- Don't remove value entry from address list to keep it visible
if _G.CoinCountWhenChangeAreaAValueAddressEntry then
  _G.CoinCountWhenChangeAreaAValueAddressEntry = nil
end

-- Reset secondary variables
_G.CoinCountWhenChangeAreaAAddressEntry = nil
_G.CoinCountWhenChangeAreaAOriginalStaticAddress = nil
_G.LastCoinCountWhenChangeAreaAInjectionCheck = 0
_G.lastCoinCountWhenChangeAreaAValue = nil

-- Clear the cached offset so Script 1 stops handling secondary values
_G.CachedCoinCountWhenChangeAreaAOffset = nil

--print("Script 3 (CoinCountWhenChangeAreaA) disabled. Secondary pointer reset to static address.")
