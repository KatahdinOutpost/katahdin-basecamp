          <Description>"see Extra Mp Recovery Speed on Use"</Description>
          <Options moHideChildren="1"/>
          <Color>00FF00</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
function aob_register(sym, patterns)
    if type(patterns) == "string" then
        patterns = {patterns}
    end

    local lastError = ""
    for _, pat in ipairs(patterns) do
        local instr = AOBScan(pat, "+X")
        if instr and instr.Count &gt; 0 then
            local addy = instr[0]
            instr.destroy()
            unregisterSymbol(sym)
            registerSymbol(sym, tonumber(addy,16))
            return true
        else
            if instr then instr.destroy() end
            lastError = lastError .. "Pattern not found: " .. pat .. "\n"
        end
    end

    error('No patterns found!\n' .. lastError)
end

function calculateInstructionDetails(address)
    local totalSize = 0
    local instructionCount = 0
    local currentAddr = tonumber(address)

    while totalSize &lt; 5 do
        local size = getInstructionSize(currentAddr)
        if not size or size == 0 then
            error('Could not determine instruction size at address: ' .. string.format('0x%X', currentAddr))
        end
        totalSize = totalSize + size
        currentAddr = currentAddr + size
        instructionCount = instructionCount + 1
    end

    local nopCount = totalSize - 5
    return totalSize, nopCount, instructionCount
end
aob_register("ExtraMpRecoveryZa", {"F3 0F 58 B0 8C"
, "F3 0F ?? ?? ?? ?? 00 00 F3 0F ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 00 48 8B ?? ?? ?? ?? ?? ?? ?? ?? 00 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? C0"
, "F3 ?? ?? ?? ?? ?? ?? ?? F3 0F ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 48 8B ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? C0 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 48"
, "F3 ?? ?? ?? ?? ?? ?? ?? F3 ?? ?? ?? ?? ?? ?? ?? 84 ?? 75 ?? 48 8D ?? ?? ?? ?? ?? E8 ?? ?? ?? ?? B2 ?? 88 ?? ?? ?? ?? ?? 48 8B ?? ?? ?? ?? ?? 48 8B ?? ?? ?? ?? ?? 48 8B"
, "F3 ?? ?? ?? ?? ?? ?? ?? F3 ?? ?? ?? ?? ?? ?? ?? 84 ?? 75 ?? 48 ?? ?? ?? ?? ?? ?? E8 ?? ?? ?? ?? B2 ?? 88 ?? ?? ?? ?? ?? 48 ?? ?? ?? ?? ?? ?? 48 ?? ?? ?? ?? ?? ?? 48 ?? ?? 48 ?? ?? 0F ?? ?? ?? ?? ?? 48 ?? ?? ?? 48 ?? ?? 0F ?? ?? ?? ?? ?? 48 ?? ?? ?? ?? ?? ?? ?? 74 ?? 84 ?? 75 ??"})
local ExtraMpRecoveryZaAddr = getAddressSafe("ExtraMpRecoveryZa")
if not ExtraMpRecoveryZaAddr then error('ExtraMpRecoveryZa address not found!') end
local totalBytes, nopCount, instCount = calculateInstructionDetails(ExtraMpRecoveryZaAddr)
_G.ExtraMpRecoveryZaTotalBytes = totalBytes
_G.ExtraMpRecoveryZaNopCount = nopCount
_G.ExtraMpRecoveryZaReadmemInstruction = string.format("readmem(ExtraMpRecoveryZa,%d)", totalBytes)
-- To force bytes manually, uncomment the following line:
-- _G.ExtraMpRecoveryZaReadmemInstruction = "readmem(ExtraMpRecoveryZa, 8)" -- Replace 8 with desired byte count
_G.ExtraMpRecoveryZaNopInstructions = ""
if nopCount &gt; 0 then
  for i = 1, nopCount do
    _G.ExtraMpRecoveryZaNopInstructions = _G.ExtraMpRecoveryZaNopInstructions .. "nop\n"
  end
  _G.ExtraMpRecoveryZaNopInstructions = _G.ExtraMpRecoveryZaNopInstructions:sub(1, -2)
end
