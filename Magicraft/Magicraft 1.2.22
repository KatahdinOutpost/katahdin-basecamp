if _G.unlimitedChaosCoreCountWhenChangeAreaATimer and _G.unlimitedChaosCoreCountWhenChangeAreaATimer.destroy then
  _G.unlimitedChaosCoreCountWhenChangeAreaATimer.destroy()
  _G.unlimitedChaosCoreCountWhenChangeAreaATimer = nil
end

if _G.ChaosCoreCountWhenChangeAreaAOriginalStaticAddress then
  unregisterSymbol("seeChaosCoreCountWhenChangeAreaAStatus")
  registerSymbol("seeChaosCoreCountWhenChangeAreaAStatus", _G.ChaosCoreCountWhenChangeAreaAOriginalStaticAddress)

  if _G.ChaosCoreCountWhenChangeAreaAAddressEntry then
    _G.ChaosCoreCountWhenChangeAreaAAddressEntry.Address = string.format("0x%X", _G.ChaosCoreCountWhenChangeAreaAOriginalStaticAddress)
    sleep(1)
    _G.ChaosCoreCountWhenChangeAreaAAddressEntry.Address = "seeChaosCoreCountWhenChangeAreaAStatus"
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeChaosCoreCountWhenChangeAreaAStatus")
  if allocatedAddr then
    unregisterSymbol("seeChaosCoreCountWhenChangeAreaAStatus")
    registerSymbol("seeChaosCoreCountWhenChangeAreaAStatus", allocatedAddr)

    if _G.ChaosCoreCountWhenChangeAreaAAddressEntry then
      _G.ChaosCoreCountWhenChangeAreaAAddressEntry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      _G.ChaosCoreCountWhenChangeAreaAAddressEntry.Address = "seeChaosCoreCountWhenChangeAreaAStatus"
    end
  end
end

_G.ChaosCoreCountWhenChangeAreaAEntryCreated = false
_G.ChaosCoreCountWhenChangeAreaAValueEntryCreated = false
_G.ChaosCoreCountWhenChangeAreaAAddressEntry = nil
_G.ChaosCoreCountWhenChangeAreaAOriginalStaticAddress = nil

_G.ChaosCoreCountWhenChangeAreaABasePointer = nil
