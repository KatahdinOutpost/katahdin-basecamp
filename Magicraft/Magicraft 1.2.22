{$lua}
local MagicCrystalsOnPickUpAaRegs = { "rbx", "rsi", "rdi", "rcx", "rdx", "rax", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15", "rbp", "rsp" }
local MagicCrystalsOnPickUpAaRegBufferOffsets = { rbx = 8, rsi = 24, rdi = 40, rcx = 56, rdx = 72, rax = 88, r8 = 104, r9 = 120, r10 = 136, r11 = 152, r12 = 264, r13 = 280, r14 = 296, r15 = 312, rbp = 328, rsp = 344}

-- GLOBAL variables for communication between scripts
_G.MagicCrystalsOnPickUpAaAddressEntry = nil
_G.MagicCrystalsOnPickUpAaOriginalStaticAddress = nil
_G.MagicCrystalsOnPickUpAaBasePointer = nil
_G.MagicCrystalsOnPickUpAaCurrentRegister = nil

local function findOrCreateMagicCrystalsOnPickUpAaEntry()
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeMagicCrystalsOnPickUpAaStatus" then
      _G.MagicCrystalsOnPickUpAaAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "MagicCrystalsOnPickUpAa (Primary Array)"
  entry.Type = vtDword
  entry.Address = "seeMagicCrystalsOnPickUpAaStatus"
  _G.MagicCrystalsOnPickUpAaAddressEntry = entry
  return entry
end

local function findOrCreateMagicCrystalsOnPickUpAaValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setMagicCrystalsOnPickUpAaValue"
  elseif "See" == "Add" then
    valueSymbolName = "addMagicCrystalsOnPickUpAaValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subMagicCrystalsOnPickUpAaValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.MagicCrystalsOnPickUpAaValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "MagicCrystalsOnPickUpAa Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.MagicCrystalsOnPickUpAaValueAddressEntry = entry
  return entry
end

local function forceRefreshExistingEntry(symbolName, newAddress)
  local addrList = getAddressList()

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == symbolName then
      entry.Address = string.format("0x%X", newAddress)
      sleep(1)
      entry.Address = symbolName
      return true
    end
  end
  return false
end

local function scanForMagicCrystalsOnPickUpAaPattern(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(MagicCrystalsOnPickUpAaRegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return reg, tonumber(hexOffset,16), nil end
        for _, reg2 in ipairs(MagicCrystalsOnPickUpAaRegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              -- Return base reg, offset, and second reg so caller can add reg2 value
              return reg, tonumber(hexOffset2,16), reg2
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return nil, 0, nil
end

local function handleMagicCrystalsOnPickUpAaOperation(addr, operation, typeStr)
  if operation == "See" then
    -- Modalità See: non fare nulla, solo visualizzazione
    return
  end

  local readFunc = readInteger
  local writeFunc = writeInteger

  if operation == "Set" then
    local valueAddr = getAddressSafe("setMagicCrystalsOnPickUpAaValue")
    local value = readInteger(valueAddr)
    writeInteger(addr, value)
  elseif operation == "Add" then
    local valueAddr = getAddressSafe("addMagicCrystalsOnPickUpAaValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastMagicCrystalsOnPickUpAaValue then
        _G.lastMagicCrystalsOnPickUpAaValue = currentValue
      elseif currentValue &gt; _G.lastMagicCrystalsOnPickUpAaValue then
        local newValue = currentValue + value
        writeInteger(addr, newValue)
        _G.lastMagicCrystalsOnPickUpAaValue = newValue
      else
        _G.lastMagicCrystalsOnPickUpAaValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subMagicCrystalsOnPickUpAaValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastMagicCrystalsOnPickUpAaValue then
        _G.lastMagicCrystalsOnPickUpAaValue = currentValue
      elseif currentValue &gt; _G.lastMagicCrystalsOnPickUpAaValue then
        local newValue = currentValue - value
        writeInteger(addr, newValue)
        _G.lastMagicCrystalsOnPickUpAaValue = newValue
      else
        _G.lastMagicCrystalsOnPickUpAaValue = currentValue
      end
    end
  end
end

local function MagicCrystalsOnPickUpAaTimerCallback()
  local injectionAddr = getAddressSafe("MagicCrystalsOnPickUpAaCopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForMagicCrystalsOnPickUpAaPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeMagicCrystalsOnPickUpAa")
  if not debugBufferAddr then return end

  local bufferOffset = MagicCrystalsOnPickUpAaRegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.MagicCrystalsOnPickUpAaBasePointer = pointerBase
  _G.MagicCrystalsOnPickUpAaCurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and MagicCrystalsOnPickUpAaRegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + MagicCrystalsOnPickUpAaRegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.MagicCrystalsOnPickUpAaOriginalStaticAddress then
    _G.MagicCrystalsOnPickUpAaOriginalStaticAddress = getAddressSafe("seeMagicCrystalsOnPickUpAaStatus")
  end

  unregisterSymbol("seeMagicCrystalsOnPickUpAaStatus")
  registerSymbol("seeMagicCrystalsOnPickUpAaStatus", primaryAddr)
  forceRefreshExistingEntry("seeMagicCrystalsOnPickUpAaStatus", primaryAddr)
  handleMagicCrystalsOnPickUpAaOperation(primaryAddr, "See", "4 Bytes")

  if not _G.MagicCrystalsOnPickUpAaEntryCreated then
    findOrCreateMagicCrystalsOnPickUpAaEntry()
    _G.MagicCrystalsOnPickUpAaEntryCreated = true
  end

  if not _G.MagicCrystalsOnPickUpAaValueEntryCreated then
    findOrCreateMagicCrystalsOnPickUpAaValueEntry()
    _G.MagicCrystalsOnPickUpAaValueEntryCreated = true
  end
end

if _G.unlimitedMagicCrystalsOnPickUpAaTimer and _G.unlimitedMagicCrystalsOnPickUpAaTimer.destroy then
  _G.unlimitedMagicCrystalsOnPickUpAaTimer.destroy()
  _G.unlimitedMagicCrystalsOnPickUpAaTimer = nil
end

_G.MagicCrystalsOnPickUpAaEntryCreated = false
_G.MagicCrystalsOnPickUpAaValueEntryCreated = false
_G.MagicCrystalsOnPickUpAaAddressEntry = nil
_G.MagicCrystalsOnPickUpAaOriginalStaticAddress = nil

if not _G.MagicCrystalsOnPickUpAaBasePointer then _G.MagicCrystalsOnPickUpAaBasePointer = nil end
if not _G.MagicCrystalsOnPickUpAaCurrentRegister then _G.MagicCrystalsOnPickUpAaCurrentRegister = nil end

if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.unlimitedMagicCrystalsOnPickUpAaTimer = createTimer(nil, false)
    _G.unlimitedMagicCrystalsOnPickUpAaTimer.Interval = 555
    _G.unlimitedMagicCrystalsOnPickUpAaTimer.OnTimer = MagicCrystalsOnPickUpAaTimerCallback
    _G.unlimitedMagicCrystalsOnPickUpAaTimer.Enabled = true
  end
  startupTimer.Enabled = true
end
{$asm}

[DISABLE]

{$lua}
if _G.unlimitedMagicCrystalsOnPickUpAaTimer and _G.unlimitedMagicCrystalsOnPickUpAaTimer.destroy then
  _G.unlimitedMagicCrystalsOnPickUpAaTimer.destroy()
  _G.unlimitedMagicCrystalsOnPickUpAaTimer = nil
end

if _G.MagicCrystalsOnPickUpAaOriginalStaticAddress then
  unregisterSymbol("seeMagicCrystalsOnPickUpAaStatus")
  registerSymbol("seeMagicCrystalsOnPickUpAaStatus", _G.MagicCrystalsOnPickUpAaOriginalStaticAddress)

  if _G.MagicCrystalsOnPickUpAaAddressEntry then
    _G.MagicCrystalsOnPickUpAaAddressEntry.Address = string.format("0x%X", _G.MagicCrystalsOnPickUpAaOriginalStaticAddress)
    sleep(1)
    _G.MagicCrystalsOnPickUpAaAddressEntry.Address = "seeMagicCrystalsOnPickUpAaStatus"
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeMagicCrystalsOnPickUpAaStatus")
  if allocatedAddr then
    unregisterSymbol("seeMagicCrystalsOnPickUpAaStatus")
    registerSymbol("seeMagicCrystalsOnPickUpAaStatus", allocatedAddr)

    if _G.MagicCrystalsOnPickUpAaAddressEntry then
      _G.MagicCrystalsOnPickUpAaAddressEntry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      _G.MagicCrystalsOnPickUpAaAddressEntry.Address = "seeMagicCrystalsOnPickUpAaStatus"
    end
  end
end

_G.MagicCrystalsOnPickUpAaEntryCreated = false
_G.MagicCrystalsOnPickUpAaValueEntryCreated = false
_G.MagicCrystalsOnPickUpAaAddressEntry = nil
_G.MagicCrystalsOnPickUpAaOriginalStaticAddress = nil

_G.MagicCrystalsOnPickUpAaBasePointer = nil
_G.MagicCrystalsOnPickUpAaCurrentRegister = nil
_G.lastMagicCrystalsOnPickUpAaValue = nil

{$asm}

MagicCrystalsOnPickUpAa:
{$lua}
local totalBytes = _G.MagicCrystalsOnPickUpAaTotalBytes or 8
return string.format("readmem(MagicCrystalsOnPickUpAaCopy, %d)", totalBytes)
{$asm}
