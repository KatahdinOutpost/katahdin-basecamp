            <CheatEntry>
              <ID>17824</ID>
              <Description>"see Key Count when Change Area"</Description>
              <Options moHideChildren="1"/>
              <Color>00FF00</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

-- Check if Script 1 is active
if not _G.unlimitedExtraMoveSpeedZaTimer then
  error("Script 1 (Primary Array) must be activated first!")
end

function aob_register(sym, patterns)
    if type(patterns) == "string" then
        patterns = {patterns}
    end

    local lastError = ""
    for _, pat in ipairs(patterns) do
        local instr = AOBScan(pat, "+X")
        if instr and instr.Count &gt; 0 then
            local addy = instr[0]
            instr.destroy()
            unregisterSymbol(sym)
            registerSymbol(sym, tonumber(addy,16))
            return true
        else
            if instr then instr.destroy() end
            lastError = lastError .. "Pattern not found: " .. pat .. "\n"
        end
    end

    error('No patterns found!\n' .. lastError)
end

aob_register("KeyCountWhenChangeAreaA", {"8B 80 78 02 00 00 48 83 C4 28 C3 E8 50"
, "8B ?? ?? ?? ?? ?? 48 83 ?? ?? C3 ?? ?? 83 ?? ?? CC"
, "8B ?? ?? ?? ?? ?? 48 83 ?? ?? C3 E8 ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? ?? 80 ?? ?? ?? 74"
, "48 ?? ?? ?? ?? ?? ?? 89 ?? ?? 48 ?? ?? ?? ?? ?? ?? ?? ?? ?? 48 ?? ?? 48 ?? ?? ?? ?? ?? ?? 89 ?? ?? 48 ?? ?? ?? ?? ?? ?? ?? ?? ?? 48 ?? ?? 48 ?? ?? ?? ?? ?? ?? 89 ?? ?? 48 ?? ?? ?? ?? ?? ?? ?? ?? ?? 48 ?? ?? 48 ?? ?? ?? ?? ?? ?? 89 ?? ?? 48 ?? ?? ?? ?? ?? ?? ?? ?? ?? 48 ?? ?? 48 ?? ?? 48 ?? ?? 48 ?? ?? ?? ?? ?? ?? 83"
, "8B ?? ?? ?? ?? ?? 48 ?? ?? ?? C3 E8 ?? ?? ?? ?? CC CC CC CC CC CC CC CC CC CC CC CC CC CC CC CC 80 ?? ?? ?? 74 ?? 33 ?? E9 ?? ?? ?? ?? 33 ?? E9 ?? ?? ?? ?? CC CC CC CC CC CC CC CC CC CC CC CC 48 ?? ?? ?? 48 ?? ?? ??"})
{$asm}

alloc(KeyCountWhenChangeAreaACopy,30)
registersymbol(KeyCountWhenChangeAreaACopy)
alloc(seeKeyCountWhenChangeAreaAStatus,8)
registersymbol(seeKeyCountWhenChangeAreaAStatus)
seeKeyCountWhenChangeAreaAStatus:
dq 0

KeyCountWhenChangeAreaACopy:
  readmem(KeyCountWhenChangeAreaA,30)

{$lua}
-- Register list (same as Script 1)
local ExtraMoveSpeedZaRegs = { "rax", "rbx", "rcx", "rdx", "rsi", "rdi",  "r8",  "r9",  "r10",  "r11",  "r12",  "r13",  "r14",  "r15", "rbp",  "rsp"  }

-- Store references
_G.KeyCountWhenChangeAreaAAddressEntry = nil
_G.KeyCountWhenChangeAreaAOriginalStaticAddress = nil
_G.LastKeyCountWhenChangeAreaAInjectionCheck = 0

local function findOrCreateKeyCountWhenChangeAreaAValueEntry()
  if "See" == "See" then
    return nil  -- Non creare entry per il valore in modalità See
  end

  local addrList = getAddressList()
  local valueSymbolName = ""
  if "See" == "Set" then
    valueSymbolName = "setKeyCountWhenChangeAreaAValue"
  elseif "See" == "Add" then
    valueSymbolName = "addKeyCountWhenChangeAreaAValue"
  elseif "See" == "Sub" then
    valueSymbolName = "subKeyCountWhenChangeAreaAValue"
  end

  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == valueSymbolName then
      _G.KeyCountWhenChangeAreaAValueAddressEntry = entry
      return entry
    end
  end

  local entry = addrList.createMemoryRecord()
  entry.Description = "KeyCountWhenChangeAreaA Value (See)"
  entry.Type = vtDword
  entry.Address = valueSymbolName
  _G.KeyCountWhenChangeAreaAValueAddressEntry = entry
  return entry
end

local function scanForKeyCountWhenChangeAreaAOffset(baseAddr, searchLimit)
  local currentAddress = tonumber(baseAddr)
  for i = 1, (searchLimit or 8) do
    local disasmStr = disassemble(currentAddress)
    if disasmStr then
      for _, reg in ipairs(ExtraMoveSpeedZaRegs) do
        local hexOffset = disasmStr:match("%["..reg.."%+([0-9A-Fa-f]+)%]")
        if hexOffset then return tonumber(hexOffset,16) end
        for _, reg2 in ipairs(ExtraMoveSpeedZaRegs) do
          if reg2 ~= reg then
            local hexOffset2 = disasmStr:match("%["..reg.."%+"..reg2.."%+([0-9A-Fa-f]+)%]")
            if hexOffset2 then
              return tonumber(hexOffset2,16)
            end
          end
        end
      end
    end
    currentAddress = currentAddress + (getInstructionSize(currentAddress) or 1)
  end
  return 0
end

local function KeyCountWhenChangeAreaAArrayMonitor()
  -- Check if Script 1 is still active
  if not _G.unlimitedExtraMoveSpeedZaTimer then
   -- print("Warning: Script 1 is no longer active!")
    return
  end

  local KeyCountWhenChangeAreaAInjectionAddr = getAddressSafe("KeyCountWhenChangeAreaACopy")
  if not KeyCountWhenChangeAreaAInjectionAddr then return end

  -- Check if KeyCountWhenChangeAreaA array has been executed recently (event occurred)
  local currentKeyCountWhenChangeAreaACheck = readInteger(KeyCountWhenChangeAreaAInjectionAddr)

  -- If KeyCountWhenChangeAreaA array was executed (new event), update cached offset
  if currentKeyCountWhenChangeAreaACheck ~= _G.LastKeyCountWhenChangeAreaAInjectionCheck then
    local foundKeyCountWhenChangeAreaAOffset = scanForKeyCountWhenChangeAreaAOffset(KeyCountWhenChangeAreaAInjectionAddr, 8)
    if foundKeyCountWhenChangeAreaAOffset and foundKeyCountWhenChangeAreaAOffset ~= 0 then
      _G.CachedKeyCountWhenChangeAreaAOffset = foundKeyCountWhenChangeAreaAOffset
      --print(string.format("KeyCountWhenChangeAreaA offset found and cached: 0x%X", foundKeyCountWhenChangeAreaAOffset))
    --  print("Script 1 will now handle KeyCountWhenChangeAreaA value using See operation with this offset!")

      -- Store the original static address for cleanup
      if not _G.KeyCountWhenChangeAreaAOriginalStaticAddress then
        _G.KeyCountWhenChangeAreaAOriginalStaticAddress = getAddressSafe("seeKeyCountWhenChangeAreaAStatus")
      end
    end
    _G.LastKeyCountWhenChangeAreaAInjectionCheck = currentKeyCountWhenChangeAreaACheck
  end
end

-- Cleanup any existing secondary timer first
if _G.KeyCountWhenChangeAreaAArrayTimer and _G.KeyCountWhenChangeAreaAArrayTimer.destroy then
  _G.KeyCountWhenChangeAreaAArrayTimer.destroy()
  _G.KeyCountWhenChangeAreaAArrayTimer = nil
end

-- Reset variables
_G.KeyCountWhenChangeAreaAAddressEntry = nil
_G.KeyCountWhenChangeAreaAOriginalStaticAddress = nil
_G.LastKeyCountWhenChangeAreaAInjectionCheck = 0

-- Create secondary monitoring timer
if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.KeyCountWhenChangeAreaAArrayTimer = createTimer(nil, false)
    _G.KeyCountWhenChangeAreaAArrayTimer.Interval = 25
    _G.KeyCountWhenChangeAreaAArrayTimer.OnTimer = KeyCountWhenChangeAreaAArrayMonitor
    _G.KeyCountWhenChangeAreaAArrayTimer.Enabled = true

    findOrCreateKeyCountWhenChangeAreaAValueEntry()

    --print("Script 4 (KeyCountWhenChangeAreaA) is now monitoring for events...")
    --print("Values will be handled by Script 1 using See operation when offset is found.")
  end
  startupTimer.Enabled = true
end
{$asm}

[DISABLE]

{$lua}
-- Stop and destroy secondary timer
if _G.KeyCountWhenChangeAreaAArrayTimer and _G.KeyCountWhenChangeAreaAArrayTimer.destroy then
  _G.KeyCountWhenChangeAreaAArrayTimer.destroy()
  _G.KeyCountWhenChangeAreaAArrayTimer = nil
end

-- IMPORTANT: Reset the secondary symbol to its original static address
if _G.KeyCountWhenChangeAreaAOriginalStaticAddress then
  unregisterSymbol("seeKeyCountWhenChangeAreaAStatus")
  registerSymbol("seeKeyCountWhenChangeAreaAStatus", _G.KeyCountWhenChangeAreaAOriginalStaticAddress)

  -- Find and force refresh any existing secondary entry
  local addrList = getAddressList()
  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeKeyCountWhenChangeAreaAStatus" then
      -- Force refresh the entry to use the static address
      entry.Address = string.format("0x%X", _G.KeyCountWhenChangeAreaAOriginalStaticAddress)
      sleep(1)
      entry.Address = "seeKeyCountWhenChangeAreaAStatus"
      break
    end
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeKeyCountWhenChangeAreaAStatus")
  if allocatedAddr then
    unregisterSymbol("seeKeyCountWhenChangeAreaAStatus")
    registerSymbol("seeKeyCountWhenChangeAreaAStatus", allocatedAddr)

  -- Force refresh any existing entry
  local addrList = getAddressList()
  for i = 0, addrList.Count-1 do
    local entry = addrList[i]
    if entry.Address == "seeKeyCountWhenChangeAreaAStatus" then
      entry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      entry.Address = "seeKeyCountWhenChangeAreaAStatus"
      break
    end
  end
  end
end

-- Don't remove value entry from address list to keep it visible
if _G.KeyCountWhenChangeAreaAValueAddressEntry then
  _G.KeyCountWhenChangeAreaAValueAddressEntry = nil
end

-- Reset secondary variables
_G.KeyCountWhenChangeAreaAAddressEntry = nil
_G.KeyCountWhenChangeAreaAOriginalStaticAddress = nil
_G.LastKeyCountWhenChangeAreaAInjectionCheck = 0
_G.lastKeyCountWhenChangeAreaAValue = nil

-- Clear the cached offset so Script 1 stops handling secondary values
_G.CachedKeyCountWhenChangeAreaAOffset = nil

--print("Script 4 (KeyCountWhenChangeAreaA) disabled. Secondary pointer reset to static address.")
{$asm}

unregistersymbol(*)
dealloc(*)

