if _G.unlimitedAncientBloodOnPickUpATimer and _G.unlimitedAncientBloodOnPickUpATimer.destroy then
  _G.unlimitedAncientBloodOnPickUpATimer.destroy()
  _G.unlimitedAncientBloodOnPickUpATimer = nil
end

if _G.AncientBloodOnPickUpAOriginalStaticAddress then
  unregisterSymbol("seeAncientBloodOnPickUpAStatus")
  registerSymbol("seeAncientBloodOnPickUpAStatus", _G.AncientBloodOnPickUpAOriginalStaticAddress)

  if _G.AncientBloodOnPickUpAAddressEntry then
    _G.AncientBloodOnPickUpAAddressEntry.Address = string.format("0x%X", _G.AncientBloodOnPickUpAOriginalStaticAddress)
    sleep(1)
    _G.AncientBloodOnPickUpAAddressEntry.Address = "seeAncientBloodOnPickUpAStatus"
  end
else
  -- Fallback: get current allocated address and reset symbol
  local allocatedAddr = getAddressSafe("seeAncientBloodOnPickUpAStatus")
  if allocatedAddr then
    unregisterSymbol("seeAncientBloodOnPickUpAStatus")
    registerSymbol("seeAncientBloodOnPickUpAStatus", allocatedAddr)

    if _G.AncientBloodOnPickUpAAddressEntry then
      _G.AncientBloodOnPickUpAAddressEntry.Address = string.format("0x%X", allocatedAddr)
      sleep(1)
      _G.AncientBloodOnPickUpAAddressEntry.Address = "seeAncientBloodOnPickUpAStatus"
    end
  end
end

_G.AncientBloodOnPickUpAEntryCreated = false
_G.AncientBloodOnPickUpAValueEntryCreated = false
_G.AncientBloodOnPickUpAAddressEntry = nil
_G.AncientBloodOnPickUpAOriginalStaticAddress = nil

_G.AncientBloodOnPickUpABasePointer = nil
_G.AncientBloodOnPickUpACurrentRegister = nil
_G.lastAncientBloodOnPickUpAValue = nil

