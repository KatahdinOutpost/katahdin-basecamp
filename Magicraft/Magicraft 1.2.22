-- SCRIPT 1: Memory Monitor (Fixed) - Config in CE Script
local targetSymbols = {"TestA", "TestB", "TestC", "TestD", "TestE", "TestF", "TestG", "TestH", "TestI", "TestJ", "TestK", "TestL", "TestM", "TestN", "TestO", "TestP", "TestQ", "TestR", "TestS", "TestT"}
local userDefinedValues = {}
local lastValidAddresses = {}

local monitorTimer = createTimer(nil, true)
monitorTimer.Interval = 555

-- Function to get a valid address
local function getValidAddress(symbol)
    return getAddressSafe(symbol)
end

-- Function to check if an address is a float
local function isFloatValue(address)
    return address % 4 == 0
end

-- Function to save configuration in a CE script
local function saveMonitorConfig()
    local addressList = getAddressList()
    local scriptRecord = addressList.getMemoryRecordByDescription('MemoryMonitor_Config')

    -- Create config record if it doesn't exist
    if not scriptRecord then
        scriptRecord = addressList.createMemoryRecord()
        scriptRecord.Description = 'MemoryMonitor_Config'
        scriptRecord.Type = vtAutoAssembler
    end

    -- Build the configuration script
    local configScript = "// Memory Monitor Configuration - DO NOT MODIFY MANUALLY\n"
    configScript = configScript .. "{$lua}\n"

    -- Add initialization of the config table
    configScript = configScript .. "if not memoryMonitorConfig then\n"
    configScript = configScript .. "  memoryMonitorConfig = {}\n"
    configScript = configScript .. "end\n"
    configScript = configScript .. "if not memoryMonitorConfig.userDefinedValues then\n"
    configScript = configScript .. "  memoryMonitorConfig.userDefinedValues = {}\n"
    configScript = configScript .. "end\n\n"

    -- Add the actual values
    configScript = configScript .. "-- User defined values\n"
    for symbol, value in pairs(userDefinedValues) do
        configScript = configScript .. string.format("memoryMonitorConfig.userDefinedValues['%s'] = %s\n", symbol, tostring(value))
    end

    configScript = configScript .. "{$asm}\n\n"
    configScript = configScript .. "[ENABLE]\n"
    configScript = configScript .. "// Configuration loaded\n"
    configScript = configScript .. "[DISABLE]\n"
    configScript = configScript .. "// Configuration preserved\n"

    -- Set the script and activate it
    scriptRecord.Script = configScript
    scriptRecord.Active = true
end

-- Function to load configuration from the CE script
local function loadMonitorConfig()
    local addressList = getAddressList()
    local scriptRecord = addressList.getMemoryRecordByDescription('MemoryMonitor_Config')

    if not scriptRecord then
        return {}
    end

    -- Ensure the script is active to load the configuration
    if not scriptRecord.Active then
        scriptRecord.Active = true
    end

    -- Check if the configuration table exists
    if memoryMonitorConfig and memoryMonitorConfig.userDefinedValues then
        return memoryMonitorConfig
    end

    -- If the table doesn't exist yet, try to parse the script content directly
    local scriptContent = scriptRecord.Script
    if scriptContent then
        local config = {userDefinedValues = {}}

        for line in scriptContent:gmatch("[^\r\n]+") do
            local symbol, value = line:match("memoryMonitorConfig%.userDefinedValues%['([^']+)'%] = ([^\r\n]+)")
            if symbol and value then
                -- Convert the value to number if possible
                local numValue = tonumber(value)
                if numValue then
                    config.userDefinedValues[symbol] = numValue
                else
                    -- Handle boolean values
                    if value == "true" then
                        config.userDefinedValues[symbol] = true
                    elseif value == "false" then
                        config.userDefinedValues[symbol] = false
                    else
                        config.userDefinedValues[symbol] = value
                    end
                end
            end
        end

        return config
    end

    return {}
end

-- Function to immediately apply all saved values to memory
local function applyAllValuesToMemory()
    for _, targetSymbol in ipairs(targetSymbols) do
        local currentAddr = getValidAddress(targetSymbol)
        if currentAddr and currentAddr ~= 0 and userDefinedValues[targetSymbol] then
            synchronize(function()
                if isFloatValue(currentAddr) then
                    writeFloat(currentAddr, userDefinedValues[targetSymbol])
                else
                    writeInteger(currentAddr, userDefinedValues[targetSymbol])
                end
            end)
            lastValidAddresses[targetSymbol] = currentAddr
        end
    end
end

-- Monitoring function with synchronization
monitorTimer.OnTimer = function()
    for _, targetSymbol in ipairs(targetSymbols) do
        local currentAddr = getValidAddress(targetSymbol)

        if currentAddr and currentAddr ~= 0 then
            if lastValidAddresses[targetSymbol] == nil or currentAddr ~= lastValidAddresses[targetSymbol] then
                -- Address changed - apply user value immediately
                synchronize(function()
                    if userDefinedValues[targetSymbol] then
                        if isFloatValue(currentAddr) then
                            writeFloat(currentAddr, userDefinedValues[targetSymbol])
                        else
                            writeInteger(currentAddr, userDefinedValues[targetSymbol])
                        end
                    end
                end)
                lastValidAddresses[targetSymbol] = currentAddr
            else
                -- Read current value and update if changed
                local guiValue
                if isFloatValue(currentAddr) then
                    guiValue = readFloat(currentAddr)
                else
                    guiValue = readInteger(currentAddr)
                end

                if userDefinedValues[targetSymbol] ~= guiValue then
                    userDefinedValues[targetSymbol] = guiValue
                    saveMonitorConfig()
                end
            end
        else
            lastValidAddresses[targetSymbol] = nil
        end
    end
end

-- Initialization function
local function initialize()
    -- Load saved values from CE configuration
    local config = loadMonitorConfig()

    if config.userDefinedValues then
        userDefinedValues = config.userDefinedValues
    else
        userDefinedValues = {}
    end

    -- Initialize values for each symbol and apply to memory immediately
    for _, targetSymbol in ipairs(targetSymbols) do
        local initialAddr = getValidAddress(targetSymbol)
        if initialAddr and initialAddr ~= 0 then
            synchronize(function()
                if isFloatValue(initialAddr) then
                    -- Use saved value or read current value
                    if userDefinedValues[targetSymbol] == nil then
                        userDefinedValues[targetSymbol] = readFloat(initialAddr)
                    else
                        writeFloat(initialAddr, userDefinedValues[targetSymbol])
                    end
                else
                    -- Use saved value or read current value
                    if userDefinedValues[targetSymbol] == nil then
                        userDefinedValues[targetSymbol] = readInteger(initialAddr)
                    else
                        writeInteger(initialAddr, userDefinedValues[targetSymbol])
                    end
                end
            end)
            lastValidAddresses[targetSymbol] = initialAddr
        end
    end

    -- Save initial configuration
    saveMonitorConfig()

    -- Force immediate application of all values
    applyAllValuesToMemory()
end

-- Function to stop monitoring
function stopMonitor()
    if monitorTimer then
        monitorTimer.destroy()
        monitorTimer = nil
    end
end

-- Function to force reload and reapply all values
function forceReloadAndApply()
    local config = loadMonitorConfig()
    if config.userDefinedValues then
        userDefinedValues = config.userDefinedValues
        applyAllValuesToMemory()
    end
end

-- Add menu item to main form for easy access
local function addMonitorToMenu()
    local mainForm = getMainForm()
    if not mainForm then
        -- Retry after a delay if main form isn't ready
        local timer = createTimer()
        timer.Interval = 1000
        timer.OnTimer = function(t)
            t.destroy()
            addMonitorToMenu()
        end
        return
    end

    local mainMenu = mainForm.Menu
    if mainMenu then
        -- Remove existing menu item if any
        for i = mainMenu.Items.Count - 1, 0, -1 do
            if mainMenu.Items[i].Caption == "Memory Monitor" then
                mainMenu.Items.delete(i)
            end
        end

        local monitorMenu = createMenuItem(mainMenu)
        monitorMenu.Caption = "Memory Monitor"

        local reloadConfig = createMenuItem(monitorMenu)
        reloadConfig.Caption = "Reload &amp;&amp; Apply All Values"
        reloadConfig.OnClick = function()
            forceReloadAndApply()
        end

        local showValues = createMenuItem(monitorMenu)
        showValues.Caption = "Show Current Values"
        showValues.OnClick = function()
            print("=== Memory Monitor Current Values ===")
            for _, symbol in ipairs(targetSymbols) do
                local value = userDefinedValues[symbol]
                local addr = getValidAddress(symbol)
                local currentMemValue = "N/A"

                if addr and addr ~= 0 then
                    if isFloatValue(addr) then
                        currentMemValue = string.format("%f", readFloat(addr))
                    else
                        currentMemValue = string.format("%d", readInteger(addr))
                    end
                end

                if value then
                    print(string.format("%s = %s (Memory: %s)", symbol, tostring(value), currentMemValue))
                else
                    print(string.format("%s = &lt;not set&gt; (Memory: %s)", symbol, currentMemValue))
                end
            end
            print("=====================================")
        end

        local stopMenu = createMenuItem(monitorMenu)
        stopMenu.Caption = "Stop Monitor"
        stopMenu.OnClick = function()
            stopMonitor()
        end

        monitorMenu.add(reloadConfig)
        monitorMenu.add(showValues)
        monitorMenu.add(stopMenu)
        mainMenu.Items.add(monitorMenu)
    end
end

-- Initialize with a small delay to ensure CE is ready
local initTimer = createTimer()
initTimer.Interval = 1000
initTimer.OnTimer = function(t)
    t.destroy()
    initialize()
    addMonitorToMenu()

    -- Additional forced application after a short delay to catch late-loaded scripts
    local delayedApplyTimer = createTimer()
    delayedApplyTimer.Interval = 3000
    delayedApplyTimer.OnTimer = function(dt)
        dt.destroy()
        applyAllValuesToMemory()
    end
end




