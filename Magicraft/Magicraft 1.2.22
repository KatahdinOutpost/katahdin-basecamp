if syntaxcheck then return end
function aob_register(sym, patterns)
    if type(patterns) == "string" then
        patterns = {patterns}
    end

    local lastError = ""
    for _, pat in ipairs(patterns) do
        local instr = AOBScan(pat, "+X")
        if instr and instr.Count &gt; 0 then
            local addy = instr[0]
            instr.destroy()
            unregisterSymbol(sym)
            registerSymbol(sym, tonumber(addy,16))
            return true
        else
            if instr then instr.destroy() end
            lastError = lastError .. "Pattern not found: " .. pat .. "\n"
        end
    end

    error('No patterns found!\n' .. lastError)
end

function calculateInstructionDetails(address)
    local totalSize = 0
    local instructionCount = 0
    local currentAddr = tonumber(address)

    while totalSize &lt; 5 do
        local size = getInstructionSize(currentAddr)
        if not size or size == 0 then
            error('Could not determine instruction size at address: ' .. string.format('0x%X', currentAddr))
        end
        totalSize = totalSize + size
        currentAddr = currentAddr + size
        instructionCount = instructionCount + 1
    end

    local nopCount = totalSize - 5
    return totalSize, nopCount, instructionCount
end
aob_register("KeysCountWhenPickUpOrUseA", {"48 63 90 78 02"
