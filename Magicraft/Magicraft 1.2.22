    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastAncientBloodOnPickUpAValue then
        _G.lastAncientBloodOnPickUpAValue = currentValue
      elseif currentValue &gt; _G.lastAncientBloodOnPickUpAValue then
        local newValue = currentValue + value
        writeInteger(addr, newValue)
        _G.lastAncientBloodOnPickUpAValue = newValue
      else
        _G.lastAncientBloodOnPickUpAValue = currentValue
      end
    end
  elseif operation == "Sub" then
    local valueAddr = getAddressSafe("subAncientBloodOnPickUpAValue")
    local value = readInteger(valueAddr)
    local currentValue = readFunc(addr)
    if currentValue then
      if not _G.lastAncientBloodOnPickUpAValue then
        _G.lastAncientBloodOnPickUpAValue = currentValue
      elseif currentValue &gt; _G.lastAncientBloodOnPickUpAValue then
        local newValue = currentValue - value
        writeInteger(addr, newValue)
        _G.lastAncientBloodOnPickUpAValue = newValue
      else
        _G.lastAncientBloodOnPickUpAValue = currentValue
      end
    end
  end
end

local function AncientBloodOnPickUpATimerCallback()
  local injectionAddr = getAddressSafe("AncientBloodOnPickUpACopy")
  if not injectionAddr then return end

  local reg, immediate, reg2 = scanForAncientBloodOnPickUpAPattern(injectionAddr, 8)
  if not reg then return end

  local debugBufferAddr = getAddressSafe("seeAncientBloodOnPickUpA")
  if not debugBufferAddr then return end

  local bufferOffset = AncientBloodOnPickUpARegBufferOffsets[reg]
  if not bufferOffset then return end

  local pointerBase = readQword(debugBufferAddr + bufferOffset)
  if not pointerBase or pointerBase == 0 then return end

  _G.AncientBloodOnPickUpABasePointer = pointerBase
  _G.AncientBloodOnPickUpACurrentRegister = reg

  -- Support two-register addressing: [reg1+reg2+offset]
  local reg2Value = 0
  if reg2 and AncientBloodOnPickUpARegBufferOffsets[reg2] then
    local r2v = readQword(debugBufferAddr + AncientBloodOnPickUpARegBufferOffsets[reg2])
    if r2v then reg2Value = r2v end
  end

  local primaryAddr = pointerBase + reg2Value + immediate

  if not _G.AncientBloodOnPickUpAOriginalStaticAddress then
    _G.AncientBloodOnPickUpAOriginalStaticAddress = getAddressSafe("seeAncientBloodOnPickUpAStatus")
  end

  unregisterSymbol("seeAncientBloodOnPickUpAStatus")
  registerSymbol("seeAncientBloodOnPickUpAStatus", primaryAddr)
  forceRefreshExistingEntry("seeAncientBloodOnPickUpAStatus", primaryAddr)
  handleAncientBloodOnPickUpAOperation(primaryAddr, "See", "4 Bytes")

  if not _G.AncientBloodOnPickUpAEntryCreated then
    findOrCreateAncientBloodOnPickUpAEntry()
    _G.AncientBloodOnPickUpAEntryCreated = true
  end

  if not _G.AncientBloodOnPickUpAValueEntryCreated then
    findOrCreateAncientBloodOnPickUpAValueEntry()
    _G.AncientBloodOnPickUpAValueEntryCreated = true
  end
end

if _G.unlimitedAncientBloodOnPickUpATimer and _G.unlimitedAncientBloodOnPickUpATimer.destroy then
  _G.unlimitedAncientBloodOnPickUpATimer.destroy()
  _G.unlimitedAncientBloodOnPickUpATimer = nil
end

_G.AncientBloodOnPickUpAEntryCreated = false
_G.AncientBloodOnPickUpAValueEntryCreated = false
_G.AncientBloodOnPickUpAAddressEntry = nil
_G.AncientBloodOnPickUpAOriginalStaticAddress = nil

if not _G.AncientBloodOnPickUpABasePointer then _G.AncientBloodOnPickUpABasePointer = nil end
if not _G.AncientBloodOnPickUpACurrentRegister then _G.AncientBloodOnPickUpACurrentRegister = nil end

if not syntaxcheck then
  local startupTimer = createTimer(nil, false)
  startupTimer.Interval = 50
  startupTimer.OnTimer = function(timer)
    if timer and timer.destroy then
      timer.destroy()
    end

    _G.unlimitedAncientBloodOnPickUpATimer = createTimer(nil, false)
    _G.unlimitedAncientBloodOnPickUpATimer.Interval = 555
    _G.unlimitedAncientBloodOnPickUpATimer.OnTimer = AncientBloodOnPickUpATimerCallback
    _G.unlimitedAncientBloodOnPickUpATimer.Enabled = true
  end
  startupTimer.Enabled = true
end
