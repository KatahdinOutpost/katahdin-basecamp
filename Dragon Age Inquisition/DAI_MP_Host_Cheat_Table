KillHumans:
//Health Regen
  mov [rbx-18],(float)-5
//HealOnKill
  mov [rbx+788],0
//Current Health
  mov [rbx-60],0
  jmp SkipStats

NPCs:
//Skip if no human with SuperPowers exist yet
