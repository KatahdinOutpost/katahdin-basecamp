PlayGod:
//Overwritten Code
  movaps xmm7,[rsp+40]
  movss [rbx+30],xmm6
  movaps xmm6,[rsp+50]
//Backup and Start
  pushfq
  push rax
  push rcx
  push rsi
  push rdi
//Ensure its the correct instance (*Potential* CRASH Guard)
  cmp r13,10
  jne SkipStats
//
//Check Base Pointer to see if it has changed ~ offset sometimes too large for direct use according to CE (Slot 1)
  mov rax,"DragonAgeInquisition.exe"+02A5D280
  mov rax,[rax]
//IsPossiblyRealAddress
  cmp rax,1000000
  jle SkipStats
//
  mov rsi,[LastPointerStart]
  cmp rsi,rax
  jne ResetStats
//Save for later checks (Part of *Potential* CRASH Guard)
  movss [Loaded],xmm8
//Abort Loaded Check if SuperHumans already exist, was causing issues with newly joining players reseting the loaded amount
  cmp byte ptr [IsSuperHumanDetected],1
  je StartCheck
//This should be 100 once fully loaded (*Potential* CRASH Guard)
  cmp dword ptr [Loaded],(float)100
  jne SkipStats
StartCheck:
  mov rsi,rbx
//IsPossiblyRealAddress
  cmp rsi,1000000
  jle SkipStats
//
  mov rsi,[rsi+20]
//IsPossiblyRealAddress
  cmp rsi,1000000
  jle SkipStats
//
  xor rcx,rcx
  add rsi,9C
WiggleRoom:
  mov rax,rcx
  add rax,rsi
  inc rcx
  cmp rcx,38
  jg NPCs
//Check for Players
  mov rdi,'_Consuma'
  cmp [rax],rdi
  je Players
//Another, rarer, check for Saarebas Players ~ doesnt seem to be a need to use it (stat offset of -90 if that changes)
  mov rdi,'t_Health'
  cmp [rax],rdi
  je SkipStats
//Check for Saarebas Players
  mov rdi,'_Enduran'
  cmp [rax],rdi
  jne WiggleRoom
  mov byte ptr [IsSaarebas],1
//Align code for Saarebas
  sub rbx,AB0
Players:
//Check if I killed that player (myself usually via Health Regen %)
  cmp [rbx-18],(float)-5
  je QuickerHumanKills
//Check if SuperPowers already given to player (Armor)
  cmp [rbx-210],(float)420
  jge SuperHuman
  cmp byte ptr [IsKillHumansActive],1
  je KillHumans
//Are SuperPowers even supposed to be given out?
  cmp byte ptr [IsEnableSuperPowers],1
  jne SkipStats
//Check if autokill is on so everyone has a visual indicator (once they realize it)
  cmp byte ptr [IsAutoKillHumansOnXP],1
  je NoRegen
//Health Regen
  mov [rbx-18],(float)20
  jmp Move
NoRegen:
//Heal On Kill
  mov [rbx+788],0
Move:
//Speed Max
  mov [rbx+420],(float)6
//Speed Modified
  mov [rbx+230],(float)3
//Health Max
  mov [rbx-D50],(float)420420
//Health Current, eg if IsAutoKillOnXP is actived ~  keep them safe despite being in the red...
  mov [rbx-60],(float)100100
//Secondary Regen
  mov [rbx+80],(float)90
//Attack
  mov [rbx-A80],(float)222222
//Cooldown Reduction
  mov [rbx+E90],(float)90
//Critical Chance
  mov [rbx-4E0],(float)100
//Increase Stealth Detection Range
  mov [rbx+D20],(float)90
//Make Main Hand Rune Damage equal Main Hand Weapon Damage
  mov rax,[rbx-A38]
  mov [rbx+C00],rax
//Make Off Hand Rune Damage equal Off Hand Weapon Damage
  mov rax,[rbx-9F0]
  mov [rbx+BB8],rax
//Elusive Current (Older visual notification and AutoKillAfterXP aid but no reason to remove it either?)
  mov [rbx+1C50],(float)4
//Armor
  mov [rbx-210],(float)420
//Armor Front
  mov [rbx+1740],(float)420
SkipStats:
//Check if Saarebas was set
  cmp byte ptr [IsSaarebas],1
  jne StandardSkip
//Un-align code for Saarebas
  add rbx,AB0
//Revert to default of not Saarebas for next cycle
  mov byte ptr [IsSaarebas],0
StandardSkip:
//Restore Registers and Flags to original values
  pop rdi
  pop rsi
  pop rcx
  pop rax
  popfq
//Returning you to your original programming...
  jmp ReturnStats

QuickerHumanKills:
  cmp [rbx-60],(float)100100
  jle SkipStats
  mov [rbx-60],(float)100100
  jmp SkipStats

SuperHuman:
  mov byte ptr [IsSuperHumanDetected],1
SuperHumanReturn:
  cmp byte ptr [IsKillHumansActive],1
  je KillHumans
  cmp byte ptr [IsAutoKillHumansOnXP],1
  jne SkipStats
CheckSuicide:
//Final suicide check, is XP set?
